---
import ThemeBuilder from "../../components/bench/ThemeBuilder.svelte";
import Base from "../../layouts/Base.astro";
import { getStats } from "../../data/stats";

const { tokens } = await getStats();
---

<Base
	title="Theme Builder: xtyle"
	description={`The theme studio. Pick an algorithm, then set anchors, knobs, or any of the ${tokens} tokens directly, and watch the whole register derive live. Contrast, coverage, gamut, and token-graph inspectors are built in.`}
>
	<ThemeBuilder client:only="svelte" />
</Base>
