---
import Base from "../layouts/Base.astro";
import Panel from "@xtyle/astro/Panel.astro";
import Dock from "@xtyle/astro/Dock.astro";
import Toc from "@xtyle/astro/Toc.astro";
import Alert from "@xtyle/astro/Alert.astro";
import Link from "@xtyle/astro/Link.astro";
import Table from "@xtyle/astro/Table.astro";
import Code from "@xtyle/astro/Code.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Text from "@xtyle/astro/Text.astro";
import Stack from "@xtyle/astro/Stack.astro";
import Eyebrow from "@xtyle/astro/Eyebrow.astro";
import { derive, makeXtyleAlgorithm, toOklchColor, hueDelta, type AccentStrategy } from "@xtyle/core";
import { toPreset } from "@xtyle/core/authoring";

const sections = [
	{ id: "what", label: "What an algorithm is" },
	{ id: "built-in", label: "The built-in set" },
	{ id: "anatomy", label: "Anatomy of a mod" },
	{ id: "preset", label: "Tier 1: a family preset" },
	{ id: "scratch", label: "Tier 2: from scratch" },
	{ id: "knobs", label: "Declaring knob controls" },
	{ id: "passes", label: "Deriving in passes" },
	{ id: "prove", label: "Prove it" },
	{ id: "load", label: "Load it" },
];

const builtIns = [
	{ id: "xtyle-default", note: "the neutral default; the shared taste with nothing turned up" },
	{ id: "xtyle-quiet", note: "restrained; muted chroma, soft elevation" },
	{ id: "xtyle-loud", note: "vibrant; boosted chroma and punchier depth" },
	{ id: "xtyle-hc", note: "high contrast; an AAA floor for accessibility" },
	{ id: "nxi-nite", note: "Day/Night; a time-of-day pass layered on the base" },
];

const specFields = [
	{ field: "id", type: "string", note: "the algorithm's id, how it loads and derives" },
	{ field: "anchors", type: "{ bg, fg, accent }", note: "baked default anchors; any omitted one derives from the others" },
	{ field: "vibrancy", type: "0–1", note: "how saturated the derivation runs before the knob overrides it" },
	{ field: "chroma", type: "{ accent, status, palette, neutral, accentTint }", note: "per-family chroma multipliers over the shared derivation" },
	{ field: "contrast", type: "{ floor, textOnFill }", note: "the AA/AAA floors the derivation must clear" },
	{ field: "elevation", type: "{ strength, alphaBoost }", note: "shadow weight and overlay opacity" },
	{ field: "accentStrategy", type: '"fan" | "step" | "shade" | "duo"', note: "the accent family this taste ships with — the default for the accentStrategy knob, which a theme can still override" },
	{ field: "knobs", type: "string[]", note: "the knobs this algorithm accepts (defaults to the shared set)" },
	{ field: "knobSpecs", type: "KnobSpec[]", note: "control domains for any knob beyond the shared set, so a knob of your own self-renders in the builder" },
	{ field: "passes", type: "(preset, input) => Pass[]", note: "ordered passes for a staged derivation (single-pass if omitted)" },
];

const knobSpecFields = [
	{ field: "name", type: "string", note: "the knob name, matched against the algorithm's knobs" },
	{ field: "kind", type: '"select" | "range" | "text"', note: "the control the builder renders" },
	{ field: "min / max / step", type: "number", note: "the bounds of a range knob" },
	{ field: "options", type: "{ value, label? }[]", note: "the accepted values of a select knob" },
	{ field: "default", type: "string | number", note: "the value the knob takes when first switched on" },
	{ field: "label", type: "string", note: "a default label hint; a consumer may localize it" },
	{ field: "group", type: "string", note: "sections controls in the builder; defaults to the name" },
	{ field: "unit", type: "string", note: "a suffix intrinsic to the value, e.g. ° for a hue step" },
];

const knobsSnippet = `import { defineAlgorithm } from "@xtyle/core/authoring";

defineAlgorithm({
  id: "mono",
  produces: ["--bg-0", "--fg-0", "--accent"],
  categories: { color: ["--bg-0", "--fg-0", "--accent"] },
  knobs: ["scheme", "punch"],           // 'scheme' is shared; 'punch' is your own
  knobSpecs: [
    { name: "punch", kind: "range", label: "Punch", min: 0, max: 0.4, step: 0.02, default: 0.15 },
  ],
  derive(input, { cuti }) {
    const punch = typeof input.knobs?.punch === "number" ? input.knobs.punch : 0.15;
    const accent = cuti.saturate(input.anchors?.accent ?? "#8a8f98", punch);
    // ... derive the register, its accent chroma lifted by 'punch'
    return [/* nodes */];
  },
});`;

const anatomySnippet = `algorithms/sunrise/
├─ mod-manifest.json   # declares the mod: name, capabilities, entry
└─ src/
   ├─ preset.ts        # the taste, as pure data
   └─ mod.ts           # defineXtyleAlgorithm(spec)`;

const manifestSnippet = `{
  "$schema": "https://xript.dev/schema/mod-manifest/v0.7.json",
  "xript": "0.7",
  "name": "sunrise",
  "version": "0.1.0",
  "title": "Sunrise",
  "family": "xtyle",
  "capabilities": ["color-math"],
  "entry": { "script": "src/mod.js", "format": "script" }
}`;

const presetSnippet = `// src/mod.ts
import { defineXtyleAlgorithm } from "@xtyle/core/authoring";

defineXtyleAlgorithm({
  id: "sunrise",
  anchors: { bg: "#1a1410", accent: "#ff9e5e" },
  vibrancy: 0.7,
  chroma: { accent: 1.4, palette: 1.3 },
  accentStrategy: "step",   // spread accent-2/3/4 evenly, not as flanks + complement
});`;

const scratchSnippet = `import { defineAlgorithm } from "@xtyle/core/authoring";

defineAlgorithm({
  id: "mono",
  produces: ["--bg-0", "--fg-0", "--accent", "--accent-fg"],
  categories: { color: ["--bg-0", "--fg-0", "--accent", "--accent-fg"] },
  knobs: ["scheme"],
  derive(input, { cuti }) {
    const bg = input.anchors?.bg ?? "#101216";
    const accent = cuti.desaturate(input.anchors?.accent ?? "#8a8f98", 0.4);
    const inks = ["#ffffff", "#0a0a0a"];
    return [
      { name: "--bg-0", value: cuti.toHex(bg) },
      { name: "--fg-0", value: cuti.pickReadable(bg, inks), refs: ["--bg-0"] },
      { name: "--accent", value: cuti.toHex(accent) },
      { name: "--accent-fg", value: cuti.pickReadable(accent, inks), refs: ["--accent"] },
    ];
  },
});`;

const passesSnippet = `import { defineXtyleAlgorithm, settlePass } from "@xtyle/core/authoring";

defineXtyleAlgorithm({
  id: "day-cycle",
  passes: (preset, input) => [
    settlePass(preset, input),   // the shared xtyle derivation
    timeOfDayShift(input),       // a register → register transform
  ],
});`;

const proveSnippet = `# prove the invariants across extremes + random anchor sets
npx xtyle gauntlet -a sunrise --mode hosted --depth full

# confirm a component's consumed tokens are all produced
npx xtyle coverage -a sunrise --consumed --bg-0,--fg-0,--accent

# grade a derived theme against the canonical WCAG text/fill pairs
npx xtyle audit -a sunrise`;

const loadSnippet = `npm run build:mods            # bundles src/mod.ts → src/mod.js
npx xtyle derive -a sunrise    # loads by id, derives a theme`;

const fanBg = "#0e1018";
const fanAccent = "#6c5cff";
// `duo` is the one strategy with a second *input*: it reads `--accent-2` as a brand anchor rather
// than deriving it, so the preview pins one to show the mode doing its actual job.
const fanAccent2 = "#ff8a3d";
type FanSwatch = { label: string; hex: string; fg: string; shift: string };
function deriveFan(strategy: AccentStrategy): FanSwatch[] {
	const algorithm = makeXtyleAlgorithm(toPreset({ id: `fan-${strategy}`, accentStrategy: strategy }));
	const register = derive(algorithm, {
		anchors: { bg: fanBg, accent: fanAccent },
		...(strategy === "duo" ? { constraints: { "--accent-2": fanAccent2 } } : {}),
	});
	const baseHue = toOklchColor(register["--accent"]).h;
	const stepsLightness = strategy === "shade" || strategy === "duo";
	return (["--accent", "--accent-2", "--accent-3", "--accent-4"] as const).map((key, i) => {
		const color = toOklchColor(register[key]);
		let shift: string;
		if (strategy === "duo") shift = i < 2 ? "brand" : `L ${Math.round(color.l * 100)}`;
		else if (stepsLightness) shift = `L ${Math.round(color.l * 100)}`;
		else if (i === 0) shift = "base hue";
		else {
			const delta = Math.round(hueDelta(baseHue, color.h));
			shift = `${delta > 0 ? "+" : ""}${delta}°`;
		}
		return {
			label: key === "--accent" ? "accent" : key.replace("--", ""),
			hex: register[key],
			fg: register[`${key}-fg`] ?? "#000",
			shift,
		};
	});
}
const fanComparison = [
	{ fan: "fan", note: "2 and 3 flank the accent; 4 is its complement", swatches: deriveFan("fan") },
	{ fan: "step", note: "all four step evenly around the wheel", swatches: deriveFan("step") },
	{ fan: "shade", note: "one hue, stepped in lightness: a tint and two deeper shades", swatches: deriveFan("shade") },
	{ fan: "duo", note: "two brand colors in, both shaded against the pair's mean lightness", swatches: deriveFan("duo") },
];
---

<Base
	title="Writing algorithms: xtyle"
	description="Author your own xtyle algorithm: a xript mod that maps anchors and knobs into a full token register. Build on the shared derivation or write one from scratch."
>
	<Dock slot="right" side="right" size="sm" label="On this page" hideHeader class="docs-toc-rail">
		<Toc items={sections} />
	</Dock>

	<div class="docs">
		<Stack gap={8}>
			<Stack gap={3}>
				<Eyebrow>Writing algorithms</Eyebrow>
				<Heading level={1} size="3xl">Author your own algorithm</Heading>
				<Text size="lg" tone="muted">
					An algorithm is the durable, reusable asset behind every theme: a named recipe
					that maps a few anchor colors and knobs into a full, internally consistent token
					register. It is a <Link href="https://xript.dev" target="_blank">xript</Link> mod,
					so the toolchain, the capability model, and the zero-authority sandbox come free.
					This page covers what a mod looks like, the two ways to write one, and how to
					prove it before it ships.
				</Text>
			</Stack>

			<Panel title="What an algorithm is" id="what" class="docs-anchor">
				<Stack gap={4}>
					<Text tone="muted">
						The engine (<code>@xtyle/core</code>) is mechanism: the open token register,
						the dependency graph, the contrast math, the coverage contract, emit. It holds
						no opinion about how a ramp should look. The <strong>algorithm is the
						opinion</strong>: how <em>this one</em> derives. A theme is just one
						materialized invocation of an algorithm, so the algorithm is the part worth
						writing once and reusing.
					</Text>
					<Alert severity="info" variant="soft">
						<span slot="title">Mechanism stays in the engine</span>
						If a derivation choice would only ever make sense for one algorithm, it
						belongs in the algorithm, not in <code>@xtyle/core</code>. That split is what
						lets many algorithms share one engine.
					</Alert>
				</Stack>
			</Panel>

			<Panel title="The built-in set" id="built-in" class="docs-anchor">
				<Stack gap={4}>
					<Text tone="muted">
						Six algorithms ship blessed. They are ordinary mods, the same shape yours
						takes, and a good place to read taste off working examples.
					</Text>
					<Table aria-label="Built-in algorithms">
						<table>
							<thead>
								<tr><th>id</th><th>posture</th></tr>
							</thead>
							<tbody>
								{builtIns.map((a) => (
									<tr><td><code>{a.id}</code></td><td>{a.note}</td></tr>
								))}
							</tbody>
						</table>
					</Table>
				</Stack>
			</Panel>

			<Panel title="Anatomy of a mod" id="anatomy" class="docs-anchor">
				<Stack gap={4}>
					<Text tone="muted">
						A mod is a directory: a manifest that declares it, and the code it runs. The
						manifest names the mod, the <code>color-math</code> capability that unlocks the
						<code>cuti</code> color primitives, and the script entry. The four exports the
						host calls (<code>graph</code>, <code>traced</code>, <code>manifest</code>,
						<code>invariants</code>) are registered for you by the authoring helper, so you
						never touch the raw plumbing.
					</Text>
					<Code lang="text" code={anatomySnippet} />
					<Code lang="json" code={manifestSnippet} />
				</Stack>
			</Panel>

			<Panel title="Tier 1: a family preset" id="preset" class="docs-anchor">
				<Stack gap={4}>
					<Text tone="muted">
						The fast path. <code>defineXtyleAlgorithm</code> takes a taste vector and runs
						the shared xtyle derivation for everything you do not override.
						<code>xtyle-default</code>'s entire definition is
						<code>{"{ id: \"xtyle-default\" }"}</code>; from there you turn knobs up or down.
					</Text>
					<Code lang="typescript" code={presetSnippet} />
					<Text tone="muted">Every field is optional but <code>id</code>; the rest fall through to the shared defaults. <code>accentStrategy</code> is the one taste that reshapes the accent family itself, and it is also a knob — so what you set here is the algorithm's default posture, not a lock a theme can't move. <code>fan</code> (the default) flanks the accent with 2/3 and complements it with 4; <code>step</code> walks all four evenly around the hue circle; <code>shade</code> holds one hue and steps its lightness; and <code>duo</code> takes <em>two</em> brand colors — <code>--accent</code> and <code>--accent-2</code> are both inputs, and 3/4 become their shades, placed against the pair's mean lightness so the two ramps read as one system.</Text>
					<div class="fan-compare" role="group" aria-label="Accent strategies compared off one accent">
						{fanComparison.map((row) => (
							<div class="fan-row">
								<div class="fan-head">
									<code>{row.fan}</code>
									<span class="fan-note">{row.note}</span>
								</div>
								<div class="fan-swatches">
									{row.swatches.map((s) => (
										<div class="fan-swatch" style={`background:${s.hex};color:${s.fg}`}>
											<span class="fan-swatch-label">{s.label}</span>
											<span class="fan-swatch-hue">{s.shift}</span>
											<span class="fan-swatch-hex">{s.hex}</span>
										</div>
									))}
								</div>
							</div>
						))}
					</div>
					<Text tone="muted">All four derive off the same <code>{fanAccent}</code> accent (degrees are the hue step off it; <code>L</code> is the OKLCH lightness), and <code>duo</code> takes a second brand anchor of <code>{fanAccent2}</code>. <code>fan</code> keeps the family tight and adds one true opposite; <code>step</code> trades that cohesion for even separation; <code>shade</code> drops hue harmony for one brand color in four depths, so even a near-gray accent stays legible where a hue turn would collapse; <code>duo</code> is the one to reach for when the brand simply <em>is</em> two colors, and neither should be derived from the other.</Text>
					<Table aria-label="defineXtyleAlgorithm spec fields">
						<table>
							<thead>
								<tr><th>field</th><th>type</th><th>what it sets</th></tr>
							</thead>
							<tbody>
								{specFields.map((f) => (
									<tr><td><code>{f.field}</code></td><td><code>{f.type}</code></td><td>{f.note}</td></tr>
								))}
							</tbody>
						</table>
					</Table>
				</Stack>
			</Panel>

			<Panel title="Tier 2: from scratch" id="scratch" class="docs-anchor">
				<Stack gap={4}>
					<Text tone="muted">
						When you want to own the derivation, <code>defineAlgorithm</code> hands you the
						input and the <code>cuti</code> color primitives and asks for the token graph
						back: an array of nodes, each naming a token, its value, and the tokens it
						derives from. Declare what you <code>produce</code> and how it
						<code>categorize</code>s so the coverage contract and emitters know the shape.
					</Text>
					<Code lang="typescript" code={scratchSnippet} />
					<Alert severity="info" variant="soft">
						<span slot="title">One color implementation, shared</span>
						<code>cuti</code> (<code>toOklch</code>, <code>mix</code>,
						<code>pickReadable</code>, <code>contrast</code>, and the rest) is the same
						math the engine derives with, so a token your mod produces can't drift from one
						the engine produces.
					</Alert>
				</Stack>
			</Panel>

			<Panel title="Declaring knob controls" id="knobs" class="docs-anchor">
				<Stack gap={4}>
					<Text tone="muted">
						An algorithm's <code>knobs</code> names the dials it reads;
						<code>knobSpecs</code> declares their <strong>domain</strong>: the kind of
						control, its range or options, its default. Each one then self-renders in the
						theme builder. The shared knobs (<code>scheme</code>, <code>vibrancy</code>,
						<code>contrastBand</code>, <code>density</code>, <code>cues</code>,
						<code>accentSplit</code>, <code>accentShiftStep</code>, <code>typeScale</code>,
						<code>radiusScale</code>) carry their domains for free; declare a
						<code>KnobSpec</code> only for a knob of your own.
					</Text>
					<Code lang="typescript" code={knobsSnippet} />
					<Text tone="muted">
						The builder renders the control straight from your declaration (a range slider,
						a select, or a text field), so a knob no one hardcoded a UI for still appears the
						moment your algorithm reads it. See it live on
						<Link href="/generator">The Bench</Link>: pick an algorithm and its own knobs
						fill the right rail.
					</Text>
					<Table aria-label="KnobSpec fields">
						<table>
							<thead>
								<tr><th>field</th><th>type</th><th>what it sets</th></tr>
							</thead>
							<tbody>
								{knobSpecFields.map((f) => (
									<tr><td><code>{f.field}</code></td><td><code>{f.type}</code></td><td>{f.note}</td></tr>
								))}
							</tbody>
						</table>
					</Table>
					<Alert severity="info" variant="soft">
						<span slot="title">The algorithm owns the domain; the consumer owns cosmetics</span>
						What a knob accepts and how it's shaped (kind, range, options) is the algorithm's
						declaration. A consumer layers only cosmetics on top (a localized label, digit
						precision), so the two never re-litigate who decides a knob's valid values.
					</Alert>
				</Stack>
			</Panel>

			<Panel title="Deriving in passes" id="passes" class="docs-anchor">
				<Stack gap={4}>
					<Text tone="muted">
						An algorithm that derives in stages lists ordered <code>passes</code>. Each is
						a register → register transform; the first receives the anchors and knobs, and
						later ones reshape what came before. A family algorithm typically starts from
						<code>settlePass</code> (the shared derivation) and layers on top.
						<code>nxi-nite</code> is the worked example, shifting the whole palette by
						time of day after the base settles.
					</Text>
					<Code lang="typescript" code={passesSnippet} />
				</Stack>
			</Panel>

			<Panel title="Prove it" id="prove" class="docs-anchor">
				<Stack gap={4}>
					<Text tone="muted">
						The gauntlet runs your algorithm against extreme and random anchor sets and
						checks every invariant it declares: contrast floors held, no token collapsed,
						nothing parsed to <code>NaN</code>. Run it hosted to prove the sandboxed mod
						that actually ships. The coverage check confirms a component's consumed tokens
						are all in what you produce, and <code>xtyle audit</code> grades a materialized
						theme against xtyle's canonical text/fill pairs at the WCAG floors: the
						register-level complement to the gauntlet's algorithm-level sweep, so you can
						read a specific theme's contrast per pair.
					</Text>
					<Code lang="bash" code={proveSnippet} />
					<Text tone="muted">
						The gauntlet proves a theme is <em>safe</em>, not that it is good. For that,
						derive a real theme and look at it under the components on
						<Link href="/generator">The Bench</Link>.
					</Text>
				</Stack>
			</Panel>

			<Panel title="Load it" id="load" class="docs-anchor">
				<Stack gap={4}>
					<Text tone="muted">
						Build the mods to bundle your <code>mod.ts</code> into the self-contained
						<code>mod.js</code> the host runs, and the algorithm loads by id, the same
						path the built-ins take. From there it works everywhere the engine does: the
						CLI, the importable API, and the browser.
					</Text>
					<Code lang="bash" code={loadSnippet} />
					<Text size="sm" tone="subtle">
						Questions or contributions live on
						<Link href="https://github.com/nekoyoubi/xtyle" target="_blank">GitHub</Link>.
					</Text>
				</Stack>
			</Panel>
		</Stack>
	</div>
</Base>

<style>
	.docs {
		max-width: 56rem;
	}
	.docs-anchor {
		scroll-margin-top: var(--space-5);
	}
	pre {
		margin: 0;
		white-space: pre;
	}
	.fan-compare {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding: var(--space-4);
		border: var(--border-thin) solid var(--bg-3);
		border-radius: var(--radius-md);
		background: var(--bg-1);
	}
	.fan-head {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-2);
		margin-bottom: var(--space-2);
	}
	.fan-note {
		color: var(--fg-2);
		font-size: 0.875rem;
	}
	.fan-swatches {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-2);
	}
	.fan-swatch {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		padding: var(--space-3);
		min-height: 4.5rem;
		border-radius: var(--radius-sm);
		font-size: 0.8125rem;
		line-height: 1.2;
	}
	.fan-swatch-label {
		font-weight: 600;
	}
	.fan-swatch-hue {
		font-size: 0.75rem;
		opacity: 0.85;
	}
	.fan-swatch-hex {
		margin-top: auto;
		font-family: var(--font-mono, ui-monospace, monospace);
		font-size: 0.75rem;
		opacity: 0.85;
	}
	@media (max-width: 30rem) {
		.fan-swatches {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
