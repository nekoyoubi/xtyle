---
interface Props {
	size?: number;
	/** Hide the mark from assistive tech — use when an adjacent text wordmark already names it. */
	decorative?: boolean;
	class?: string;
}
const { size = 22, decorative = false, class: extra } = Astro.props;

const cells = [
	{ tone: "outer", d: "M7 2 1 4.3 1 10.56 7 8.26Z" },
	{ tone: "outer", d: "M7 9.16 1 11.46 1 16.74 7 14.43Z" },
	{ tone: "outer", d: "M7 15.33 1 17.64 1 21.96 7 19.65Z" },
	{ tone: "inner", d: "M9 1.63 15 4.63 15 10.92 9 7.92Z" },
	{ tone: "inner", d: "M9 8.82 15 11.82 15 17.13 9 14.13Z" },
	{ tone: "inner", d: "M9 15.03 15 18.03 15 22.37 9 19.37Z" },
	{ tone: "outer", d: "M17 4.35 23 2.04 23 8.3 17 10.6Z" },
	{ tone: "outer", d: "M17 11.5 23 9.2 23 14.47 17 16.78Z" },
	{ tone: "outer", d: "M17 17.68 23 15.37 23 19.69 17 21.99Z" },
] as const;
---
<svg
	class:list={["xtyle-logo", extra]}
	viewBox="0 0 24 24"
	width={size}
	height={size}
	role={decorative ? undefined : "img"}
	aria-label={decorative ? undefined : "xtyle"}
	aria-hidden={decorative ? "true" : undefined}
>
	<g transform="translate(12 12) scale(-.9 1) translate(-12 -12)">
		{cells.map((c) => (
			<path class:list={["xtyle-logo__panel", `xtyle-logo__panel--${c.tone}`]} d={c.d} />
		))}
	</g>
</svg>

<style>
	.xtyle-logo__panel {
		stroke: var(--bg-0);
		stroke-width: 0.25px;
		vector-effect: non-scaling-stroke;
	}
	.xtyle-logo__panel--outer {
		fill: var(--fg-1);
	}
	.xtyle-logo__panel--inner {
		fill: var(--fg-2);
	}
</style>
