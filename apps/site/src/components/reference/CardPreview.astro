---
/**
 * A compact, live mini-demo of a single component, keyed by manifest id, shown inside its card on
 * the components index. Everything renders from the active xtyle-default theme (the page's ethos:
 * nothing is a mockup). Tonal components spread across a few tones so the grid doubles as a
 * full-tone showcase. Structural/whole-app components (shell, layout) render a small token-built
 * schematic where a faithful live render can't fit a card.
 */
import Badge from "@xtyle/astro/Badge.astro";
import Button from "@xtyle/astro/Button.astro";
import Switch from "@xtyle/astro/Switch.astro";
import Checkbox from "@xtyle/astro/Checkbox.astro";
import Radio from "@xtyle/astro/Radio.astro";
import Rating from "@xtyle/astro/Rating.astro";
import Segmented from "@xtyle/astro/Segmented.astro";
import Slider from "@xtyle/astro/Slider.astro";
import Swatch from "@xtyle/astro/Swatch.astro";
import Progress from "@xtyle/astro/Progress.astro";
import Spinner from "@xtyle/astro/Spinner.astro";
import Dot from "@xtyle/astro/Dot.astro";
import Ribbon from "@xtyle/astro/Ribbon.astro";
import Alert from "@xtyle/astro/Alert.astro";
import Skeleton from "@xtyle/astro/Skeleton.astro";
import Avatar from "@xtyle/astro/Avatar.astro";
import AvatarGroup from "@xtyle/astro/AvatarGroup.astro";
import Icon from "@xtyle/astro/Icon.astro";
import QrCode from "@xtyle/astro/Qr.astro";
import Kbd from "@xtyle/astro/Kbd.astro";
import Link from "@xtyle/astro/Link.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Text from "@xtyle/astro/Text.astro";
import Eyebrow from "@xtyle/astro/Eyebrow.astro";
import Separator from "@xtyle/astro/Separator.astro";
import Breadcrumb from "@xtyle/astro/Breadcrumb.astro";
import Pagination from "@xtyle/astro/Pagination.astro";
import Steps from "@xtyle/astro/Steps.astro";
import Timeline from "@xtyle/astro/Timeline.astro";
import Sparkline from "@xtyle/astro/Sparkline.astro";
import Stat from "@xtyle/astro/Stat.astro";
import Field from "@xtyle/astro/Field.astro";
import NumberInput from "@xtyle/astro/NumberInput.astro";
import Select from "@xtyle/astro/Select.astro";
import Textarea from "@xtyle/astro/Textarea.astro";
import Cluster from "@xtyle/astro/Cluster.astro";
import Chart from "@xtyle/astro/Chart.astro";
import Combobox from "@xtyle/astro/Combobox.astro";
import DatePicker from "@xtyle/astro/DatePicker.astro";
import SplitButton from "@xtyle/astro/SplitButton.astro";
import Markdown from "@xtyle/astro/Markdown.astro";
import List from "@xtyle/astro/List.astro";

interface Props {
	id: string;
}
const { id } = Astro.props;

const statusTones = ["success", "warn", "danger", "info"] as const;
const hueTones = ["red", "orange", "yellow", "green", "blue", "purple", "pink", "cyan"] as const;

const previewZones = [
	{ value: "Europe/London", label: "London" },
	{ value: "Europe/Berlin", label: "Berlin" },
	{ value: "Asia/Tokyo", label: "Tokyo" },
];
const previewLoad = [
	{ name: "Requests", points: [12, 18, 15, 26, 22, 34, 29, 41].map((value, at) => ({ at, value })) },
];
const previewMarkdown = [
	"### Derivation",
	"",
	"An **algorithm** maps anchors into a *full* token set.",
	"",
	"- pin the anchors",
	"- turn the `knobs`",
].join("\n");
---

<div class="cxp" data-preview={id}>
	{id === "badge" && (
		<Cluster gap={1} align="center">
			{statusTones.map((t) => <Badge tone={t} variant="soft">{t}</Badge>)}
		</Cluster>
	)}
	{id === "button" && (
		<Cluster gap={2} align="center">
			<Button variant="solid" tone="accent">Save</Button>
			<Button variant="subtle" tone="neutral">Cancel</Button>
		</Cluster>
	)}
	{id === "switch" && (
		<Cluster gap={3} align="center">
			<Switch checked label="Wi-Fi" />
			<Switch label="Bluetooth" />
		</Cluster>
	)}
	{id === "checkbox" && (
		<Cluster gap={3} align="center">
			<Checkbox checked label="Ship it" />
			<Checkbox label="Draft" />
		</Cluster>
	)}
	{id === "radio" && (
		<Cluster gap={3} align="center">
			<Radio checked name="cxp-radio" label="Daily" />
			<Radio name="cxp-radio" label="Weekly" />
		</Cluster>
	)}
	{id === "rating" && <Rating value={4} max={5} readonly label="4 of 5" />}
	{id === "segmented" && <Segmented label="View" options="Day,Week,Month" value="Week" />}
	{id === "list" && (
		<div class="cxp-list">
			<List
				label="Views"
				interaction="selectable"
				selection="single"
				items={[
					{ value: "inbox", label: "Inbox", lead: "folder" },
					{ value: "starred", label: "Starred", lead: "check", selected: true },
					{ value: "sent", label: "Sent", lead: "search" },
				]}
			/>
		</div>
	)}
	{id === "slider" && <Slider label="Volume" value={62} style="width: 13rem;" />}
	{id === "split-button" && (
		<SplitButton
			tone="accent"
			menuLabel="More save actions"
			items={[
				{ label: "Save and close", value: "save-close" },
				{ label: "Save as draft", value: "save-draft" },
			]}
		>
			Save
		</SplitButton>
	)}
	{id === "swatch" && (
		<Cluster gap={2} align="center">
			<Swatch color="var(--accent)" label="Accent" />
			<Swatch color="var(--success)" label="Success" />
		</Cluster>
	)}
	{id === "progress" && <Progress tone="accent" value={64} showValue aria-label="64%" style="width: 12rem;" />}
	{id === "spinner" && (
		<Cluster gap={3} align="center">
			<Spinner tone="accent" />
			<Spinner tone="success" />
			<Spinner tone="danger" />
		</Cluster>
	)}
	{id === "alert" && <Alert tone="info" severity="info">Heads up, a new version is available.</Alert>}
	{id === "toast" && <Alert tone="success" severity="success">Saved your changes.</Alert>}
	{id === "dot" && (
		<Cluster gap={4} align="center">
			<Dot tone="success" size="lg" />
			<Dot tone="warn" size="lg" pulse="slow" />
			<Dot tone="danger" size="lg" ping />
			<Dot tone="info" size="lg" glow />
		</Cluster>
	)}
	{id === "ribbon" && (
		<div class="cxp-ribbon">
			<Ribbon corner="top-right" tone="accent" size="sm" label="New" />
			<span class="cxp-schema__line" style="width: 62%"></span>
			<span class="cxp-schema__line" style="width: 44%"></span>
		</div>
	)}
	{id === "skeleton" && (
		<Cluster gap={2} align="center">
			<Skeleton shape="circle" style="width: 2rem; height: 2rem;" />
			<div style="display: grid; gap: 0.35rem;">
				<Skeleton shape="line" style="width: 7rem;" />
				<Skeleton shape="line" style="width: 5rem;" />
			</div>
		</Cluster>
	)}
	{id === "empty" && (
		<div class="cxp-empty">
			<Icon name="folder" size="lg" />
			<Text size="xs" tone="muted">No results yet</Text>
		</div>
	)}
	{id === "avatar" && (
		<Cluster gap={2} align="center">
			<Avatar tone="accent" alt="Ada">AL</Avatar>
			<Avatar tone="success" alt="Grace">GH</Avatar>
			<Avatar tone="purple" alt="Alan">AT</Avatar>
		</Cluster>
	)}
	{id === "avatar-group" && (
		<AvatarGroup>
			<Avatar tone="accent" alt="Ada">AL</Avatar>
			<Avatar tone="success" alt="Grace">GH</Avatar>
			<Avatar tone="purple" alt="Alan">AT</Avatar>
			<Avatar tone="warn" alt="Katherine">KJ</Avatar>
		</AvatarGroup>
	)}
	{id === "icon" && (
		<Cluster gap={2} align="center">
			{["search", "folder", "gear", "eye", "palette"].map((n) => <Icon name={n} size="md" />)}
		</Cluster>
	)}
	{id === "kbd" && (
		<Cluster gap={1} align="center">
			<Kbd>Ctrl</Kbd><Text as="span" size="xs" tone="muted">+</Text><Kbd>K</Kbd>
		</Cluster>
	)}
	{id === "link" && (
		<Text size="sm">Read the <Link href="#">derivation model</Link> for the full story.</Text>
	)}
	{id === "heading" && <Heading level={3} size="lg">Section title</Heading>}
	{id === "eyebrow" && (
		<div style="display: grid; gap: 0.15rem;">
			<Eyebrow tracking="wide">Reference</Eyebrow>
			<Heading level={3} size="md">Components</Heading>
		</div>
	)}
	{id === "text" && <Text size="sm">The quick brown fox jumps over the lazy dog.</Text>}
	{id === "markdown" && <div class="cxp-md"><Markdown source={previewMarkdown} /></div>}
	{id === "separator" && (
		<div style="width: 12rem; display: grid; gap: 0.4rem;">
			<Text as="span" size="xs" tone="muted">Above</Text>
			<Separator label="or" />
			<Text as="span" size="xs" tone="muted">Below</Text>
		</div>
	)}
	{id === "breadcrumb" && (
		<Breadcrumb items={[{ label: "Home", href: "#" }, { label: "Components", href: "#" }, { label: "Badge" }]} />
	)}
	{id === "pagination" && <Pagination total={10} current={3} aria-label="Pages" />}
	{id === "steps" && (
		<Steps current={1} style="width: 100%;">
			<ol>
				<li>Cart</li>
				<li>Ship</li>
				<li>Pay</li>
			</ol>
		</Steps>
	)}
	{id === "timeline" && (
		<Timeline>
			<ol>
				<li><strong>Opened</strong><time>9:01</time></li>
				<li><strong>Reviewed</strong><time>9:40</time></li>
			</ol>
		</Timeline>
	)}
	{id === "sparkline" && <Sparkline values={[4, 6, 5, 8, 7, 9, 12, 10, 13]} variant="area" tone="accent" label="Trend" style="--spark-width: 9rem; --spark-height: 2.2rem;" />}
	{id === "stat" && <Stat value="1,284" label="Signups" delta="+12%" trend="up" />}
	{id === "field" && <Field label="Email" value="ada@xtyle.dev" style="width: 13rem;" />}
	{id === "number-input" && <NumberInput label="Qty" value={3} min={0} max={99} />}
	{id === "select" && <Select label="Plan" options="Starter,Pro,Team" value="Pro" style="width: 11rem;" />}
	{id === "textarea" && <Textarea label="Notes" value={"Two lines\nof notes"} rows={2} style="width: 13rem;" />}
	{id === "combobox" && (
		<Combobox label="Time zone" placeholder="Type a city…" options={previewZones} value="Europe/Berlin" clearable style="width: 13rem;" />
	)}
	{id === "date-picker" && <DatePicker label="Ship date" value="2026-07-14" style="width: 12rem;" />}
	{id === "chart" && (
		<div class="cxp-chart">
			<Chart series={previewLoad} variant="area" curve="smooth" height={160} label="Requests over time" static style="width: 12rem;" />
		</div>
	)}

	{/* Schematics: structural / whole-app / heavy components rendered as a token-built diagram. */}
	{id === "card" && <div class="cxp-schema cxp-card"><span class="cxp-schema__head"></span><span class="cxp-schema__line" style="width: 80%"></span><span class="cxp-schema__line" style="width: 55%"></span></div>}
	{id === "card-link" && <div class="cxp-schema cxp-card cxp-card--link"><span class="cxp-schema__line" style="width: 70%"></span><span class="cxp-schema__line" style="width: 45%"></span><span class="cxp-cardlink-arrow">→</span></div>}
	{id === "panel" && <div class="cxp-schema cxp-panel"><span class="cxp-schema__bar"></span><span class="cxp-schema__line" style="width: 75%"></span><span class="cxp-schema__line" style="width: 60%"></span></div>}
	{id === "section" && <div class="cxp-schema cxp-section"><span class="cxp-schema__line" style="width: 40%"></span><span class="cxp-schema__block"></span></div>}
	{id === "stack" && <div class="cxp-stack"><span></span><span></span><span></span></div>}
	{id === "cluster" && <div class="cxp-cluster"><span></span><span></span><span></span><span></span></div>}
	{id === "grid" && <div class="cxp-grid"><span></span><span></span><span></span><span></span><span></span><span></span></div>}
	{id === "app-shell" && <div class="cxp-appshell"><span class="cxp-appshell__bar"></span><div class="cxp-appshell__body"><span class="cxp-appshell__side"></span><span class="cxp-appshell__main"></span><span class="cxp-appshell__side"></span></div></div>}
	{id === "mobile-shell" && <div class="cxp-mshell"><span class="cxp-mshell__bar"></span><span class="cxp-mshell__body"></span><span class="cxp-mshell__nav"><i class="is-on"></i><i></i><i></i></span></div>}
	{id === "bottom-nav" && <div class="cxp-bnav"><span class="is-on"><i></i>Inbox</span><span><i></i>Search</span><span><i></i>You</span></div>}
	{id === "dock" && <div class="cxp-dock"><span class="cxp-dock__rail"></span><span class="cxp-dock__main"></span></div>}
	{id === "dock-zone" && <div class="cxp-dockzone"><span class="cxp-dockzone__tabs"></span><div class="cxp-dockzone__panes"><span></span><span></span></div></div>}
	{id === "splitter" && <div class="cxp-splitter"><span></span><span class="cxp-splitter__bar"></span><span></span></div>}
	{id === "statusbar" && <div class="cxp-statusbar"><span>main</span><span>UTF-8</span><span>Ln 1</span></div>}
	{id === "toolbar" && <div class="cxp-toolbar"><span class="cxp-toolbar__title"></span><span class="cxp-toolbar__btn"></span><span class="cxp-toolbar__btn"></span></div>}
	{id === "hero" && <div class="cxp-hero"><span></span></div>}
	{id === "parallax" && <div class="cxp-hero cxp-parallax"></div>}
	{id === "carousel" && <div class="cxp-carousel"><span></span><span></span><span></span><em class="cxp-carousel__dots"><i class="is-on"></i><i></i><i></i></em></div>}
	{id === "image" && <div class="cxp-image"></div>}
	{id === "qr" && <QrCode data="https://xtyle.dev" size={64} label="xtyle.dev QR code" />}
	{id === "dialog" && <div class="cxp-dialog"><span class="cxp-dialog__bar"></span><span class="cxp-schema__line" style="width: 70%"></span><span class="cxp-dialog__btn"></span></div>}
	{id === "menu" && <div class="cxp-menu"><span class="cxp-menu__trigger">Actions ▾</span><span class="cxp-menu__pop"><i></i><i></i><i></i></span></div>}
	{id === "tooltip" && <div class="cxp-tooltip"><span class="cxp-tooltip__bubble">Copy link</span><span class="cxp-tooltip__anchor"></span></div>}
	{id === "toc" && <div class="cxp-toc"><span class="is-on"></span><span></span><span></span></div>}
	{id === "tree" && <div class="cxp-tree"><span class="cxp-tree__branch">▾ src</span><span class="cxp-tree__leaf">index.ts</span><span class="cxp-tree__leaf">app.ts</span></div>}
	{id === "accordion" && <div class="cxp-accordion"><span class="cxp-accordion__row is-open">▾ Details</span><span class="cxp-accordion__body"></span><span class="cxp-accordion__row">▸ Shipping</span></div>}
	{id === "tabs" && <div class="cxp-tabs"><span class="cxp-tabs__strip"><i class="is-on">Overview</i><i>Specs</i><i>Reviews</i></span><span class="cxp-tabs__panel"></span></div>}
	{id === "code" && <pre class="cxp-code"><span><em>const</em> theme = derive(algo);</span><span><em>emit</em>(theme, "css");</span></pre>}
	{id === "table" && (
		<table class="cxp-table"><thead><tr><th>Order</th><th>Total</th></tr></thead><tbody><tr><td>#1024</td><td>$42</td></tr><tr><td>#1025</td><td>$18</td></tr></tbody></table>
	)}
	{id === "color-picker" && <div class="cxp-cpick"><span class="cxp-cpick__field"></span><span class="cxp-cpick__hue"></span></div>}
	{id === "form-group" && <div class="cxp-formgroup"><span class="cxp-formgroup__label"></span><span class="cxp-formgroup__control"></span><span class="cxp-formgroup__help"></span></div>}
	{id === "bar" && <div class="cxp-bars"><span style="height: 45%"></span><span style="height: 72%"></span><span style="height: 58%"></span><span style="height: 90%"></span><span style="height: 66%"></span></div>}
	{id === "pie" && <div class="cxp-pie"></div>}
	{id === "heatmap" && <div class="cxp-heatmap">{Array.from({ length: 28 }).map((_, i) => <span style={`opacity: ${0.15 + ((i * 37) % 100) / 118}`}></span>)}</div>}
	{id === "spotlight" && (
		<div class="cxp-spotlight">
			<span class="cxp-spotlight__page">
				<i></i><i></i><i></i><i></i>
			</span>
			<span class="cxp-spotlight__hole"></span>
			<span class="cxp-spotlight__say"></span>
		</div>
	)}
	{id === "tour" && (
		<div class="cxp-tour">
			<span class="cxp-tour__page">
				<i></i><i></i><i></i><i></i>
			</span>
			<span class="cxp-tour__hole"></span>
			<span class="cxp-tour__say">
				<span class="cxp-tour__dots"><b class="is-on"></b><b></b><b></b></span>
			</span>
		</div>
	)}
	{id === "redact" && (
		<div class="cxp-redact">
			<span class="cxp-redact__row"><i></i><span class="cxp-redact__mask"></span></span>
			<span class="cxp-redact__row"><span class="cxp-redact__blur"></span><i style="width: 40%"></i></span>
		</div>
	)}
	{id === "popover" && (
		<div class="cxp-popover">
			<span class="cxp-popover__trigger">Details</span>
			<span class="cxp-popover__panel">
				<i style="width: 80%"></i>
				<i style="width: 55%"></i>
			</span>
		</div>
	)}
	{id === "command-palette" && (
		<div class="cxp-palette">
			<span class="cxp-palette__query"><Icon name="search" size="sm" /><i></i><Kbd>⌘K</Kbd></span>
			<span class="cxp-palette__row is-on"></span>
			<span class="cxp-palette__row"></span>
			<span class="cxp-palette__row"></span>
		</div>
	)}
	{id === "sheet" && (
		<div class="cxp-sheet">
			<span class="cxp-sheet__scrim"></span>
			<span class="cxp-sheet__panel">
				<i class="cxp-sheet__grip"></i>
				<i class="cxp-schema__line" style="width: 70%"></i>
				<i class="cxp-schema__line" style="width: 45%"></i>
			</span>
		</div>
	)}
	{id === "dropzone" && (
		<div class="cxp-dropzone">
			<Icon name="arrow-up" size="md" />
			<Text size="xs" tone="muted">Drop files</Text>
		</div>
	)}
	{id === "calendar" && (
		<div class="cxp-calendar">
			<span class="cxp-calendar__head">
				{["S", "M", "T", "W", "T", "F", "S"].map((d) => <i>{d}</i>)}
			</span>
			<span class="cxp-calendar__grid">
				{Array.from({ length: 28 }).map((_, i) => (
					<i class={i === 13 ? "is-on" : i === 20 ? "is-range" : undefined}>{i + 1}</i>
				))}
			</span>
		</div>
	)}
</div>

<style>
	.cxp {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 4.25rem;
		padding: var(--space-3);
		overflow: hidden;
		border-radius: var(--radius-md);
		background:
			linear-gradient(var(--bg-0), var(--bg-0)) padding-box,
			repeating-linear-gradient(45deg, var(--bg-2) 0 6px, transparent 6px 12px);
	}
	.cxp > :global(*) { max-width: 100%; }

	.cxp-empty { display: grid; justify-items: center; gap: 0.2rem; color: var(--fg-2); }

	.cxp-list { width: 12rem; text-align: left; }

	.cxp-md { width: 13rem; text-align: left; }
	.cxp-md :global(.xtyle-markdown) { font-size: var(--text-sm); }
	.cxp-md :global(.xtyle-markdown__body h3) { font-size: var(--text-body); margin-block: 0 var(--space-2); }
	.cxp-md :global(.xtyle-markdown__body ul) { margin-block: 0; }

	.cxp-ribbon {
		position: relative;
		display: grid;
		align-content: center;
		gap: 0.3rem;
		width: 8rem;
		height: 5rem;
		padding: var(--space-2);
		border-radius: var(--radius-md);
		background: var(--bg-1);
		border: var(--border-thin) solid var(--line);
	}

	/* Schematic scaffolding shared by the structural previews. */
	.cxp-schema {
		display: grid;
		gap: 0.3rem;
		width: 9rem;
		padding: var(--space-2);
		border-radius: var(--radius-sm);
		background: var(--bg-1);
		border: var(--border-thin) solid var(--line);
	}
	.cxp-schema__head { height: 0.9rem; border-radius: var(--radius-sm); background: var(--bg-3); }
	.cxp-schema__bar { height: 0.55rem; border-radius: var(--radius-full); background: var(--accent); width: 40%; }
	.cxp-schema__line { height: 0.4rem; border-radius: var(--radius-full); background: var(--line-2); }
	.cxp-schema__block { height: 1.6rem; border-radius: var(--radius-sm); background: var(--bg-3); }

	.cxp-card--link { position: relative; }
	.cxp-cardlink-arrow { position: absolute; right: 0.5rem; bottom: 0.4rem; color: var(--accent-text); font-weight: var(--weight-bold); }
	.cxp-panel { border-inline-start: var(--border-thick) solid var(--accent); }
	.cxp-section { border-radius: var(--radius-md); }

	.cxp-stack { display: grid; gap: 0.3rem; width: 6rem; }
	.cxp-stack > span { height: 0.7rem; border-radius: var(--radius-sm); background: var(--accent-bg); }
	.cxp-cluster { display: flex; gap: 0.3rem; }
	.cxp-cluster > span { width: 1.6rem; height: 1rem; border-radius: var(--radius-sm); background: var(--accent-bg); }
	.cxp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.3rem; width: 6rem; }
	.cxp-grid > span { height: 1rem; border-radius: var(--radius-sm); background: var(--accent-bg); }

	.cxp-appshell { display: grid; gap: 0.25rem; width: 10rem; }
	.cxp-appshell__bar { height: 0.7rem; border-radius: var(--radius-sm); background: var(--bg-3); }
	.cxp-appshell__body { display: grid; grid-template-columns: 1fr 2.4fr 1fr; gap: 0.25rem; height: 2.4rem; }
	.cxp-appshell__side { border-radius: var(--radius-sm); background: var(--bg-2); }
	.cxp-appshell__main { border-radius: var(--radius-sm); background: var(--accent-bg); }

