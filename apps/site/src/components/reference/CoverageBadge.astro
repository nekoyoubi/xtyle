---
import Badge from "@xtyle/astro/Badge.astro";

interface Props {
	covered: boolean;
	missing?: string[];
	produced: number;
	consumed: number;
}

const { covered, missing = [], produced, consumed } = Astro.props;
const have = consumed - missing.length;
const label = covered
	? `coverage ${have}/${consumed}`
	: `${have}/${consumed} · ${missing.length} missing`;
const title = covered
	? `All ${consumed} consumed tokens are produced by the default register (${produced} tokens).`
	: `Missing from the default register: ${missing.join(", ")}`;
---

<Badge tone={covered ? "success" : "warn"} title={title}>
	<span
		class:list={["cov-dot", covered ? "cov-dot--full" : "cov-dot--partial"]}
		aria-hidden="true"></span>{label}
</Badge>

<style>
	.cov-dot {
		display: inline-block;
		width: 0.55em;
		height: 0.55em;
		border-radius: var(--radius-full);
		background: currentColor;
		margin-inline-end: 0.4em;
		vertical-align: middle;
	}
	.cov-dot--full {
		box-shadow: 0 0 0 0.12em var(--success-bg);
	}
	.cov-dot--partial {
		box-shadow: 0 0 0 0.12em var(--warn-bg);
	}
</style>
