---
import type { Binding } from "@xtyle/core";
import Tabs from "@xtyle/astro/Tabs.astro";
import Code from "@xtyle/astro/Code.astro";

interface Props {
	sources: Partial<Record<Binding, string>>;
	id: string;
}

const { sources, id } = Astro.props;

const order: Binding[] = ["html", "svelte", "astro"];
const labels: Record<Binding, string> = {
	html: "HTML",
	svelte: "Svelte",
	astro: "Astro",
};
const langFor: Record<Binding, string> = {
	html: "markup",
	svelte: "svelte",
	astro: "astro",
};

const entries = order
	.filter((b) => typeof sources[b] === "string" && sources[b]!.length > 0)
	.map((b) => ({ binding: b, label: labels[b], source: sources[b]! }));

const initial = entries[0]?.binding;
---

{entries.length > 0 && (
	<div class="code-tabs" data-code-tabs>
		<Tabs variant="underline" value={initial} label="Code by binding">
			{entries.map((e) => (
				<button slot="tab" value={e.binding}>{e.label}</button>
			))}
			{entries.map((e) => (
				<div slot="panel" data-binding={e.binding} data-source={e.source}>
					<Code lang={langFor[e.binding]} code={e.source} />
				</div>
			))}
		</Tabs>
		<button type="button" class="code-tabs__copy" data-copy-btn aria-label="Copy code">
			<span data-copy-label>Copy</span>
		</button>
		<span class="code-tabs__status" data-copy-status role="status" aria-live="polite"></span>
	</div>
)}

<script>
	function activeSource(root: HTMLElement): string {
		const tabs = root.querySelector<HTMLElement & { value?: string | null }>("xtyle-tabs");
		const binding = tabs?.value ?? root.querySelector<HTMLElement>("[data-source]")?.dataset.binding;
		const panel = binding
			? root.querySelector<HTMLElement>(`[data-binding="${binding}"]`)
			: root.querySelector<HTMLElement>("[data-source]");
		return panel?.dataset.source ?? "";
	}

	function initCopy(root: HTMLElement): void {
		const copyBtn = root.querySelector<HTMLButtonElement>("[data-copy-btn]");
		const copyLabel = root.querySelector<HTMLElement>("[data-copy-label]");
		const copyStatus = root.querySelector<HTMLElement>("[data-copy-status]");
		if (!copyBtn || !copyLabel) return;

		copyBtn.addEventListener("click", async () => {
			const text = activeSource(root);
			let message = "Copied";
			try {
				await navigator.clipboard.writeText(text);
				copyLabel.textContent = "Copied";
			} catch {
				message = "Copy failed";
				copyLabel.textContent = "Copy failed";
			}
			if (copyStatus) copyStatus.textContent = message;
			setTimeout(() => {
				copyLabel.textContent = "Copy";
				if (copyStatus) copyStatus.textContent = "";
			}, 1400);
		});
	}

	function initCodeTabs(): void {
		for (const root of document.querySelectorAll<HTMLElement>("[data-code-tabs]")) {
			initCopy(root);
		}
	}

	document.addEventListener("astro:page-load", initCodeTabs);
	initCodeTabs();
</script>

<style>
	.code-tabs {
		position: relative;
	}
	.code-tabs__copy {
		position: absolute;
		top: 0;
		right: 0;
		appearance: none;
		border: var(--border-thin) solid var(--line);
		border-radius: var(--radius-sm);
		background: var(--bg-1);
		color: var(--fg-2);
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		font-weight: var(--weight-medium);
		padding: var(--space-1) var(--space-3);
		cursor: pointer;
		transition:
			color var(--duration-fast) var(--ease-standard),
			border-color var(--duration-fast) var(--ease-standard);
	}
	.code-tabs__copy:hover {
		color: var(--fg-0);
		border-color: var(--line-2);
	}
	.code-tabs__copy:focus-visible {
		outline: var(--border-normal) solid transparent;
		box-shadow: 0 0 0 var(--border-thick) var(--ring);
	}
	.code-tabs__status {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
