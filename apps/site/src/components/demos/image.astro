---
import Image from "@xtyle/astro/Image.astro";
import Carousel from "@xtyle/astro/Carousel.astro";
import Card from "@xtyle/astro/Card.astro";
import Stack from "@xtyle/astro/Stack.astro";
import Grid from "@xtyle/astro/Grid.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Text from "@xtyle/astro/Text.astro";
import Button from "@xtyle/astro/Button.astro";
import Badge from "@xtyle/astro/Badge.astro";
import Sparkline from "@xtyle/astro/Sparkline.astro";

const sceneSvg =
	'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 360"><defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#6ea8fe"/><stop offset="0.55" stop-color="#7c5cff"/><stop offset="1" stop-color="#ff7ac6"/></linearGradient></defs><rect width="640" height="360" fill="url(#g)"/><circle cx="500" cy="90" r="46" fill="#fff" opacity="0.85"/><path d="M0 300 L180 190 L320 260 L470 160 L640 250 L640 360 L0 360 Z" fill="#1c2333" opacity="0.55"/></svg>';

const squareSvg =
	'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200"><rect width="200" height="200" fill="#11151f"/><rect x="46" y="46" width="108" height="108" rx="18" fill="#6ea8fe"/><circle cx="100" cy="100" r="30" fill="#0b0d12"/></svg>';

const scene = "data:image/svg+xml," + encodeURIComponent(sceneSvg);
const square = "data:image/svg+xml," + encodeURIComponent(squareSvg);

// The cover the preview hides behind: an xtyle title card, so hovering it shows off the real thing.
const coverArt =
	"data:image/svg+xml," +
	encodeURIComponent(
		'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 360"><defs><linearGradient id="xc" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#6ea8fe"/><stop offset="0.5" stop-color="#7c5cff"/><stop offset="1" stop-color="#ff7ac6"/></linearGradient></defs><rect width="640" height="360" fill="#0b0d12"/><rect width="640" height="360" fill="url(#xc)" opacity="0.16"/><text x="320" y="186" font-family="sans-serif" font-size="82" font-weight="bold" fill="url(#xc)" text-anchor="middle">xtyle</text><text x="320" y="232" font-family="sans-serif" font-size="20" fill="#e6e9ef" opacity="0.55" text-anchor="middle">hover to see what it derives</text></svg>',
	);

// The tokens the palette slide shows off, straight from the derived register.
const paletteTokens = ["--accent", "--success", "--warn", "--danger", "--info"];

// An animated inline SVG that stands in for a hover video (self-contained, no asset needed).
const motionSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 360" preserveAspectRatio="xMidYMid slice" style="width:100%;height:100%;display:block"><defs><linearGradient id="mg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#6ea8fe"><animate attributeName="stop-color" values="#6ea8fe;#7c5cff;#ff7ac6;#6ea8fe" dur="6s" repeatCount="indefinite"/></stop><stop offset="1" stop-color="#ff7ac6"><animate attributeName="stop-color" values="#ff7ac6;#6ea8fe;#7c5cff;#ff7ac6" dur="6s" repeatCount="indefinite"/></stop></linearGradient></defs><rect width="640" height="360" fill="url(#mg)"/><circle cx="500" cy="90" r="46" fill="#fff" opacity="0.85"><animate attributeName="cx" values="500;150;500" dur="7s" repeatCount="indefinite"/><animate attributeName="cy" values="90;140;90" dur="7s" repeatCount="indefinite"/></circle><path d="M0 300 L180 190 L320 260 L470 160 L640 250 L640 360 L0 360 Z" fill="#1c2333" opacity="0.55"/></svg>`;
---

<Stack gap={6}>
	<Card>
		<Heading slot="header" level={3} size="sm">Framed with a caption</Heading>
		<Image src={scene} alt="An abstract gradient landscape" ratio="16/9" caption="A 16/9 frame that holds its space while the image loads" />
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Hover to preview</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">
				Hover or focus a cover and the still comes alive and plays a preview clip;
				leaving resets it. The preview can be a moving image, a nested carousel, or a video via
				<code>hover-src</code>. Add <code>hover-audio</code> and a mute toggle rides the reveal into
				the corner of the frame.
			</Text>
			<Grid minColWidth="14rem" gap={4}>
				<Stack gap={1}>
					<Image src={coverArt} alt="xtyle" ratio="16/9">
						<Carousel slot="hover" autoplay loop transition="fade" pauseOnHover={false} interval={1600} dots={false} controls={false} label="What xtyle derives">
							<div class="xshow">
								<span class="xshow__label">Derived palette</span>
								<div class="xshow__swatches">
									{paletteTokens.map((token) => <span style={`background: var(${token});`}></span>)}
								</div>
							</div>
							<div class="xshow">
								<span class="xshow__label">Components, themed</span>
								<div class="xshow__row">
									<Button variant="solid" tone="accent" size="sm">Ship it</Button>
									<Badge variant="soft" tone="success">Live</Badge>
								</div>
							</div>
							<div class="xshow">
								<span class="xshow__label">Metrics, on-theme</span>
								<Sparkline values={[4, 7, 5, 9, 8, 12, 10, 14]} variant="area" tone="accent" label="Trend" style="--spark-width: 9rem; --spark-height: 2.4rem;" />
							</div>
						</Carousel>
					</Image>
					<Text size="xs" tone="subtle" weight="semibold" style="text-align: center;">a nested carousel</Text>
				</Stack>
				<Stack gap={1}>
					<Image src={scene} alt="An abstract gradient landscape" ratio="16/9">
						<div slot="hover" set:html={motionSvg}></div>
					</Image>
					<Text size="xs" tone="subtle" weight="semibold" style="text-align: center;">a moving preview</Text>
				</Stack>
				<Stack gap={1}>
					<Image src={scene} alt="Nebula Drifter, a landscape that comes alive" ratio="16/9" hoverSrc="/preview-scene.mp4" hoverAudio="off" />
					<Text size="xs" tone="subtle" weight="semibold" style="text-align: center;">hover-src video, with a mute toggle</Text>
				</Stack>
			</Grid>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Lightbox</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">Click or focus and press Enter to open the full image over a scrim; Escape or the backdrop closes it.</Text>
			<Grid minColWidth="10rem" gap={3}>
				<Image src={scene} alt="An abstract gradient landscape" ratio="1/1" lightbox />
				<Image src={square} alt="A framed emblem" ratio="1/1" lightbox />
				<Image src={scene} alt="An abstract gradient landscape" ratio="1/1" lightbox />
			</Grid>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Zoom button</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">With <code>trigger="button"</code> the frame stops being the click target; a zoom button reveals on hover and focus, so click-to-zoom sits beside selectable text without fighting it.</Text>
			<Grid minColWidth="10rem" gap={3}>
				<Image src={scene} alt="An abstract gradient landscape" ratio="1/1" lightbox trigger="button" />
				<Image src={square} alt="A framed emblem" ratio="1/1" lightbox trigger="button" />
			</Grid>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Standalone lightbox for raw images</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">
				One <code>&lt;xtyle-lightbox&gt;</code> mounted in the card opens any <code>[data-xtyle-lightbox]</code>
				in its scope, including plain <code>&lt;img&gt;</code> markup no component rendered (a markdown or
				CMS body). Click a thumbnail, or focus it and press Enter, to open the shared dialog.
			</Text>
			<div id="delegated-gallery" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(8rem, 1fr)); gap: var(--space-3);">
				<xtyle-lightbox scope="#delegated-gallery"></xtyle-lightbox>
				<img src={scene} alt="An abstract gradient landscape" data-xtyle-lightbox data-lightbox-caption="An abstract gradient landscape, full size" style="width: 100%; border-radius: var(--radius-md); cursor: zoom-in;" />
				<img src={square} alt="A framed emblem" data-xtyle-lightbox data-lightbox-caption="The emblem, contained" style="width: 100%; border-radius: var(--radius-md); cursor: zoom-in;" />
				<img src={scene} alt="An abstract gradient landscape" data-xtyle-lightbox style="width: 100%; border-radius: var(--radius-md); cursor: zoom-in;" />
			</div>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Lightbox in a frosted panel</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">The lightbox opens against the viewport, so it stays centered even inside a panel whose <code>backdrop-filter</code> or <code>transform</code> would otherwise pin a modal to its own box.</Text>
			<div style="transform: translateZ(0); backdrop-filter: blur(8px); border: var(--border-thin) solid var(--border); border-radius: var(--radius-lg); padding: var(--space-4); background: var(--bg-2); max-width: 22rem;">
				<Image src={scene} alt="An abstract gradient landscape" ratio="16/9" lightbox />
			</div>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Fit and radius</Heading>
		<Grid minColWidth="12rem" gap={4}>
			<Stack gap={1}>
				<Image src={square} alt="Emblem, cover" ratio="16/9" fit="cover" />
				<Text tone="muted" size="xs">cover</Text>
			</Stack>
			<Stack gap={1}>
				<Image src={square} alt="Emblem, contain" ratio="16/9" fit="contain" />
				<Text tone="muted" size="xs">contain</Text>
			</Stack>
			<Stack gap={1}>
				<Image src={scene} alt="Scene, no radius" ratio="16/9" radius="none" />
				<Text tone="muted" size="xs">radius none</Text>
			</Stack>
			<Stack gap={1}>
				<Image src={scene} alt="Scene, large radius" ratio="16/9" radius="lg" />
				<Text tone="muted" size="xs">radius lg</Text>
			</Stack>
		</Grid>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Load failure</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">When the image fails to load, a muted frame with a warning glyph replaces it.</Text>
			<div style="max-width: 20rem;">
				<Image src="/does-not-exist.jpg" alt="A missing image" ratio="16/9" />
			</div>
		</Stack>
	</Card>
</Stack>

<style>
	/* The hover-preview slides. Each is fully opaque: a stacked cross-fade reveals the slide beneath
	   the outgoing one, so a translucent slide would let the cover show through mid-dissolve. */
	.xshow {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--space-2);
		width: 100%;
		/* A definite size, like the framed images these slides replaced: `height: 100%` against the
		   grid's auto-sized cell collapses the track, which lets the cover show through and drags the
		   carousel's control bar up into the frame. */
		aspect-ratio: 16 / 9;
		padding: var(--space-3);
		/* An accent-tinted surface off the derived register, so the slide reads as a designed panel
		   rather than floating text on the card behind it. Opaque, so the cover can't show through. */
		background:
			radial-gradient(120% 90% at 15% 0%, color-mix(in oklab, var(--accent) 22%, transparent), transparent 70%),
			var(--bg-2);
		border-radius: var(--radius-md);
		overflow: hidden;
	}
	.xshow__label {
		color: var(--fg-1);
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.xshow__swatches {
		display: flex;
		gap: var(--space-2);
	}
	.xshow__swatches > span {
		width: 1.9rem;
		height: 1.9rem;
		border-radius: var(--radius-full);
		box-shadow: 0 0 0 var(--border-thin) var(--surface-overlay-border);
	}
	.xshow__row {
		display: flex;
		align-items: center;
		gap: var(--space-2);
	}
</style>
