---
import Icon from "@xtyle/astro/Icon.astro";
import Button from "@xtyle/astro/Button.astro";
import Card from "@xtyle/astro/Card.astro";
import Stack from "@xtyle/astro/Stack.astro";
import Cluster from "@xtyle/astro/Cluster.astro";
import Grid from "@xtyle/astro/Grid.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Text from "@xtyle/astro/Text.astro";
import { ICON_NAMES } from "@xtyle/core";
---

<Stack gap={6}>
	<Card>
		<Heading slot="header" level={3} size="sm">The functional set</Heading>
		<Grid minColWidth="7rem" gap={3}>
			{
				ICON_NAMES.map((name) => (
					<Stack gap={1} align="center" style="text-align: center; padding: 0.75rem 0;">
						<Icon name={name} size="lg" />
						<Text tone="muted" size="xs" mono>{name}</Text>
					</Stack>
				))
			}
		</Grid>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Generated marks</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">
				A <code>name</code> that carries a spec (a <code>--</code> grammar) is composed on the fly instead of
				looked up: primitives placed on a grid, sized, rotated, outlined, or knocked out, colored from the
				theme's own series so a mark recolors with the theme. See the grammar for the full syntax.
			</Text>
			<Grid minColWidth="8rem" gap={3}>
				{
					[
						"dice-3--square3-c1--dot-p7-s14-ko--dot-s14-ko--dot-p3-s14-ko",
						"crest--shield-c1--star-s45-cf",
						"badge--circle-c2--bolt-s52-cb",
						"target--ring-c1--dot-s28-c2",
						"framed--square-c0-o2c1--heart-s44-c2",
						"spun--diamond-c1--cross-s42-r45-cf",
						"check-badge--circle-c3--check-s55-cf",
						"search-chip--square-c0-o2c2--search-s52-c2",
						"pennant--triangle-c1-r90--divider-s60-cf",
						"split--circle-c2--divider-s70-cb",
					].map((spec) => (
						<Stack gap={1} align="center" style="text-align: center; padding: 0.75rem 0;">
							<Icon name={spec} size="xl" />
							<Text tone="muted" size="xs" mono style="word-break: break-all;">{spec.split("--")[0]}</Text>
						</Stack>
					))
				}
			</Grid>
			<Text tone="muted" size="sm">
				The same spec under a different scheme via <code>colors</code>:
			</Text>
			<Cluster gap={4} align="center">
				<Icon name="chip--hex-c1--dot-s30-c2" size="xl" colors="accents" />
				<Icon name="chip--hex-c1--dot-s30-c2" size="xl" colors="skittles" />
				<Icon name="chip--hex-c1--dot-s30-c2" size="xl" colors="statuses" />
			</Cluster>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Text marks</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">
				The <code>letter</code> primitive typesets a glyph as a mark (<code>--letter-A</code>), so a
				monogram or initial composes like any other primitive: colored, framed, outlined, scaled. It
				draws in an indexed font slot (<code>-f0</code> sans, <code>-f1</code> display, <code>-f2</code>
				mono), and a <code>---f</code> finish swaps a slot for another theme font. A named web font
				renders only where it's loaded; theme-token fonts always work.
			</Text>
			<Grid minColWidth="8rem" gap={3}>
				{
					[
						"letter A--letter-A",
						"display Q--letter-Q-f1",
						"mono 7--letter-7-f2",
						"badged A--circle-c1--letter-A-cb-s55",
						"framed N--square-c0-o2c1--letter-N-c1-s55",
						"outlined R--letter-R-o2c2-s150",
					].map((spec) => (
						<Stack gap={1} align="center" style="text-align: center; padding: 0.75rem 0;">
							<Icon name={spec} size="xl" />
							<Text tone="muted" size="xs" mono style="word-break: break-all;">{spec.split("--")[0]}</Text>
						</Stack>
					))
				}
			</Grid>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Sizes</Heading>
		<Cluster gap={4} align="center" style="align-items: baseline;">
			<Icon name="search" size="sm" />
			<Icon name="search" size="md" />
			<Icon name="search" size="lg" />
			<Icon name="search" size="xl" />
		</Cluster>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Tones</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">
				With no <code>tone</code> an icon inherits the surrounding text color; a <code>tone</code> tints
				it to a semantic role or named hue.
			</Text>
			<Cluster gap={3} align="center">
				<Icon name="success" tone="success" size="lg" />
				<Icon name="warning" tone="warn" size="lg" />
				<Icon name="error" tone="danger" size="lg" />
				<Icon name="info" tone="info" size="lg" />
				<Icon name="dot" tone="accent" size="lg" />
			</Cluster>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Spin</Heading>
		<Cluster gap={4} align="center">
			<Icon name="loader" spin size="lg" label="Loading" />
			<Text tone="muted" size="sm">The <code>loader</code> glyph with <code>spin</code> is a lightweight busy indicator.</Text>
		</Cluster>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">In controls</Heading>
		<Cluster gap={3} align="center">
			<Button><Icon name="plus" slot="icon-start" />New</Button>
			<Button variant="subtle"><Icon name="external-link" slot="icon-end" />Docs</Button>
			<Button variant="ghost" iconOnly aria-label="More"><Icon name="more-vertical" /></Button>
		</Cluster>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Transport controls</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">
				The media-transport glyphs (<code>play</code>, <code>pause</code>, <code>stop</code>,
				<code>skip-back</code>, <code>skip-forward</code>) drop into a run bar or a player the
				same way any glyph does, so a run / execute / start-stop control renders in one voice.
			</Text>
			<Cluster gap={2} align="center">
				<Button variant="ghost" iconOnly aria-label="Skip back"><Icon name="skip-back" /></Button>
				<Button><Icon name="play" slot="icon-start" />Run</Button>
				<Button variant="subtle" iconOnly aria-label="Pause"><Icon name="pause" /></Button>
				<Button variant="subtle" iconOnly aria-label="Stop"><Icon name="stop" tone="danger" /></Button>
				<Button variant="ghost" iconOnly aria-label="Skip forward"><Icon name="skip-forward" /></Button>
			</Cluster>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Inline</Heading>
		<Text>
			Press the <Icon name="search" /> to search, then <Icon name="check" tone="success" /> to confirm or
			<Icon name="close" tone="danger" /> to dismiss.
		</Text>
	</Card>
</Stack>
