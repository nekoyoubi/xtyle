---
import Badge from "@xtyle/astro/Badge.astro";
import Card from "@xtyle/astro/Card.astro";
import Stack from "@xtyle/astro/Stack.astro";
import Cluster from "@xtyle/astro/Cluster.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Text from "@xtyle/astro/Text.astro";
import { ACCENT_VARIANTS, HUES } from "@xtyle/core";

const variants = ["solid", "soft", "outline"] as const;
const semantic = ["accent", "neutral", "success", "warn", "danger", "info"] as const;

const TONE_GROUPS = [
	{ label: "Accents", tones: ["accent", ...ACCENT_VARIANTS, "neutral"] },
	{ label: "Statuses", tones: ["success", "info", "warn", "danger"] },
	{ label: "Named hues", tones: [...HUES] },
] as const;
---

<Stack gap={6}>
	<Card>
		<Heading slot="header" level={3} size="sm">Three fills, six semantic tones</Heading>
		<Stack gap={4}>
			{
				variants.map((variant) => (
					<Stack gap={2}>
						<Text size="xs" tone="muted" mono>{variant}</Text>
						<Cluster gap={2} align="center">
							{semantic.map((tone) => (
								<Badge variant={variant} tone={tone}>
									{tone}
								</Badge>
							))}
						</Cluster>
					</Stack>
				))
			}
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Every tone</Heading>
		<Stack gap={4}>
			{TONE_GROUPS.map((group) => (
				<Stack gap={2}>
					<Text size="xs" tone="subtle" weight="semibold">{group.label}</Text>
					<Cluster gap={2} align="center">
						{group.tones.map((tone) => <Badge variant="soft" tone={tone}>{tone}</Badge>)}
					</Cluster>
				</Stack>
			))}
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Sizes, dots, counts, and dismissal</Heading>
		<Stack gap={4}>
			<Cluster gap={3} align="center">
				<Badge size="sm" tone="accent">small</Badge>
				<Badge size="md" tone="accent">medium</Badge>
				<Badge size="lg" tone="accent">large</Badge>
			</Cluster>
			<Cluster gap={3} align="center">
				<Badge variant="soft" tone="success" dot>Live</Badge>
				<Badge variant="soft" tone="warn" dot>Degraded</Badge>
				<Badge variant="soft" tone="danger" dot>Offline</Badge>
				<Badge variant="solid" tone="info" count={12}>Inbox</Badge>
				<Badge variant="outline" tone="neutral" count="99+">Alerts</Badge>
			</Cluster>
			<Cluster gap={3} align="center" class="demo-removable">
				<Badge variant="soft" tone="blue" removable>design</Badge>
				<Badge variant="soft" tone="purple" removable>frontend</Badge>
				<Badge variant="soft" tone="green" removable>tokens</Badge>
			</Cluster>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Live status</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">
				A <code>pulse</code> breathes the dot so a chip reads as live, at Progress's
				two speeds (<code>slow</code> and <code>fast</code>). It holds still under
				reduced-motion, and a plain dot stays static for contrast.
			</Text>
			<Cluster gap={3} align="center">
				<Badge variant="soft" tone="success" dot pulse>Live</Badge>
				<Badge variant="soft" tone="accent" dot pulse>Streaming</Badge>
				<Badge variant="soft" tone="danger" dot pulse="fast">Alert</Badge>
				<Badge variant="soft" tone="neutral" dot>Idle</Badge>
			</Cluster>
			<Text tone="muted" size="sm">
				The same breathe drives the standalone <code>.xtyle-dot</code> for a chip-less
				live pip, a connection light or a per-row streaming indicator with no label around it.
			</Text>
			<Cluster gap={4} align="center">
				<Cluster gap={2} align="center">
					<span class="xtyle-dot xtyle-dot--success xtyle-dot--pulse-slow" role="img" aria-label="Connected"></span>
					<Text size="sm">Connected</Text>
				</Cluster>
				<Cluster gap={2} align="center">
					<span class="xtyle-dot xtyle-dot--accent xtyle-dot--pulse-fast" role="img" aria-label="Streaming"></span>
					<Text size="sm">Streaming</Text>
				</Cluster>
				<Cluster gap={2} align="center">
					<span class="xtyle-dot xtyle-dot--neutral" role="img" aria-label="Offline"></span>
					<Text size="sm">Offline</Text>
				</Cluster>
			</Cluster>
		</Stack>
	</Card>
</Stack>

<script>
	function initRemovableBadges(): void {
		for (const cluster of document.querySelectorAll<HTMLElement>(".demo-removable")) {
			cluster.addEventListener("click", (event) => {
				const button = (event.target as HTMLElement).closest(".xtyle-badge__remove");
				button?.closest(".xtyle-badge")?.remove();
			});
		}
	}

	document.addEventListener("astro:page-load", initRemovableBadges);
	initRemovableBadges();
</script>
