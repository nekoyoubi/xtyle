---
import Timeline from "@xtyle/astro/Timeline.astro";
import Card from "@xtyle/astro/Card.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Stack from "@xtyle/astro/Stack.astro";
import Badge from "@xtyle/astro/Badge.astro";
import Text from "@xtyle/astro/Text.astro";
---

<Stack gap={6}>
	<Card>
		<Heading slot="header" level={3} size="sm">Release activity</Heading>
		<Timeline>
			<ol>
				<li>
					<strong>Shipped v0.6.0</strong>
					<time>2 hours ago</time>
					<p>The accessibility pass, the reduced-motion self-guards, and a new gallery mockup went live.</p>
				</li>
				<li>
					<strong>Merged the release branch</strong>
					<time>yesterday</time>
					<p>Folded the cycle's commits into main and cut the changelog.</p>
				</li>
				<li>
					<strong>Froze the milestone</strong>
					<time>3 days ago</time>
				</li>
				<li>
					<strong>Opened v0.6.0</strong>
					<time>last week</time>
				</li>
			</ol>
		</Timeline>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Terse feed</Heading>
		<Timeline>
			<ol>
				<li><strong>Deploy succeeded</strong><time>12:04</time></li>
				<li><strong>Build passed</strong><time>12:01</time></li>
				<li><strong>Pushed 3 commits</strong><time>11:58</time></li>
			</ol>
		</Timeline>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Statused events</Heading>
		<Timeline>
			<ol>
				<li id="event-deploy">
					<strong>Deploy <Badge tone="success" size="sm">green</Badge></strong>
					<time datetime="2026-07-13T12:04">12:04</time>
					<p>Rolled out to every region with no failed health check.</p>
				</li>
				<li id="event-rollback">
					<strong>Rollback <Badge tone="danger" size="sm">failed</Badge></strong>
					<time datetime="2026-07-13T11:47">11:47</time>
				</li>
				<li id="event-open">
					<strong>Opened the incident <Badge tone="warn" size="sm">sev-2</Badge></strong>
					<time datetime="2026-07-13T11:02">11:02</time>
					<p>The rail stops here: the last event ends at its dot rather than trailing a line into nothing.</p>
				</li>
			</ol>
		</Timeline>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Zero-JS</Heading>
		<Stack gap={4}>
			<Text size="sm" tone="muted">
				The Astro binding reads the authored <code>&lt;li&gt;</code>s on the server and renders the whole feed — the dots, the
				rails, and each event's content in its own region — so the timeline arrives complete. <code>static</code> keeps it that
				way: the instance below never asks for the runtime, and on a page with no other xtyle element it stays a plain,
				fully-styled feed with zero JavaScript. Re-reading the list when it changes is what hydration adds on top.
			</Text>
			<Timeline static>
				<ol>
					<li><strong>Rendered on the server</strong><time>build time</time></li>
					<li><strong>Shipped as plain HTML</strong><time>no runtime</time></li>
					<li><strong>Styled by the cascade alone</strong><time>no script</time></li>
				</ol>
			</Timeline>
		</Stack>
	</Card>
</Stack>
