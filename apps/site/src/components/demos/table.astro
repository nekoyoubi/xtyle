---
import Table from "@xtyle/astro/Table.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Text from "@xtyle/astro/Text.astro";
import Badge from "@xtyle/astro/Badge.astro";
import Card from "@xtyle/astro/Card.astro";
import Stack from "@xtyle/astro/Stack.astro";

type Row = {
	algorithm: string;
	tone: "accent" | "info" | "warn" | "success";
	tokens: number;
	coverage: number;
	status: "Blessed" | "Draft" | "Community";
};

const rows: Row[] = [
	{ algorithm: "xtyle-default", tone: "accent", tokens: 142, coverage: 100, status: "Blessed" },
	{ algorithm: "xtyle-quiet", tone: "info", tokens: 138, coverage: 98, status: "Blessed" },
	{ algorithm: "xtyle-loud", tone: "warn", tokens: 151, coverage: 96, status: "Draft" },
	{ algorithm: "xtyle-hc", tone: "success", tokens: 147, coverage: 100, status: "Blessed" },
	{ algorithm: "aurora", tone: "info", tokens: 129, coverage: 91, status: "Community" },
];

const statusTone: Record<Row["status"], "success" | "warn" | "neutral"> = {
	Blessed: "success",
	Draft: "warn",
	Community: "neutral",
};
---

<Stack gap={6}>
	<Card>
		<Heading slot="header" level={3} size="sm">Sortable, hover, sticky header</Heading>
		<Text slot="header" size="xs" tone="muted">
			Click a sortable column header (or focus it and press Enter) to re-order the rows. The caret
			is an <Text as="span" mono size="xs">&lt;xtyle-icon&gt;</Text>, so it re-skins with the rest of
			the icon set; it rotates and colors off <Text as="span" mono size="xs">aria-sort</Text>.
		</Text>
		<Table variant="default" hover sticky maxHeight="12rem" ariaLabel="Built-in xtyle algorithms">
				<table>
					<thead>
						<tr>
							<th data-sortable>Algorithm</th>
							<th data-sortable data-sort-type="number">Tokens</th>
							<th data-sortable data-sort-type="number">Coverage</th>
							<th>Status</th>
						</tr>
					</thead>
					<tbody>
						{
							rows.map((row) => (
								<tr>
									<td><Text as="span" weight="medium" mono>{row.algorithm}</Text></td>
									<td data-sort-value={row.tokens}>{row.tokens}</td>
									<td data-sort-value={row.coverage}>
										<Badge
											variant="soft"
											tone={row.coverage === 100 ? "success" : "warn"}
										>{row.coverage}%</Badge>
									</td>
									<td>
										<Badge variant="soft" tone={statusTone[row.status]}>{row.status}</Badge>
									</td>
								</tr>
							))
						}
					</tbody>
				</table>
		</Table>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Selectable rows</Heading>
		<Text slot="header" size="xs" tone="muted">
			<Text as="span" mono size="xs">selection="multi"</Text> turns the body rows into a grid: click or
			Space toggles, arrow keys move the cursor, <Text as="span" mono size="xs">Ctrl/Cmd</Text>-click and
			<Text as="span" mono size="xs">Shift</Text>-click extend. Selection is consumed from the shared
			collection core, keyed by each row's <Text as="span" mono size="xs">data-value</Text>.
		</Text>
		<Table selection="multi" hover ariaLabel="Selectable algorithms">
			<table>
				<thead>
					<tr>
						<th aria-label="Select"></th>
						<th>Algorithm</th>
						<th>Tokens</th>
						<th>Status</th>
					</tr>
				</thead>
				<tbody>
					{
						rows.map((row) => (
							<tr data-value={row.algorithm} data-selected={row.algorithm === "xtyle-default" ? "" : undefined}>
								<td><input type="checkbox" data-row-select aria-label={`Select ${row.algorithm}`} /></td>
								<td><Text as="span" weight="medium" mono>{row.algorithm}</Text></td>
								<td>{row.tokens}</td>
								<td><Badge variant="soft" tone={statusTone[row.status]}>{row.status}</Badge></td>
							</tr>
						))
					}
				</tbody>
			</table>
		</Table>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Striped, compact</Heading>
		<Table variant="striped" size="compact" ariaLabel="Token consumption by component">
			<table>
				<thead>
					<tr>
						<th>Component</th>
						<th>Category</th>
						<th>Consumed tokens</th>
					</tr>
				</thead>
				<tbody>
					<tr><td>button</td><td>control</td><td>9</td></tr>
					<tr><td>field</td><td>form</td><td>11</td></tr>
					<tr><td>alert</td><td>feedback</td><td>7</td></tr>
					<tr><td>dialog</td><td>overlay</td><td>8</td></tr>
					<tr><td>table</td><td>content</td><td>12</td></tr>
				</tbody>
			</table>
		</Table>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Bordered</Heading>
		<Table variant="bordered" ariaLabel="Input tiers">
			<table>
				<thead>
					<tr>
						<th>Tier</th>
						<th>Audience</th>
						<th>Surface</th>
					</tr>
				</thead>
				<tbody>
					<tr><td>Builders</td><td>algorithm authors</td><td>internal derivation</td></tr>
					<tr><td>Knobs</td><td>everyone</td><td>declared inputs</td></tr>
					<tr><td>Overrides</td><td>power users</td><td>any token, anywhere</td></tr>
				</tbody>
			</table>
		</Table>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Zero-JS</Heading>
		<Stack gap={4}>
			<Text size="sm" tone="muted">
				The element styles a plain <code>&lt;table&gt;</code> by writing part classes onto its rows, cells, header, and footer
				at upgrade — so without a runtime the table would render bare. The Astro binding applies those same classes on the
				server, and <code>static</code> keeps the result: the table below is fully styled with zero JavaScript. Sorting, the
				scroll affordance, and row selection are what hydration adds on top.
			</Text>
			<Table static variant="striped" ariaLabel="Rendering modes">
				<table>
					<thead>
						<tr>
							<th>Mode</th>
							<th>Runtime</th>
						</tr>
					</thead>
					<tbody>
						<tr><td>Static</td><td>never loaded</td></tr>
						<tr><td>Hydrated</td><td>upgrades in place</td></tr>
					</tbody>
					<tfoot>
						<tr><td>Both</td><td>same markup</td></tr>
					</tfoot>
				</table>
			</Table>
		</Stack>
	</Card>
</Stack>

<script>
	type Dir = "ascending" | "descending";

	function sortTable(table: HTMLTableElement, columnIndex: number, dir: Dir, numeric: boolean) {
		const tbody = table.querySelector("tbody");
		if (!tbody) return;
		const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>("tr"));
		const value = (row: HTMLTableRowElement) => {
			const cell = row.cells[columnIndex];
			const raw = cell?.getAttribute("data-sort-value") ?? cell?.textContent?.trim() ?? "";
			return numeric ? Number.parseFloat(raw) || 0 : raw.toLowerCase();
		};
		rows.sort((a, b) => {
			const av = value(a);
			const bv = value(b);
			const cmp = av < bv ? -1 : av > bv ? 1 : 0;
			return dir === "ascending" ? cmp : -cmp;
		});
		for (const row of rows) tbody.appendChild(row);
	}

	for (const header of document.querySelectorAll<HTMLTableCellElement>("th[data-sortable]")) {
		const activate = () => {
			const table = header.closest("table");
			if (!table) return;
			const headers = Array.from(table.querySelectorAll<HTMLTableCellElement>("th"));
			const index = headers.indexOf(header);
			const current = header.getAttribute("aria-sort");
			const next: Dir = current === "ascending" ? "descending" : "ascending";
			for (const other of headers) other.setAttribute("aria-sort", "none");
			header.setAttribute("aria-sort", next);
			sortTable(table, index, next, header.dataset.sortType === "number");
		};
		header.addEventListener("click", activate);
		header.addEventListener("keydown", (event) => {
			if (event.key === "Enter" || event.key === " ") {
				event.preventDefault();
				activate();
			}
		});
	}
</script>
