---
import Kbd from "@xtyle/astro/Kbd.astro";
import Card from "@xtyle/astro/Card.astro";
import Stack from "@xtyle/astro/Stack.astro";
import Cluster from "@xtyle/astro/Cluster.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Text from "@xtyle/astro/Text.astro";
---

<Stack gap={6}>
	<Card>
		<Heading slot="header" level={3} size="sm">Chords</Heading>
		<Stack gap={3}>
			<Cluster gap={1}>
				<Kbd>Ctrl</Kbd>
				<Text tone="muted">+</Text>
				<Kbd>K</Kbd>
			</Cluster>
			<Cluster gap={1}>
				<Kbd>Ctrl</Kbd>
				<Text tone="muted">+</Text>
				<Kbd>Shift</Kbd>
				<Text tone="muted">+</Text>
				<Kbd>P</Kbd>
			</Cluster>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Sizes</Heading>
		<Cluster gap={2} style="align-items: baseline;">
			<Kbd size="sm">Esc</Kbd>
			<Kbd>Enter</Kbd>
			<Kbd size="lg">Space</Kbd>
		</Cluster>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Tones</Heading>
		<Stack gap={3}>
			<Text tone="muted" size="sm">
				A <code>tone</code> tints the whole keycap for a primary-chord or status key.
			</Text>
			<Cluster gap={2} align="center">
				<Kbd tone="accent">⌘</Kbd>
				<Kbd tone="accent">K</Kbd>
				<Kbd tone="success">Enter</Kbd>
				<Kbd tone="warn">Tab</Kbd>
				<Kbd tone="danger">Del</Kbd>
				<Kbd tone="info">?</Kbd>
			</Cluster>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">Inline</Heading>
		<Text>
			Press <Kbd size="sm">/</Kbd> to search, or <Kbd size="sm">Esc</Kbd> to dismiss.
		</Text>
	</Card>
</Stack>
