---
import Dialog from "@xtyle/astro/Dialog.astro";
import Button from "@xtyle/astro/Button.astro";
import Card from "@xtyle/astro/Card.astro";
import Field from "@xtyle/astro/Field.astro";
import Stack from "@xtyle/astro/Stack.astro";
import Cluster from "@xtyle/astro/Cluster.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Text from "@xtyle/astro/Text.astro";
---

<div class="dialog-demo" data-dialog-demo>
	<Card>
		<Stack slot="header" gap={1}>
			<Heading level={2} size="body">Open a modal</Heading>
			<Text tone="muted" size="sm">
				Each button opens a real <code>&lt;dialog&gt;</code> — scrim, focus
				trap, and Esc-to-close come from the platform.
			</Text>
		</Stack>
		<Cluster gap={3}>
			<Button variant="solid" tone="accent" data-open="confirm">
				Delete account…
			</Button>
			<Button variant="outline" tone="neutral" data-open="signin">
				Sign in…
			</Button>
			<Button variant="ghost" tone="neutral" data-open="terms">
				Read the terms…
			</Button>
			<Button variant="outline" tone="accent" data-open="editor">
				Open editor…
			</Button>
		</Cluster>
	</Card>

	<Dialog id="confirm" heading="Delete account?" size="sm">
		<Text>
			This permanently removes your account and all of its data. This cannot be
			undone.
		</Text>
		<Button slot="footer" variant="ghost" tone="neutral" data-close>Cancel</Button>
		<Button slot="footer" variant="solid" tone="danger" data-close>Delete</Button>
	</Dialog>

	<Dialog id="signin" heading="Sign in" size="md">
		<Stack gap={4}>
			<Text tone="muted" size="sm">
				A medium dialog comfortably holds a short form.
			</Text>
			<Field label="Email" type="email" placeholder="you@example.com" />
			<Field label="Password" type="password" placeholder="••••••••" />
		</Stack>
		<Button slot="footer" variant="ghost" tone="neutral" data-close>Cancel</Button>
		<Button slot="footer" variant="solid" tone="accent" data-close>Sign in</Button>
	</Dialog>

	<Dialog id="terms" size="lg" label="Terms of service">
		<Cluster slot="header" gap={2} align="center">
			<span class="xtyle-badge xtyle-badge--soft xtyle-badge--info">v3</span>
			<Heading level={2} size="lg">Terms of service</Heading>
		</Cluster>
		<Stack gap={3}>
			<Text>
				The large dialog gives room for richer content — a custom header, a
				scrolling body, and a tidy action row.
			</Text>
			<Text tone="muted" size="sm">
				By continuing you agree to the acceptable-use policy, the data-handling
				addendum, and the boring parts nobody reads. The body region scrolls on
				its own when content overflows, keeping the header and footer pinned.
			</Text>
			<Text tone="muted" size="sm">
				Every surface here is derived from the same algorithm powering this
				page — the overlay panel, the hairlines, the scrim, and the focus ring
				are all materialized tokens, not bespoke styling.
			</Text>
		</Stack>
		<Button slot="footer" variant="outline" tone="neutral" data-close>Decline</Button>
		<Button slot="footer" variant="solid" tone="accent" data-close>Accept</Button>
	</Dialog>

	<Dialog id="editor" heading="Edit theme" size="xl">
		<Stack gap={3}>
			<Text tone="muted" size="sm">
				A wide, editor-class host. The default <code>lg</code> caps at 48rem, which
				crushes a code editor or a multi-column form; <code>size="xl"</code> (64rem)
				and <code>size="full"</code> are the ready-made wide steps. For an exact
				width, a consumer styles <code>::part(dialog)</code> from its own stylesheet.
			</Text>
			<div class="dialog-editor">
				<pre class="dialog-editor__code"><code>{`export const theme = derive({
	bg: "#0f1115",
	accent: "#5b8cff",
	algorithm: "xtyle-default",
});`}</code></pre>
				<Stack gap={2} class="dialog-editor__aside">
					<Field label="Background" value="#0f1115" />
					<Field label="Accent" value="#5b8cff" />
					<Field label="Algorithm" value="xtyle-default" />
				</Stack>
			</div>
		</Stack>
		<Button slot="footer" variant="ghost" tone="neutral" data-close>Cancel</Button>
		<Button slot="footer" variant="solid" tone="accent" data-close>Save</Button>
	</Dialog>
</div>

<style>
	.dialog-editor {
		display: grid;
		grid-template-columns: 1fr 16rem;
		gap: var(--space-4);
		align-items: start;
	}
	.dialog-editor__code {
		margin: 0;
		padding: var(--space-4);
		background: var(--code-bg, var(--bg-sunken));
		color: var(--code-fg, var(--fg-1));
		border-radius: var(--radius-md);
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		line-height: var(--leading-normal);
	}
	@media (max-width: 40rem) {
		.dialog-editor { grid-template-columns: 1fr; }
	}
</style>

<script>
	const root = document.querySelector<HTMLElement>("[data-dialog-demo]");
	if (root) {
		root.querySelectorAll<HTMLElement>("[data-open]").forEach((trigger) => {
			trigger.addEventListener("click", () => {
				const id = trigger.dataset.open;
				const dialog = id
					? root.querySelector<HTMLElement & { showModal?: () => void }>(`#${id}`)
					: null;
				dialog?.showModal?.();
			});
		});
		root.querySelectorAll<HTMLElement>("[data-close]").forEach((trigger) => {
			trigger.addEventListener("click", () => {
				const dialog = trigger.closest<HTMLElement & { close?: () => void }>(
					"xtyle-dialog",
				);
				dialog?.close?.();
			});
		});
	}
</script>
