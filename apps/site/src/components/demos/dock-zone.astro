---
import Card from "@xtyle/astro/Card.astro";
import Stack from "@xtyle/astro/Stack.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Text from "@xtyle/astro/Text.astro";
import DockZone from "@xtyle/astro/DockZone.astro";

// A full `DockLayout`: the docked tree plus a window already torn off, so the float chrome (the
// titlebar with its dock and close buttons, the resize grip) is on screen without a drag first.
const initialLayout = {
	tree: {
		kind: "split",
		direction: "row",
		sizes: [1, 2],
		children: [
			{ kind: "leaf", id: "zone-0", panels: ["files"], active: 0 },
			{
				kind: "split",
				direction: "column",
				sizes: [3, 2],
				children: [
					{ kind: "leaf", id: "zone-1", panels: ["preview"], active: 0 },
					{ kind: "leaf", id: "zone-2", panels: ["problems", "outline"], active: 0 },
				],
			},
		],
	},
	floating: [{ panelId: "terminal", x: 210, y: 46, w: 300, h: 130, origin: "zone-1" }],
};
---

<Stack gap={6}>
	<Card>
		<Heading slot="header" level={2} size="sm">A movable-panel workspace</Heading>
		<Stack gap={3}>
			<Text tone="muted">
				The workspace opens already split into zones, with the Terminal panel torn off into a
				floating window. Drag a tab onto another zone to move it: drop over the center to join as a
				tab, or against an edge to split. Clicking a tab just selects it. Float the Preview panel out
				with its <span aria-hidden="true">⧉</span> button, or drag any tab out past the zones. Drag the
					floating window by its titlebar and it just moves — the workspace is open floor. Push it up
					against a zone's boundary and the drop films light up: release there and it re-docks as a
					split. Its <span aria-hidden="true">⤓</span> button docks it back as a tab, and its corner
					resizes it. The <span aria-hidden="true">⋮</span> kebab on a panel opens its overflow menu.
					Every one of those surfaces — tab strip, section header, header buttons, kebab, float window,
					drag film — is drawn by the component's xript fragment, so an app reskins or restructures them
					the same way a mod would. The layout is the drag physics only; the panels are your own content.
			</Text>
			<DockZone layout={JSON.stringify(initialLayout)} style="height: 360px;" class="dock-demo">
				<section
					data-panel-id="files"
					data-title="Files"
					data-actions={JSON.stringify([{ id: "new-file", label: "New file", icon: "+" }])}
					data-menu={JSON.stringify([
						{ heading: "Files" },
						{ label: "Collapse all", value: "collapse-all" },
						{ label: "Refresh", value: "refresh", hint: "F5" },
					])}
				>
					<ul class="dz-tree">
						<li class="dz-tree__dir">src
							<ul>
								<li class="dz-tree__dir">components
									<ul>
										<li>Button.astro</li>
										<li class="is-active">DockZone.astro</li>
										<li>Table.astro</li>
									</ul>
								</li>
								<li>derive.ts</li>
								<li>register.ts</li>
							</ul>
						</li>
						<li>package.json</li>
						<li>README.md</li>
					</ul>
				</section>
				<section data-panel-id="outline" data-title="Outline" data-badge="6" data-closable>
					<ul class="dz-outline">
						<li>Overview</li>
						<li class="dz-outline--child">Anchors</li>
						<li class="dz-outline--child">Knobs</li>
						<li>Derivation</li>
						<li class="dz-outline--child">Color ramp</li>
						<li>Coverage</li>
					</ul>
				</section>
				<section
					data-panel-id="preview"
					data-title="Preview"
					data-closable
					data-actions={JSON.stringify([{ id: "float", label: "Float panel", icon: "⧉" }])}
					data-menu={JSON.stringify([
						{ label: "Reveal in tree", value: "reveal" },
						{ label: "Float panel", value: "float" },
						{ separator: true },
						{ label: "Close preview", value: "close", intent: "danger" },
					])}
				>
					<div class="dz-preview">
						<span class="dz-preview__eyebrow">Themed output</span>
						<strong class="dz-preview__title">midnight-ocean</strong>
						<p>A full token set derived from three anchors, ready to paint the whole library.</p>
						<div class="dz-preview__swatches" aria-hidden="true">
							<span style="background: var(--bg-1)"></span>
							<span style="background: var(--accent)"></span>
							<span style="background: var(--success)"></span>
							<span style="background: var(--warn)"></span>
							<span style="background: var(--danger)"></span>
						</div>
					</div>
				</section>
				<section data-panel-id="problems" data-title="Problems" data-badge="3">
					<ul class="dz-problems">
						<li class="dz-problems--warn">Contrast 4.2:1 below AA on <code>--warn-bg</code></li>
						<li class="dz-problems--error">Token <code>--border</code> consumed, not produced</li>
						<li class="dz-problems--info">3 components consume <code>--accent-3</code></li>
					</ul>
				</section>
				<section data-panel-id="terminal" data-title="Terminal" data-closable>
					<pre class="dz-term">$ xtyle derive --bg #101418 --accent #4fd6be
✓ 214 tokens · AA on every text pair
$ _</pre>
				</section>
			</DockZone>
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={2} size="sm">A stacked tool rail</Heading>
		<Stack gap={3}>
			<Text tone="muted">
				The same element in <code>mode="stack"</code>: every panel is open at once as a collapsible
				section, the shape a tool or inspector rail wants. Click a section header to collapse it;
				drag a header to re-dock it, exactly like a tab.
			</Text>
			<DockZone mode="stack" style="height: 320px; max-width: 300px;" class="dock-rail">
				<section data-panel-id="layers" data-title="Layers" data-actions={JSON.stringify([{ id: "add-layer", label: "Add layer", icon: "+" }])}>
					<ul class="dz-outline">
						<li>Background</li>
						<li class="dz-outline--child">Gradient</li>
						<li>Midground</li>
						<li>Foreground</li>
						<li class="dz-outline--child">Highlights</li>
					</ul>
				</section>
				<section data-panel-id="props" data-title="Properties">
					<ul class="dz-outline">
						<li>Opacity 100%</li>
						<li>Blend normal</li>
						<li>X 128 · Y 96</li>
					</ul>
				</section>
				<section data-panel-id="history" data-title="History" data-badge="12" data-menu={JSON.stringify([{ label: "Clear history", value: "clear", intent: "danger" }])}>
					<ul class="dz-outline">
						<li>Move layer</li>
						<li>Recolor accent</li>
						<li>Add gradient</li>
					</ul>
				</section>
			</DockZone>
		</Stack>
	</Card>
</Stack>

<script>
	import "@xtyle/core/elements";

	// Listen on document, not the element: Astro's ClientRouter remounts the zone on navigation,
	// which would detach a zone-scoped listener. The event bubbles and composes, so document catches it.
	document.addEventListener("panel-action", (event) => {
		const zone = event.target as (HTMLElement & { closePanel(id: string): void; floatPanel(id: string): void }) | null;
		if (!zone?.classList?.contains("dock-demo")) return;
		const { panelId, actionId } = (event as CustomEvent<{ panelId: string; actionId: string }>).detail;
		if (actionId === "close") zone.closePanel(panelId);
		else if (actionId === "float") zone.floatPanel(panelId);
	});
</script>

<style>
	.dock-demo :global(section[data-panel-id]) {
		font-size: var(--text-sm);
		line-height: var(--leading-normal);
		color: var(--fg-1);
	}
	.dock-demo :global(.dz-tree),
	.dock-demo :global(.dz-tree ul),
	.dock-demo :global(.dz-outline),
	.dock-demo :global(.dz-problems) {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.dock-demo :global(.dz-tree ul) {
		padding-inline-start: var(--space-4);
	}
	.dock-demo :global(.dz-tree li),
	.dock-demo :global(.dz-outline li) {
		padding: var(--space-0) 0;
		font-family: var(--font-mono);
		font-size: var(--text-xs);
	}
	.dock-demo :global(.dz-tree__dir) {
		color: var(--fg-0);
		font-weight: var(--weight-medium);
	}
	.dock-demo :global(.dz-tree .is-active) {
		color: var(--accent-text);
	}
	.dock-demo :global(.dz-outline--child) {
		padding-inline-start: var(--space-3);
		color: var(--fg-2);
	}
	.dock-demo :global(.dz-preview) {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	.dock-demo :global(.dz-preview__eyebrow) {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent-text);
	}
	.dock-demo :global(.dz-preview__title) {
		font-size: var(--text-lg);
		color: var(--fg-0);
	}
	.dock-demo :global(.dz-preview p) {
		margin: 0;
		color: var(--fg-2);
	}
	.dock-demo :global(.dz-preview__swatches) {
		display: flex;
		gap: var(--space-1);
	}
	.dock-demo :global(.dz-preview__swatches span) {
		width: var(--space-6);
		height: var(--space-6);
		border-radius: var(--radius-sm);
		border: var(--border-thin) solid var(--line);
	}
	.dock-demo :global(.dz-problems li) {
		display: flex;
		gap: var(--space-2);
		padding: var(--space-1) 0;
		border-bottom: var(--border-thin) solid var(--line);
	}
	.dock-demo :global(.dz-problems li::before) {
		content: "";
		width: var(--space-2);
		height: var(--space-2);
		margin-top: 0.35em;
		flex: none;
		border-radius: var(--radius-full);
	}
	.dock-demo :global(.dz-problems--warn::before) {
		background: var(--warn);
	}
	.dock-demo :global(.dz-problems--error::before) {
		background: var(--danger);
	}
	.dock-demo :global(.dz-problems--info::before) {
		background: var(--info);
	}
	.dock-demo :global(.dz-problems code) {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--fg-1);
	}
	.dock-demo :global(.dz-term) {
		margin: 0;
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		line-height: var(--leading-normal);
		color: var(--fg-1);
		white-space: pre-wrap;
	}
</style>
