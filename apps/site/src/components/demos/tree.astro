---
import Tree from "@xtyle/astro/Tree.astro";
import Stack from "@xtyle/astro/Stack.astro";
import Cluster from "@xtyle/astro/Cluster.astro";
import Button from "@xtyle/astro/Button.astro";
import Text from "@xtyle/astro/Text.astro";
import Heading from "@xtyle/astro/Heading.astro";
import type { TreeNode } from "@xtyle/core/markup";

const docs: TreeNode[] = [
	{
		label: "Guides",
		locked: true,
		children: [
			{ label: "Getting started", href: "#getting-started", selected: true, title: "Install, derive a theme, render your first component" },
			{ label: "Deriving a theme", href: "#deriving", title: "Pin a background and an accent; the algorithm does the rest" },
			{
				label: "Algorithms",
				expanded: true,
				title: "The durable, reusable engine behind every theme",
				children: [
					{ label: "Writing one", href: "#writing", title: "Manifest, knobs, and the derivation graph" },
					{ label: "Knobs & overrides", href: "#knobs" },
				],
			},
		],
	},
	{
		label: "Reference",
		children: [
			{ label: "Engine API", href: "#engine", title: "derive, emit, apply, and the token register" },
			{ label: "CLI", href: "#cli" },
			{ label: "Deprecated", href: "#deprecated", disabled: true },
		],
	},
	{ label: "Changelog", href: "#changelog" },
];

const files: TreeNode[] = [
	{
		label: "src",
		expanded: true,
		children: [
			{ label: "index.ts", href: "#index" },
			{
				label: "algorithms",
				children: [{ label: "default.ts", href: "#default" }],
			},
		],
	},
	{ label: "package.json", href: "#pkg" },
];

const binder: TreeNode[] = [
	{
		label: "Chapter 1",
		value: "ch1",
		expanded: true,
		// a live word count plus a distinct, toned drift pill — two trailing badges, each its own color
		badge: ["1,204", { text: "3", tone: "warn" }],
		children: [
			{
				label: "Opening",
				value: "ch1-1",
				selected: true,
				badge: "512",
				// a positional move cluster: "up" is disabled on the first sibling (greyed, not omitted,
				// so the button count stays stable row to row)
				actions: [
					{ id: "up", label: "Move up", icon: "↑", disabled: true },
					{ id: "down", label: "Move down", icon: "↓" },
					{ id: "rename", label: "Rename", icon: "✎" },
					{ id: "delete", label: "Delete", icon: "✕" },
				],
			},
			{
				label: "Rising action",
				value: "ch1-2",
				badge: ["388", { text: "1", tone: "warn" }],
				actions: [
					{ id: "up", label: "Move up", icon: "↑" },
					{ id: "down", label: "Move down", icon: "↓", disabled: true },
					{ id: "rename", label: "Rename", icon: "✎" },
					{ id: "delete", label: "Delete", icon: "✕" },
				],
			},
		],
	},
	{ label: "Chapter 2", value: "ch2", badge: "812", actions: [{ id: "rename", label: "Rename", icon: "✎" }] },
	{ label: "Notes", value: "notes", badge: "12" },
];

const live: TreeNode[] = [
	{
		label: "Act I",
		value: "act1",
		expanded: true,
		badge: "1,204",
		children: [
			{ label: "Opening", value: "act1-1", selected: true, badge: "512" },
			{ label: "Rising action", value: "act1-2", badge: "692" },
		],
	},
	{
		label: "Act II",
		value: "act2",
		expanded: true,
		badge: "640",
		children: [{ label: "Turn", value: "act2-1", badge: "640" }],
	},
];
---

<Stack gap={6} class="demo">
	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Documentation</Heading>
		<Tree label="Documentation" items={docs} />
	</section>

	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Files · compact</Heading>
		<Tree label="Project files" items={files} size="sm" />
	</section>

	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Binder · row badges & actions</Heading>
		<Tree label="Binder" items={binder} class="binder" />
	</section>

	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Live data · state survives the feed</Heading>
		<Text size="sm" tone="muted">
			Collapse Act II, select a row, then keep typing: the counts stream in while the collapse,
			the selection, and the tab stop stay where you put them. Reset re-seeds from the flags.
		</Text>
		<Tree label="Manuscript" items={live} class="live" />
		<Cluster gap={2}>
			<Button size="sm" variant="subtle" data-live="type">Type a word</Button>
			<Button size="sm" variant="ghost" data-live="reset">Reset state</Button>
		</Cluster>
	</section>
</Stack>

<script>
	import "@xtyle/core/elements";
	// Row actions fire tree-action; a real app would rename/delete here. Flash the row for the demo.
	document.addEventListener("tree-action", (event) => {
		const tree = event.target as HTMLElement | null;
		if (!tree?.classList?.contains("binder")) return;
		const { value } = (event as CustomEvent<{ value: string; action: string }>).detail;
		// Light-DOM (Astro) mode has no shadow root; the rows live directly under the element.
		const root: ParentNode = tree.shadowRoot ?? tree;
		const row = root.querySelector(`[data-value="${value}"] .xtyle-tree__row`) as HTMLElement | null;
		if (row) {
			row.animate([{ background: "var(--accent-bg)" }, { background: "transparent" }], { duration: 500 });
		}
	});

	type LiveNode = {
		label: string;
		value: string;
		badge?: string;
		expanded?: boolean;
		selected?: boolean;
		children?: LiveNode[];
	};
	type LiveTree = HTMLElement & { items: LiveNode[]; resetState(): void };

	const liveTree = document.querySelector("xtyle-tree.live") as LiveTree | null;
	const counts: Record<string, number> = { "act1-1": 512, "act1-2": 692, "act2-1": 640 };

	// The feed keeps declaring `expanded` / `selected` on every push, exactly as a real data source
	// would. Those flags only seed a node the tree has never seen before, so a branch the user
	// collapsed stays collapsed no matter how many times the counts land.
	function manuscript(): LiveNode[] {
		return [
			{
				label: "Act I",
				value: "act1",
				expanded: true,
				badge: (counts["act1-1"] + counts["act1-2"]).toLocaleString(),
				children: [
					{ label: "Opening", value: "act1-1", selected: true, badge: counts["act1-1"].toLocaleString() },
					{ label: "Rising action", value: "act1-2", badge: counts["act1-2"].toLocaleString() },
				],
			},
			{
				label: "Act II",
				value: "act2",
				expanded: true,
				badge: counts["act2-1"].toLocaleString(),
				children: [{ label: "Turn", value: "act2-1", badge: counts["act2-1"].toLocaleString() }],
			},
		];
	}

	document.querySelector('[data-live="type"]')?.addEventListener("click", () => {
		counts["act1-1"] += 1;
		if (liveTree) liveTree.items = manuscript();
	});

	document.querySelector('[data-live="reset"]')?.addEventListener("click", () => {
		liveTree?.resetState();
	});
</script>

<style>
	.demo {
		width: 100%;
		max-width: 22rem;
	}
	.demo__group {
		display: grid;
		gap: var(--space-3);
	}
</style>
