---
import Button from "@xoji/astro/Button.astro";
import Card from "@xoji/astro/Card.astro";
import Stack from "@xoji/astro/Stack.astro";
import Cluster from "@xoji/astro/Cluster.astro";
import Heading from "@xoji/astro/Heading.astro";
import Text from "@xoji/astro/Text.astro";
import { ACCENT_VARIANTS, HUES } from "@xoji/core";

const variants = ["solid", "outline", "ghost", "subtle", "link"] as const;
const tones = ["accent", "neutral", "danger", "success", "warn", "info"] as const;
const sizes = ["xs", "sm", "md", "lg"] as const;

const TONE_GROUPS = [
	{ label: "Accents", tones: ["accent", ...ACCENT_VARIANTS, "neutral"] },
	{ label: "Statuses", tones: ["success", "info", "warn", "danger"] },
	{ label: "Named hues", tones: [...HUES] },
] as const;
---

<Stack gap={6} class="button-demo">
	<Card class="button-demo__panel">
		<Stack gap={4}>
			<header class="button-demo__head">
				<Heading level={2} size="md">Variants × tones</Heading>
				<Text size="sm" tone="muted">
					Five visual treatments, six semantic tones — independent axes, mix freely.
				</Text>
			</header>
			<div class="button-demo__matrix" role="presentation">
				<div class="button-demo__matrix-corner" aria-hidden="true"></div>
				{tones.map((tone) => (
					<div class="button-demo__matrix-col">{tone}</div>
				))}
				{variants.map((variant) => (
					<>
						<div class="button-demo__matrix-row">{variant}</div>
						{tones.map((tone) => (
							<div class="button-demo__matrix-cell">
								<Button variant={variant} tone={tone}>
									{tone[0].toUpperCase() + tone.slice(1)}
								</Button>
							</div>
						))}
					</>
				))}
			</div>
		</Stack>
	</Card>

	<Card class="button-demo__panel">
		<Stack gap={4}>
			<header class="button-demo__head">
				<Heading level={2} size="md">Every tone</Heading>
				<Text size="sm" tone="muted">
					The matrix above shows the six semantic roles; the full vocabulary adds the accent ramp and the twelve named hues.
				</Text>
			</header>
			<Stack gap={4}>
				{TONE_GROUPS.map((group) => (
					<Stack gap={2}>
						<Text size="xs" tone="subtle" weight="semibold">{group.label}</Text>
						<Cluster gap={4} align="center">
							{group.tones.map((tone) => (
								<Button tone={tone}>{tone}</Button>
							))}
						</Cluster>
					</Stack>
				))}
			</Stack>
		</Stack>
	</Card>

	<div class="button-demo__split">
		<Card class="button-demo__panel">
			<Stack gap={4}>
				<header class="button-demo__head">
					<Heading level={2} size="md">Sizes</Heading>
					<Text size="sm" tone="muted">Compact, default, and large.</Text>
				</header>
				<Cluster gap={3} align="center">
					{sizes.map((size) => (
						<Button size={size}>{size.toUpperCase()}</Button>
					))}
				</Cluster>
				<Cluster gap={3} align="center">
					{sizes.map((size) => (
						<Button variant="outline" tone="neutral" size={size}>
							Cancel
						</Button>
					))}
				</Cluster>
			</Stack>
		</Card>

		<Card class="button-demo__panel">
			<Stack gap={4}>
				<header class="button-demo__head">
					<Heading level={2} size="md">States</Heading>
					<Text size="sm" tone="muted">
						Loading, disabled, toggles, and the anchor form — all from the same component.
					</Text>
				</header>
				<Cluster gap={3} align="center">
					<Button tone="success" loading>Saving…</Button>
					<Button disabled>Disabled</Button>
					<Button variant="outline" tone="neutral" disabled>Disabled</Button>
				</Cluster>
				<Cluster gap={3} align="center">
					<Button variant="subtle" tone="accent" pressed>Bold</Button>
					<Button variant="subtle" tone="accent" pressed={false}>Italic</Button>
					<Button variant="outline" tone="neutral" pressed>Grid</Button>
					<Button variant="ghost" tone="neutral" pressed={false}>List</Button>
				</Cluster>
				<Cluster gap={3} align="center">
					<Button variant="ghost" tone="neutral" size="xs" selected>Day</Button>
					<Button variant="ghost" tone="neutral" size="xs" selected={false}>Week</Button>
					<Button variant="ghost" tone="neutral" size="xs" selected={false}>Month</Button>
				</Cluster>
				<Cluster gap={3} align="center">
					<Button variant="link" tone="info" href="/components">As a link</Button>
					<Button variant="ghost" tone="danger">Hover me</Button>
				</Cluster>
			</Stack>
		</Card>
	</div>

	<Card class="button-demo__panel">
		<Stack gap={4}>
			<header class="button-demo__head">
				<Heading level={2} size="md">Icons & shapes</Heading>
				<Text size="sm" tone="muted">
					Leading and trailing icon slots, the square icon-only form, and a full-width block.
				</Text>
			</header>
			<Cluster gap={3} align="center">
				<Button tone="accent">
					<svg slot="icon-start" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
						<path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2Z" />
					</svg>
					New theme
				</Button>
				<Button variant="outline" tone="neutral">
					Continue
					<svg slot="icon-end" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
						<path fill="currentColor" d="M13.3 5.3 11.9 6.7 16.2 11H4v2h12.2l-4.3 4.3 1.4 1.4 6.7-6.7-6.7-6.7Z" />
					</svg>
				</Button>
				<Button variant="subtle" tone="danger" iconOnly aria-label="Delete">
					<svg slot="icon-start" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
						<path fill="currentColor" d="M9 3h6l1 2h4v2H4V5h4l1-2Zm-3 6h12l-1 12H7L6 9Z" />
					</svg>
				</Button>
				<Button variant="ghost" tone="neutral" iconOnly aria-label="Settings">
					<svg slot="icon-start" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
						<path fill="currentColor" d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm9 4-2-1 1-2-2-2-2 1-1-2h-2l-1 2-2-1-2 2 1 2-2 1v2l2 1-1 2 2 2 2-1 1 2h2l1-2 2 1 2-2-1-2 2-1v-2Z" />
					</svg>
				</Button>
			</Cluster>
			<Button block tone="accent">Block button — fills its container</Button>
		</Stack>
	</Card>

	<Card class="button-demo__panel">
		<Stack gap={4}>
			<header class="button-demo__head">
				<Heading level={2} size="md">List rows & alignment</Heading>
				<Text size="sm" tone="muted">
					Pair <code>block</code> with <code>align="start"</code> for a left-aligned action row: a settings entry or a recent-file row that runs a callback, chevron trailing.
				</Text>
			</header>
			<Stack gap={2} class="button-demo__rows">
				<Button block align="start" variant="ghost" tone="neutral">
					<svg slot="icon-start" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
						<path fill="currentColor" d="M4 4h16v4H4V4Zm0 6h16v4H4v-4Zm0 6h10v4H4v-4Z" />
					</svg>
					Recent projects
					<svg slot="icon-end" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
						<path fill="currentColor" d="m9 6 6 6-6 6-1.4-1.4L11.2 12 7.6 8.4 9 6Z" />
					</svg>
				</Button>
				<Button block align="start" variant="ghost" tone="neutral">
					<svg slot="icon-start" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
						<path fill="currentColor" d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm9 4-2-1 1-2-2-2-2 1-1-2h-2l-1 2-2-1-2 2 1 2-2 1v2l2 1-1 2 2 2 2-1 1 2h2l1-2 2 1 2-2-1-2 2-1v-2Z" />
					</svg>
					Settings
					<svg slot="icon-end" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
						<path fill="currentColor" d="m9 6 6 6-6 6-1.4-1.4L11.2 12 7.6 8.4 9 6Z" />
					</svg>
				</Button>
			</Stack>
			<Stack gap={2}>
				<Button block align="start" variant="outline" tone="neutral">Start-aligned</Button>
				<Button block variant="outline" tone="neutral">Centered (default)</Button>
				<Button block align="end" variant="outline" tone="neutral">End-aligned</Button>
			</Stack>
		</Stack>
	</Card>
</Stack>

<style>
	.button-demo__split {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: var(--space-4);
	}
	@media (min-width: 48rem) {
		.button-demo__split {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
	.button-demo__head :global(h3) {
		margin: 0 0 var(--space-1);
	}
	.button-demo__matrix {
		display: grid;
		grid-template-columns: auto repeat(6, minmax(0, 1fr));
		gap: var(--space-2);
		align-items: center;
		overflow-x: auto;
	}
	.button-demo__matrix-corner {
		min-width: 4rem;
	}
	.button-demo__matrix-col,
	.button-demo__matrix-row {
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--fg-2);
	}
	.button-demo__matrix-col {
		text-align: center;
	}
	.button-demo__matrix-row {
		padding-right: var(--space-3);
		white-space: nowrap;
	}
	.button-demo__matrix-cell {
		display: flex;
		justify-content: center;
	}
	.button-demo__matrix-cell :global(.xoji-button) {
		width: 100%;
		justify-content: center;
	}
	.button-demo__rows :global(.xoji-button__label) {
		margin-right: auto;
	}
</style>
