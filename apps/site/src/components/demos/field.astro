---
import Field from "@xoji/astro/Field.astro";
import Stack from "@xoji/astro/Stack.astro";
import Grid from "@xoji/astro/Grid.astro";
import Heading from "@xoji/astro/Heading.astro";
---

<Stack gap={6} class="demo">
	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">A signed-in form</Heading>
		<Grid minColWidth="16rem" gap={4}>
			<Field
				label="Email"
				name="email"
				type="email"
				placeholder="you@example.com"
				description="We'll only use this to sign you in."
				required
			>
				<svg slot="prefix" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
					<path fill="currentColor" d="M4 6h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Zm1.4 2L12 12.3 18.6 8H5.4Z" />
				</svg>
			</Field>
			<Field
				label="Password"
				name="password"
				type="password"
				placeholder="••••••••••••"
				description="At least 12 characters."
				required
				clearable
			/>
		</Grid>
	</section>

	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">Adornments</Heading>
		<Grid minColWidth="16rem" gap={4}>
			<Field label="Search" name="q" placeholder="Search the docs…">
				<svg slot="prefix" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
					<path fill="currentColor" d="M10 4a6 6 0 1 0 3.5 10.9l4.3 4.3 1.4-1.4-4.3-4.3A6 6 0 0 0 10 4Zm0 2a4 4 0 1 1 0 8 4 4 0 0 1 0-8Z" />
				</svg>
			</Field>
			<Field label="Amount" name="amount" type="number" value="0">
				<span slot="prefix">$</span>
				<span slot="suffix">USD</span>
			</Field>
		</Grid>
	</section>

	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">Sizes</Heading>
		<Grid minColWidth="13rem" gap={4} align="end">
			<Field label="Small" name="size-sm" size="sm" placeholder="sm" />
			<Field label="Medium" name="size-md" size="md" placeholder="md (default)" />
			<Field label="Large" name="size-lg" size="lg" placeholder="lg" />
		</Grid>
	</section>

	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">States</Heading>
		<Grid minColWidth="16rem" gap={4}>
			<Field
				label="Workspace name"
				name="invalid"
				value="my workspace!"
				invalid
				error="Use only letters, numbers, and dashes."
			/>
			<Field label="API key" name="readonly" value="xoji_sk_live_8f2c…" readonly description="Generated once. Copy it now." />
			<Field label="Inherited setting" name="disabled" value="From parent theme" disabled />
		</Grid>
	</section>

	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">Type-ahead</Heading>
		<Grid minColWidth="16rem" gap={4}>
			<Field
				label="Branch"
				name="branch"
				placeholder="Type to filter…"
				description="Suggestions come from the field's own datalist, so they work inside the shadow root."
				options={["main", "develop", "release/1.0", "hotfix/login", "feature/themes"]}
			/>
			<Field
				label="Timezone"
				name="tz"
				placeholder="Start typing a city…"
				options={[
					{ value: "America/New_York", label: "New York" },
					{ value: "Europe/London", label: "London" },
					{ value: "Asia/Tokyo", label: "Tokyo" },
					{ value: "Australia/Sydney", label: "Sydney" },
				]}
			/>
		</Grid>
	</section>

	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">Code-shaped</Heading>
		<Grid minColWidth="16rem" gap={4}>
			<Field
				label="Accent token"
				name="hex"
				mono
				spellcheck="false"
				value="#7c5cff"
				description="A mono field for hex, ids, and paths; spellcheck is forwarded off."
			/>
			<Field label="Slug" name="slug" mono spellcheck="false" value="open-register" placeholder="kebab-case" />
		</Grid>
	</section>
</Stack>

<style>
	.demo {
		width: 100%;
	}
	.demo__group {
		display: grid;
		gap: var(--space-3);
	}
</style>
