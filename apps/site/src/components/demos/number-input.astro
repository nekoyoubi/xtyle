---
import NumberInput from "@xoji/astro/NumberInput.astro";
import Stack from "@xoji/astro/Stack.astro";
import Cluster from "@xoji/astro/Cluster.astro";
import Heading from "@xoji/astro/Heading.astro";
import Text from "@xoji/astro/Text.astro";
---

<Stack gap={6} class="demo">
	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Common fields</Heading>
		<Cluster gap={5} align="end" class="demo__row">
			<Stack gap={2}>
				<NumberInput label="Quantity" value={1} min={0} max={99} />
			</Stack>
			<Stack gap={2}>
				<NumberInput label="Step by 5" value={20} min={0} max={100} step={5} />
			</Stack>
			<Stack gap={2}>
				<NumberInput label="Price" value={9.99} min={0} step={0.01} />
			</Stack>
		</Cluster>
	</section>

	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Alternate step</Heading>
		<Cluster gap={5} align="end" class="demo__row">
			<Stack gap={2}>
				<NumberInput label="Volume" value={50} min={0} max={100} altStep={10} />
				<Text size="xs" tone="subtle">Shift, PageUp/Dn → ±10</Text>
			</Stack>
			<Stack gap={2}>
				<NumberInput label="Fine tune" value={1} min={0} step={1} altStep={0.1} altDefault />
				<Text size="xs" tone="subtle">plain → ±0.1, Shift → ±1</Text>
			</Stack>
		</Cluster>
	</section>

	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Free-form</Heading>
		<Cluster gap={5} align="end" class="demo__row">
			<Stack gap={2}>
				<NumberInput label="Graph parameter" value={3.14159} step="any" />
				<Text size="xs" tone="subtle">step="any" → type 1e-3 or 2.71828; commits verbatim, no clamp</Text>
			</Stack>
		</Cluster>
	</section>

	<section class="demo__group">
		<Heading level={3} size="sm" tone="muted">Sizes &amp; disabled</Heading>
		<Cluster gap={5} align="end">
			<Stack gap={2} align="center">
				<NumberInput label="Small" size="sm" value={3} min={0} />
				<Text size="xs" tone="subtle">sm</Text>
			</Stack>
			<Stack gap={2} align="center">
				<NumberInput label="Large" size="lg" value={7} min={0} />
				<Text size="xs" tone="subtle">lg</Text>
			</Stack>
			<Stack gap={2} align="center">
				<NumberInput label="Locked" value={42} disabled />
				<Text size="xs" tone="subtle">disabled</Text>
			</Stack>
		</Cluster>
	</section>
</Stack>

<style>
	.demo {
		width: 100%;
	}
	.demo__group {
		display: grid;
		gap: var(--space-3);
	}
	.demo__row {
		flex-wrap: wrap;
	}
</style>
