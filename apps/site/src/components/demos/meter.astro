---
import Meter from "@xtyle/astro/Meter.astro";
import Card from "@xtyle/astro/Card.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Stack from "@xtyle/astro/Stack.astro";
---

<Stack gap={6}>
	<Card>
		<Heading slot="header" level={3} size="sm">System health</Heading>
		<Stack gap={4}>
			<Meter value={38} low={50} high={85} optimum={0} unit="%" label="CPU" />
			<Meter value={72} low={50} high={85} optimum={0} unit="%" label="Memory" />
			<Meter value={93} low={50} high={85} optimum={0} unit="%" label="Disk" />
			<Meter value={88} low={20} high={80} optimum={100} unit="%" label="Battery" />
		</Stack>
	</Card>

	<Card>
		<Heading slot="header" level={3} size="sm">No thresholds</Heading>
		<Meter value={60} unit="%" label="Storage used" />
	</Card>
</Stack>
