---
import Segmented from "@xtyle/astro/Segmented.astro";
import Segment from "@xtyle/astro/Segment.astro";
import Icon from "@xtyle/astro/Icon.astro";
import Stack from "@xtyle/astro/Stack.astro";
import Cluster from "@xtyle/astro/Cluster.astro";
import Heading from "@xtyle/astro/Heading.astro";
import Text from "@xtyle/astro/Text.astro";
import { ACCENT_VARIANTS, HUES } from "@xtyle/core";

const TONE_GROUPS = [
	{ label: "Accents", tones: ["accent", ...ACCENT_VARIANTS, "neutral"] },
	{ label: "Statuses", tones: ["success", "info", "warn", "danger"] },
	{ label: "Named hues", tones: [...HUES] },
] as const;
---

<Stack gap={6} class="demo">
	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">Choices worth showing at once</Heading>
		<Stack gap={4}>
			<Segmented label="View" options="Day,Week,Month" value="Week" />
			<Segmented label="Alignment" options="Left:start,Center:center,Right:end" value="center" />
			<Segmented label="Theme" options="Light,Dark,Auto" value="Auto" />
		</Stack>
	</section>

	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">Sizes &amp; disabled</Heading>
		<Stack gap={4} align="start">
			<Segmented size="sm" label="Small" options="One,Two,Three" value="Two" />
			<Segmented label="Medium (default)" options="One,Two,Three" value="Two" />
			<Segmented size="lg" label="Large" options="One,Two,Three" value="Two" />
			<Segmented label="Locked" options="One,Two,Three" value="Two" disabled />
		</Stack>
	</section>

	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">Structured options</Heading>
		<Stack gap={2}>
			<Text size="sm" tone="muted">
				Pass <code>{`{ value, label }[]`}</code> when the label differs from the value the handler
				needs, or carries a comma or colon the shorthand can't survive.
			</Text>
			<Segmented
				label="Export"
				value="md"
				options={[
					{ value: "md", label: "Markdown" },
					{ value: "html", label: "HTML" },
					{ value: "epub", label: "EPUB" },
				]}
			/>
		</Stack>
	</section>

	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">Per-option disabled &amp; badges</Heading>
		<Stack gap={2}>
			<Text size="sm" tone="muted">
				A data-conditional view switch: <code>report</code> carries a count while <code>text</code>
				and <code>log</code> stay disabled until their data exists. Arrow keys skip the disabled
				segments, and the default selection lands on the first enabled one.
			</Text>
			<Segmented
				label="Run output"
				options={[
					{ value: "report", label: "Report", badge: "128" },
					{ value: "text", label: "Text", disabled: true },
					{ value: "log", label: "Log", disabled: true },
				]}
			/>
		</Stack>
	</section>

	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">Icon segments</Heading>
		<Stack gap={2}>
			<Text size="sm" tone="muted">
				Drop <code>{`<Segment>`}</code> children holding an <code>{`<Icon>`}</code> in place of text
				labels. Each carries a <code>value</code> and an accessible <code>label</code>; selection,
				roving focus, and the form value work exactly as with <code>options</code>. The option owns
				its name and tooltip (hover a segment), so the icon stays decorative. Drop the visible
				heading with <code>aria-label</code> for a bare toolbar bar, as in the Playback control.
			</Text>
			<Cluster gap={4} align="end">
				<Segmented label="Severity" value="info">
					<Segment value="info" label="Info"><Icon name="info" /></Segment>
					<Segment value="warn" label="Warnings"><Icon name="warning" /></Segment>
					<Segment value="error" label="Errors"><Icon name="error" /></Segment>
				</Segmented>
				<Segmented tone="success" aria-label="Playback" value="play">
					<Segment value="play" label="Play"><Icon name="play" /></Segment>
					<Segment value="pause" label="Pause"><Icon name="pause" /></Segment>
					<Segment value="stop" label="Stop"><Icon name="stop" /></Segment>
				</Segmented>
			</Cluster>
		</Stack>
	</section>

	<section class="demo__group">
		<Heading level={2} size="sm" tone="muted">Every tone</Heading>
		<Stack gap={4}>
			{TONE_GROUPS.map((group) => (
				<Stack gap={2}>
					<Text size="xs" tone="subtle" weight="semibold">{group.label}</Text>
					<Cluster gap={4} align="center">
						{group.tones.map((tone) => <Segmented tone={tone} label={tone} options="Off,On" value="On" />)}
					</Cluster>
				</Stack>
			))}
		</Stack>
	</section>
</Stack>

<style>
	.demo {
		width: 100%;
	}
	.demo__group {
		display: grid;
		gap: var(--space-3);
	}
</style>
