---
import { listComponents } from "@xtyle/core";
import Tree from "@xtyle/astro/Tree.astro";
import { categoryOrder, categoryMeta } from "./reference/categories.ts";
import { isNewComponent } from "../data/newness.ts";
import { BENCH_TOOLS } from "../data/bench-tools.ts";

interface Props {
	currentPath: string;
}
const { currentPath } = Astro.props;

const all = listComponents();
const activeId = currentPath.startsWith("/components/")
	? currentPath.slice("/components/".length)
	: null;

const categoryNodes = categoryOrder
	.map((category) => {
		const comps = all
			.filter((c) => c.category === category)
			.sort((a, b) => a.name.localeCompare(b.name));
		if (comps.length === 0) return null;
		return {
			label: categoryMeta[category].label,
			value: category,
			expanded: comps.some((c) => c.id === activeId),
			children: comps.map((c) => ({
				label: c.name,
				value: c.id,
				href: `/components/${c.id}`,
				selected: c.id === activeId,
				...(isNewComponent(c.since) ? { badge: "New" } : {}),
			})),
		};
	})
	.filter((node): node is NonNullable<typeof node> => node !== null);

const items = [
	{ label: "About", value: "overview", href: "/", selected: currentPath === "/" },
	{
		label: "Bench",
		value: "bench",
		expanded: true,
		locked: true,
		children: BENCH_TOOLS.map((t) => ({
			label: t.label,
			value: `bench-${t.id}`,
			href: t.href,
			selected: currentPath === t.href,
			...(isNewComponent(t.since) ? { badge: "New" } : {}),
		})),
	},
	{
		label: "Components",
		value: "components",
		href: "/components",
		selected: currentPath === "/components",
		expanded: true,
		locked: true,
		children: categoryNodes,
	},
	{
		label: "Docs",
		value: "docs",
		expanded: true,
		locked: true,
		children: [
			{ label: "Getting started", value: "start", href: "/start", selected: currentPath === "/start" },
			{ label: "Algorithms", value: "algorithms", href: "/algorithms", selected: currentPath === "/algorithms" },
			{ label: "Extending", value: "extending", href: "/extending-components", selected: currentPath === "/extending-components" },
			{ label: "MCP", value: "mcp", href: "/mcp", selected: currentPath === "/mcp" },
		],
	},
];
---

<nav class="x-sitenav">
	<Tree items={items} label="Site navigation" />
</nav>

<style>
	.x-sitenav :global(.xtyle-tree__badge) {
		color: var(--accent-text);
		background: var(--accent-bg);
		font-size: var(--text-xs);
		font-weight: var(--weight-semibold);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		padding: 0.05em 0.4em;
		border-radius: var(--radius-full);
		line-height: 1.4;
	}
</style>
