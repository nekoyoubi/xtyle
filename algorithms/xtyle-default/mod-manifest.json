		],
		"knobSpecs": [
			{
				"name": "scheme",
				"kind": "select",
				"label": "Scheme",
				"options": [
					{
						"value": "dark",
						"label": "dark"
					},
					{
						"value": "light",
						"label": "light"
					}
				]
			},
			{
				"name": "surfaceRamp",
				"kind": "range",
				"label": "Surface ramp",
				"min": -0.06,
				"max": 0.06,
				"step": 0.005,
				"default": 0.045,
				"defaultByScheme": {
					"dark": 0.045,
					"light": -0.045
				}
			},
			{
				"name": "accentStrategy",
				"kind": "select",
				"label": "Accent strategy",
				"options": [
					{
						"value": "fan",
						"label": "fan (flanks + complement)"
					},
					{
						"value": "step",
						"label": "step (even hue wheel)"
					},
					{
						"value": "shade",
						"label": "shade (one hue, four depths)"
					},
					{
						"value": "duo",
						"label": "duo (two brands + their shades)"
					}
				]
			},
			{
				"name": "accentShiftStep",
				"kind": "range",
				"label": "Accent shift step",
				"min": 0,
				"max": 180,
				"step": 5,
				"default": 90,
				"unit": "°"
			},
			{
				"name": "accentSplit",
				"kind": "range",
				"label": "Accent split",
				"min": 0,
				"max": 90,
				"step": 1,
				"default": 45,
				"unit": "°"
			},
