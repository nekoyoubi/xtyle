{
	"$schema": "https://xript.dev/schema/mod-manifest/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-quiet",
	"version": "0.1.0",
	"title": "Xtyle Quiet",
	"family": "xtyle",
	"capabilities": ["color-math"],
	"entry": {
		"script": "src/mod.js",
		"format": "script",
		"exports": {
			"graph": {
				"description": "Token lineage nodes for anchors+knobs.",
				"params": [{ "name": "input", "type": "DeriveInput" }],
				"returns": { "array": "TokenNode" }
			},
			"traced": {
				"description": "Per-pass register snapshots for anchors+knobs.",
				"params": [{ "name": "input", "type": "DeriveInput" }],
				"returns": { "array": "TraceSnapshot" }
			},
			"manifest": {
				"description": "produces + categories + knobs.",
				"returns": "AlgorithmManifest"
			},
			"invariants": {
				"description": "Evaluate per-algorithm invariants.",
				"params": [{ "name": "ctx", "type": "map" }],
				"returns": { "array": "InvariantResult" }
			}
		}
	}
}
