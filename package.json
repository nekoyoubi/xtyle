{
	"name": "xoji-workspace",
	"version": "0.3.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"build": "node scripts/build-fragments.mjs && npm run build -w @xoji/core && node scripts/build-mods.mjs && npm run build --workspaces --if-present",
		"build:fragments": "node scripts/build-fragments.mjs",
		"build:mods": "node scripts/build-mods.mjs",
		"check:mods": "node scripts/check-mods-fresh.mjs",
		"pretest": "node scripts/check-mods-fresh.mjs",
		"test": "npm run test --workspaces --if-present",
		"dev": "npm run dev --workspace=@xoji/site --if-present",
		"version:bump": "node scripts/bump-version.mjs",
		"stats:snapshot": "node scripts/snapshot-stats.mjs",
		"release": "node scripts/release.mjs"
	},
	"devDependencies": {
		"esbuild": "^0.21.5"
	}
}
