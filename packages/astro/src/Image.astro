---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight, composeFallbackSlot } from "@xtyle/core/elements/ssr";
import { hoverMediaHtml, IMAGE_FITS, resolveVocab, IMAGE_RADII, IMAGE_LOADING, IMAGE_TRIGGERS, IMAGE_HOVER_AUDIO, resolveOptionalVocab } from "@xtyle/core";

type ImageFit = (typeof IMAGE_FITS)[number];
type ImageRadius = (typeof IMAGE_RADII)[number];
type ImageLoading = (typeof IMAGE_LOADING)[number];
type ImageTrigger = (typeof IMAGE_TRIGGERS)[number];
type ImageHoverAudio = (typeof IMAGE_HOVER_AUDIO)[number];

interface Props {
	src?: string;
	alt?: string;
	ratio?: string;
	fit?: ImageFit;
	radius?: ImageRadius;
	loading?: ImageLoading;
	lightbox?: boolean;
	trigger?: ImageTrigger;
	caption?: string;
	/** A video (`.mp4`/`.webm`) or gif shown on hover/focus; the still `src` is the poster. */
	hoverSrc?: string;
	/** An explicit poster still for the hover video (defaults to `src`). */
	hoverPoster?: string;
	/** Allow sound on the hover video and show an unmute toggle; omit for a silent preview. */
	hoverAudio?: ImageHoverAudio;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	src,
	alt = "",
	ratio,
	fit: fitInput,
	radius: radiusInput,
	loading: loadingInput,
	lightbox = false,
	trigger: triggerInput,
	caption,
	hoverSrc,
	hoverPoster,
	hoverAudio: hoverAudioInput,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("image", Astro.props);
const fit = resolveVocab(fitInput, IMAGE_FITS, "cover", "image fit");
const radius = resolveVocab(radiusInput, IMAGE_RADII, "md", "image radius");
const loading = resolveVocab(loadingInput, IMAGE_LOADING, "lazy", "image loading");
const trigger = resolveVocab(triggerInput, IMAGE_TRIGGERS, "frame", "image trigger");
const hoverAudio = resolveOptionalVocab(hoverAudioInput, IMAGE_HOVER_AUDIO, "image hoverAudio");

const bindings = { src, alt, ratio, fit, radius, loading, caption };
const scaffold = await renderFragmentLight("image", bindings);
// Compose the hover slot: an author-supplied `hover` slot wins; otherwise `hoverSrc` generates the
// media. Either way it replaces the fragment's `<slot name="hover">` so the zero-JS render is right.
const hoverContent = Astro.slots.has("hover")
	? await Astro.slots.render("hover")
	: hoverSrc
		? hoverMediaHtml(hoverSrc, hoverPoster ?? src)
		: null;
const composed = composeFallbackSlot(scaffold, "hover", hoverContent);
---

<xtyle-image
	src={src}
	alt={alt}
	ratio={ratio}
	fit={fit}
	radius={radius}
	loading={loading}
	caption={caption}
	lightbox={lightbox ? "" : undefined}
	trigger={trigger === "button" ? "button" : undefined}
	hover-src={hoverSrc}
	hover-poster={hoverPoster}
	hover-audio={hoverAudio}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
