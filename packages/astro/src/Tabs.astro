---
import { type TabItemData } from "@xtyle/core/markup";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { checkAuthoring } from "./internal/diagnose.js";
import { TABS_SIZES, resolveVocab, TABS_VARIANTS, TABS_ACTIVATIONS } from "@xtyle/core";

type Size = (typeof TABS_SIZES)[number];
type TabsVariant = (typeof TABS_VARIANTS)[number];
type TabsActivation = (typeof TABS_ACTIVATIONS)[number];

interface Props {
	items?: TabItemData[];
	variant?: TabsVariant;
	size?: Size;
	activation?: TabsActivation;
	value?: string;
	label?: string;
	labelledby?: string;
	/** Pin the tablist while the active panel scrolls beneath it (app-surface tabs); off for inline tabs. */
	sticky?: boolean;
	/** Render only the tab strip (no panel region) so the consumer owns the content; the element still
	 * drives selection, roving focus, and a11y, and tabs omit `aria-controls` since they own no panels. */
	tablist?: boolean;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	items,
	variant: variantInput,
	size: sizeInput,
	activation: activationInput,
	value,
	label,
	labelledby,
	sticky = false,
	tablist = false,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;

await checkAuthoring("tabs", Astro.props);
const size = resolveVocab(sizeInput, TABS_SIZES, "md", "tabs size");
const variant = resolveVocab(variantInput, TABS_VARIANTS, "underline", "tabs variant");
const activation = resolveVocab(activationInput, TABS_ACTIVATIONS, "automatic", "tabs activation");

const tabItems = items ?? [];
const uid = `xtyle-tabs-${Math.random().toString(36).slice(2, 9)}`;

const bindings = {
	tabs: tabItems.map((item, i) => ({
		key: item.value ?? String(i),
		label: item.label,
		panel: item.panel ?? "",
		disabled: item.disabled,
	})),
	activeId: value ?? null,
	variant,
	size,
	sticky,
	tablist,
	label: label ?? null,
	labelledby: labelledby ?? null,
	uid,
};
// Two authoring modes. items-mode (the common case) renders the whole chrome light from `bindings`
// and ships no children. The advanced slotted mode pairs the consumer's children by order, and
// those must reach the element still carrying their marker — hence `data-xtyle-tab` /
// `data-xtyle-panel`, which no framework claims.
//
// `slot` cannot be that marker. On a child of an Astro *component* it is a routing directive Astro
// always consumes: with a matching `<slot name>` below the child renders there minus the attribute,
// and with no match the child is dropped entirely. (A `slot` a component writes on its own root
// element, as `Segment.astro` does, is ordinary HTML and survives — that is a different case, not a
// bug to fix.) The named receivers below stay so a legacy `slot=`-marked child is passed through
// rather than discarded.
const useItems = tabItems.length > 0;
const light = useItems ? await renderFragmentLight("tabs", bindings) : "";
---

{useItems ? (
	<xtyle-tabs
		variant={variant}
		size={size}
		activation={activation}
		value={value}
		label={label}
		labelledby={labelledby}
		sticky={sticky}
		tablist={tablist || undefined}
		items={JSON.stringify(items)}
		class={extra}
		set:html={light}
		{...rest}
	/>
) : (
	<xtyle-tabs variant={variant} size={size} activation={activation} value={value} label={label} labelledby={labelledby} sticky={sticky} tablist={tablist || undefined} class={extra} {...rest}>
		<slot name="tab" />
		<slot name="panel" />
		<slot />
	</xtyle-tabs>
)}

{!isStatic && <script>import "@xtyle/core/elements";</script>}
