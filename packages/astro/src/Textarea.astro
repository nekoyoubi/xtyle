---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { SIZES, resolveVocab, TEXTAREA_RESIZES } from "@xtyle/core";

type Size = (typeof SIZES)[number];
type TextareaResize = (typeof TEXTAREA_RESIZES)[number];

interface Props {
	label?: string;
	value?: string;
	rows?: number;
	resize?: TextareaResize;
	placeholder?: string;
	size?: Size;
	name?: string;
	invalid?: boolean;
	error?: string;
	disabled?: boolean;
	required?: boolean;
	/** Render the control in the monospace stack for code-shaped text. */
	mono?: boolean;
	/** Render zero-JS: emit the declarative shadow but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	label,
	value,
	rows = 3,
	resize: resizeInput,
	placeholder,
	size: sizeInput,
	name,
	invalid = false,
	error,
	disabled = false,
	required = false,
	mono = false,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("textarea", Astro.props);
const size = resolveVocab(sizeInput, SIZES, "md", "textarea size");
const resize = resolveVocab(resizeInput, TEXTAREA_RESIZES, "vertical", "textarea resize");

const seed = Math.random().toString(36).slice(2, 9);
const fieldId = `xtyle-textarea-${seed}`;
const errorId = `xtyle-textarea-error-${seed}`;

const bindings = {
	fieldId,
	errorId,
	label: label ?? null,
	error: error ?? null,
	size,
	resize,
	invalid,
	mono,
};
const light = await renderFragmentLight("textarea", bindings);
---

<xtyle-textarea
	label={label}
	value={value}
	rows={rows}
	resize={resize}
	placeholder={placeholder}
	size={size}
	name={name}
	invalid={invalid || undefined}
	error={error}
	disabled={disabled || undefined}
	required={required || undefined}
	mono={mono || undefined}
	class={extra}
	set:html={light}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
