---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { ORIENTATIONS, resolveVocab, SEPARATOR_VARIANTS, SEPARATOR_SIZES } from "@xtyle/core";

type Orientation = (typeof ORIENTATIONS)[number];
type SeparatorVariant = (typeof SEPARATOR_VARIANTS)[number];
type SeparatorSize = (typeof SEPARATOR_SIZES)[number];

interface Props {
	orientation?: Orientation;
	variant?: SeparatorVariant;
	size?: SeparatorSize;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	orientation: orientationInput,
	variant: variantInput,
	size: sizeInput,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("separator", Astro.props);
const orientation = resolveVocab(orientationInput, ORIENTATIONS, "horizontal", "separator orientation");
const variant = resolveVocab(variantInput, SEPARATOR_VARIANTS, "default", "separator variant");
const size = resolveVocab(sizeInput, SEPARATOR_SIZES, "normal", "separator size");

const bindings = { orientation, variant, size };
const chrome = await renderFragmentLight("separator", bindings);
const slotHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const composed = chrome.replace("<slot></slot>", () => slotHtml);
---

<xtyle-separator orientation={orientation} variant={variant} size={size} class={extra} set:html={composed} {...rest} />

{!isStatic && <script>import "@xtyle/core/elements";</script>}
