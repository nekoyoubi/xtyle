---
interface Props {
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const { class: extra, ...rest } = Astro.props;
---

<xtyle-timeline class:list={["xtyle-timeline", extra]} {...rest}>
	<slot />
</xtyle-timeline>

<script>
	import "@xtyle/core/elements";
</script>
