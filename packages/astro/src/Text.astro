---
import { checkAuthoring } from "./internal/diagnose.js";
import { resolveTone, EMPHASIS_TONES, TEXT_TAGS, resolveVocab, TEXT_SIZES, TEXT_WEIGHTS, TEXT_LEADINGS } from "@xtyle/core";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import type { TextTone } from "@xtyle/core";

type TextAs = (typeof TEXT_TAGS)[number];
type TextSize = (typeof TEXT_SIZES)[number];
type TextWeight = (typeof TEXT_WEIGHTS)[number];
type TextLeading = (typeof TEXT_LEADINGS)[number];

interface Props {
	as?: TextAs;
	size?: TextSize;
	weight?: TextWeight;
	leading?: TextLeading;
	tone?: TextTone;
	mono?: boolean;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	as: asInput,
	size: sizeInput,
	weight: weightInput,
	leading: leadingInput,
	tone: toneInput,
	mono = false,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("text", Astro.props);
const as = resolveVocab(asInput, TEXT_TAGS, "p", "text as");
const size = resolveVocab(sizeInput, TEXT_SIZES, "body", "text size");
const weight = resolveVocab(weightInput, TEXT_WEIGHTS, "normal", "text weight");
const leading = resolveVocab(leadingInput, TEXT_LEADINGS, "snug", "text leading");
const tone = resolveTone(toneInput, "default", EMPHASIS_TONES);

const bindings = { as, size, weight, leading, tone, mono };
const chrome = await renderFragmentLight("text", bindings);
const slotHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const composed = chrome.replace("<slot></slot>", () => slotHtml);
---

<xtyle-text
	as={as}
	size={size}
	weight={weight}
	leading={leading}
	tone={tone}
	mono={mono || undefined}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
