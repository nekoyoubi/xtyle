---
import { checkAuthoring } from "./internal/diagnose.js";
import { TOUR_PROGRESS, resolveVocab, POPOVER_PLACEMENTS, resolveOptionalVocab, SPOTLIGHT_SHAPES, SPOTLIGHT_PULSES } from "@xtyle/core";
type Progress = (typeof TOUR_PROGRESS)[number];
type Placement = (typeof POPOVER_PLACEMENTS)[number];
type Shape = (typeof SPOTLIGHT_SHAPES)[number];
type Pulse = (typeof SPOTLIGHT_PULSES)[number];

interface Props {
	open?: boolean;
	index?: number;
	progress?: Progress;
	backLabel?: string;
	nextLabel?: string;
	doneLabel?: string;
	skipLabel?: string;
	noSkip?: boolean;
	placement?: Placement;
	shape?: Shape;
	pulse?: Pulse;
	noDismiss?: boolean;
	/** Render zero-JS: emit the markup but never load the runtime. A tour is invisible until started, so this is a bare element. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	open = false,
	index,
	progress: progressInput,
	backLabel,
	nextLabel,
	doneLabel,
	skipLabel,
	noSkip = false,
	placement: placementInput,
	shape: shapeInput,
	pulse: pulseInput,
	noDismiss = false,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("tour", Astro.props);
const progress = resolveVocab(progressInput, TOUR_PROGRESS, "count", "tour progress");
const placement = resolveOptionalVocab(placementInput, POPOVER_PLACEMENTS, "tour placement");
const shape = resolveOptionalVocab(shapeInput, SPOTLIGHT_SHAPES, "tour shape");
const pulse = resolveOptionalVocab(pulseInput, SPOTLIGHT_PULSES, "tour pulse");
---

<xtyle-tour
	open={open || undefined}
	index={index}
	progress={progress}
	back-label={backLabel}
	next-label={nextLabel}
	done-label={doneLabel}
	skip-label={skipLabel}
	no-skip={noSkip || undefined}
	placement={placement}
	shape={shape}
	pulse={pulse}
	no-dismiss={noDismiss || undefined}
	class={extra}
	{...rest}
>
	<slot />
</xtyle-tour>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
