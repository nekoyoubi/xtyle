---
import { type AccordionSection } from "@xtyle/core/markup";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { checkAuthoring } from "./internal/diagnose.js";
import { SIZES, resolveVocab } from "@xtyle/core";

type Size = (typeof SIZES)[number];

interface Props {
	items?: AccordionSection[];
	multiple?: boolean;
	size?: Size;
	headingLevel?: 1 | 2 | 3 | 4 | 5 | 6;
	/** Render zero-JS: emit the declarative shadow but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	items,
	multiple = false,
	size: sizeInput,
	headingLevel,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;

await checkAuthoring("accordion", Astro.props);
const size = resolveVocab(sizeInput, SIZES, "md", "accordion size");

const sections = items ?? [];
const uid = `xtyle-accordion-${Math.random().toString(36).slice(2, 9)}`;

const openKeys: string[] = [];
sections.forEach((section, i) => {
	if (!section.open) return;
	const key = section.value ?? String(i);
	if (multiple) openKeys.push(key);
	else if (openKeys.length === 0) openKeys.push(key);
});

const bindings = {
	sections: sections.map((section, i) => ({
		header: section.header,
		panel: section.panel,
		panelSlot: section.panelSlot,
		value: section.value ?? String(i),
		disabled: section.disabled,
	})),
	openKeys,
	size,
	headingLevel,
	uid,
};
// Two authoring modes. items-mode renders the whole structure light from `bindings` and ships no
// children. The advanced slotted mode pairs the consumer's children by order, and those must reach
// the element still carrying their marker — hence `data-xtyle-header` / `data-xtyle-panel`, which
// no framework claims.
//
// `slot` cannot be that marker. On a child of an Astro *component* it is a routing directive Astro
// always consumes: with a matching `<slot name>` below the child renders there minus the attribute,
// and with no match the child is dropped entirely. (A `slot` a component writes on its own root
// element, as `Segment.astro` does, is ordinary HTML and survives — that is a different case, not a
// bug to fix.) The named receivers below stay so a legacy `slot=`-marked child is passed through
// rather than discarded.
const useItems = sections.length > 0;
const light = useItems ? await renderFragmentLight("accordion", bindings) : "";
---

{useItems ? (
	<xtyle-accordion
		multiple={multiple || undefined}
		size={size}
		heading-level={headingLevel}
		items={JSON.stringify(items)}
		class={extra}
		set:html={light}
		{...rest}
	/>
) : (
	<xtyle-accordion multiple={multiple || undefined} size={size} heading-level={headingLevel} class={extra} {...rest}>
		<slot name="header" />
		<slot name="panel" />
		<slot />
	</xtyle-accordion>
)}

{!isStatic && <script>import "@xtyle/core/elements";</script>}
