---
import { checkAuthoring } from "./internal/diagnose.js";
import { type MenuItem } from "@xtyle/core/markup";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";

interface Props {
	items?: MenuItem[];
	label?: string;
	open?: boolean;
	/** Cursor-anchored mode: no trigger is rendered; the menu opens at a point via `el.openAt(x, y)` (a `contextmenu` handler). */
	context?: boolean;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const { items = [], label, open = false, context = false, static: isStatic = false, class: extra, ...rest } = Astro.props;
await checkAuthoring("menu", Astro.props);

const popupId = `xtyle-menu-${Math.random().toString(36).slice(2, 9)}-popup`;

const bindings = {
	items,
	label: label ?? null,
	open,
	context,
	popupId,
};
const light = await renderFragmentLight("menu", bindings);
---

<xtyle-menu
	items={items && items.length > 0 ? JSON.stringify(items) : undefined}
	label={label}
	open={open || undefined}
	context={context || undefined}
	class={extra}
	{...rest}
	set:html={light}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
