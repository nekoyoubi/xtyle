---
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { avatarInitials } from "@xtyle/core";

import type { Tone, FullTone as BadgeTone } from "@xtyle/core";
type AvatarSize = "sm" | "md" | "lg" | "xl";
type AvatarShape = "circle" | "square";

interface Props {
	src?: string;
	alt?: string;
	/** The person the avatar stands for: supplies the fallback initials when there is no image and
	 * nothing slotted, and names the avatar when no `alt` is given. */
	userName?: string;
	tone?: BadgeTone;
	size?: AvatarSize;
	shape?: AvatarShape;
	status?: Tone;
	statusLabel?: string;
	/** Breathe the status dot for a live / online presence: a bare `true` pulses slow, `"fast"` quick. */
	pulse?: boolean | "slow" | "fast";
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	src,
	alt = "",
	userName,
	tone = "neutral",
	size = "md",
	shape = "circle",
	status,
	statusLabel,
	pulse,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;

const iconHtml = Astro.slots.has("icon") ? await Astro.slots.render("icon") : "";
const bodyHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";

const bindings = {
	src: src ?? null,
	alt,
	userName: userName ?? null,
	// Resolved here rather than left to the slot: the initials are real content, and this is the
	// layer that knows whether the consumer supplied any of their own.
	initials: bodyHtml.trim() ? "" : avatarInitials(userName),
	tone,
	size,
	shape,
	status: status ?? null,
	statusLabel: statusLabel ?? null,
	pulse: pulse ?? null,
};
const chrome = await renderFragmentLight("avatar", bindings);
const composed = chrome
	.replace('<slot name="icon"></slot>', () => iconHtml)
	.replace("<slot></slot>", () => bodyHtml);
---

<xtyle-avatar
	src={src ?? undefined}
	alt={alt}
	user-name={userName ?? undefined}
	tone={tone}
	size={size}
	shape={shape}
	status={status ?? undefined}
	status-label={statusLabel ?? undefined}
	pulse={pulse === true ? "" : pulse || undefined}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
