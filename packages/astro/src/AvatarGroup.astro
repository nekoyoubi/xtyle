---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { AVATAR_GROUP_SIZES, resolveOptionalVocab, AVATAR_GROUP_SPACINGS } from "@xtyle/core";

type AvatarGroupSize = (typeof AVATAR_GROUP_SIZES)[number];
type AvatarGroupSpacing = (typeof AVATAR_GROUP_SPACINGS)[number];

interface Props {
	size?: AvatarGroupSize;
	spacing?: AvatarGroupSpacing;
	/** How many avatars beyond the shown ones to summarize as a trailing `+N` chip. */
	overflow?: number;
	/** Accessible name for the group (a list of people). */
	label?: string;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const { size: sizeInput, spacing: spacingInput, overflow, label, static: isStatic = false, class: extra, ...rest } = Astro.props;
await checkAuthoring("avatar-group", Astro.props);
const size = resolveOptionalVocab(sizeInput, AVATAR_GROUP_SIZES, "avatar-group size");
const spacing = resolveOptionalVocab(spacingInput, AVATAR_GROUP_SPACINGS, "avatar-group spacing");

const bindings = {
	size: size ?? null,
	spacing: spacing ?? null,
	overflow: overflow ?? 0,
	label: label ?? null,
};
const chrome = await renderFragmentLight("avatar-group", bindings);
const slotHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const composed = chrome.replace("<slot></slot>", () => slotHtml);
---

<xtyle-avatar-group
	size={size}
	spacing={spacing}
	overflow={overflow ?? undefined}
	label={label}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
