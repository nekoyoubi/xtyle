---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { CAROUSEL_TRANSITIONS, resolveOptionalVocab, CAROUSEL_DIRECTIONS } from "@xtyle/core";

type CarouselTransition = (typeof CAROUSEL_TRANSITIONS)[number];
type CarouselDirection = (typeof CAROUSEL_DIRECTIONS)[number];

interface Props {
	label?: string;
	autoplay?: boolean;
	interval?: number;
	loop?: boolean;
	/** The prev/next arrows: `true` (a bar below), `false` (hidden), or `"overlay"` (on the slides). */
	controls?: boolean | "overlay";
	dots?: boolean;
	/** Whether hover/focus pauses autoplay (default true); set `false` for a decorative carousel that should keep cycling under the pointer. */
	pauseOnHover?: boolean;
	transition?: CarouselTransition;
	direction?: CarouselDirection;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it.
	 * The slides render in the fill's track as a plain scrollable strip; the arrows, dots, and autoplay
	 * are runtime enhancements and stay absent. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	label,
	autoplay = false,
	interval,
	loop = false,
	controls = true,
	dots = true,
	pauseOnHover = true,
	transition: transitionInput,
	direction: directionInput,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("carousel", Astro.props);
const transition = resolveOptionalVocab(transitionInput, CAROUSEL_TRANSITIONS, "carousel transition");
const direction = resolveOptionalVocab(directionInput, CAROUSEL_DIRECTIONS, "carousel direction");

// The slides ship inside the fill's track from the first byte. Server-rendering only the frame (no
// dots, no arrows: the slide count is not knowable from a rendered slot string, and the controls are
// a runtime enhancement anyway) means the element upgrades over a scaffold that already holds the
// consumer's nodes, instead of tearing them out of the page while the sandbox loads.
const slides = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const light = await renderFragmentLight("carousel", {
	slideCount: 0,
	index: 0,
	controls: controls === "overlay" ? "overlay" : controls ? "bar" : "none",
	dots,
	showPlay: false,
	playing: true,
	loop,
	label,
	direction: direction ?? "right",
});
const composed = light.replace("<slot></slot>", () => slides);
---

<xtyle-carousel
	label={label}
	interval={interval}
	autoplay={autoplay ? "" : undefined}
	loop={loop ? "" : undefined}
	controls={controls === "overlay" ? "overlay" : controls ? undefined : "false"}
	dots={dots ? undefined : "false"}
	pause-on-hover={pauseOnHover ? undefined : "false"}
	transition={transition && transition !== "slide" ? transition : undefined}
	direction={direction && direction !== "right" ? direction : undefined}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
