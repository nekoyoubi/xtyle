---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight, composeFallbackSlot } from "@xtyle/core/elements/ssr";
import { resolveOptionalTone, TOAST_SEVERITIES, resolveOptionalVocab, TOAST_VARIANTS, resolveVocab } from "@xtyle/core";
import type { FullTone } from "@xtyle/core";

type ToastSeverity = (typeof TOAST_SEVERITIES)[number];
type ToastVariant = (typeof TOAST_VARIANTS)[number];

interface Props {
	/** Color — any semantic role, accent variant, or named hue. Defaults to the severity color. */
	tone?: FullTone;
	/** Meaning — drives the glyph + politeness, independent of color. Omit for a color-only toast. */
	severity?: ToastSeverity;
	variant?: ToastVariant;
	closable?: boolean;
	closeLabel?: string;
	actionLabel?: string;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	tone: toneInput,
	severity: severityInput,
	variant: variantInput,
	closable = true,
	closeLabel,
	actionLabel,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("toast", Astro.props);
const severity = resolveOptionalVocab(severityInput, TOAST_SEVERITIES, "toast severity");
const variant = resolveVocab(variantInput, TOAST_VARIANTS, "soft", "toast variant");
const tone = resolveOptionalTone(toneInput);

const bindings = {
	tone,
	severity,
	variant,
	closable,
	closeLabel: closeLabel ?? "Dismiss",
	actionLabel: actionLabel ?? null,
};
const light = await renderFragmentLight("toast", bindings);
const iconHtml = Astro.slots.has("icon") ? await Astro.slots.render("icon") : null;
const messageHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const composed = composeFallbackSlot(light, "icon", iconHtml).replace("<slot></slot>", () => messageHtml);
---

<xtyle-toast
	tone={tone}
	severity={severity}
	variant={variant}
	closable={String(closable)}
	close-label={closeLabel}
	action-label={actionLabel}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
