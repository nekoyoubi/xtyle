---
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import {
	resolveHeatmapColors,
	resolveHeatmapGlows,
	resolveHeatmapScale,
	resolveHeatmapCategorical,
} from "./internal/palette.ts";
import { categoricalLegend, type HeatmapScheme, type Palette } from "@xtyle/core";

interface Props {
	values?: number[][];
	/** A second intensity matrix (same shape as `values`) driving each cell's glow halo. */
	glow?: number[][];
	rows?: string[];
	cols?: string[];
	scheme?: HeatmapScheme;
	reverse?: boolean;
	max?: number;
	/** The glow-channel ceiling a full-strength halo maps to; defaults to the glow data's own max. */
	glowMax?: number;
	/** The px blur a full-strength glow halo reaches; defaults to 7. Lower it on a dense grid, raise it on a sparse one. */
	glowBlur?: number;
	/** Names the glow metric so its value reaches each cell's accessible name and readout; defaults to "glow". */
	glowLabel?: string;
	/** Cells to ring as the current / "now" marker, each a `[rowIndex, colIndex]` pair. */
	current?: number[][];
	/** Tint for the current-cell ring: a semantic tone (`success` / `danger` / `warn` / `info` / `neutral`); defaults to accent. */
	currentTone?: "success" | "danger" | "warn" | "info" | "neutral";
	/** Pulse the current-cell ring (honors `prefers-reduced-motion`). */
	currentPulse?: boolean;
	/** Per-cell hover text (same shape as `values`); overrides a cell's default readout and accessible name. */
	titles?: string[][];
	/** Show a key below the grid: a ramp scale (intensity mode) or a category legend (categorical mode). */
	scale?: boolean;
	/** Color by category instead of intensity: each column (or row) takes a distinct series hue, and the
	 * cell value washes it from the surface up. `scheme` is read as a `Palette` and sampled, one color per category. */
	categorical?: boolean;
	/** Which axis carries the categories in `categorical` mode: `col` (default) or `row`. */
	categoryAxis?: "col" | "row";
	showValues?: boolean;
	/** Make cells actionable: each becomes a `role="button"` that fires `select` on click or Enter/Space. */
	selectable?: boolean;
	label?: string;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	values = [],
	glow = [],
	rows = [],
	cols = [],
	scheme,
	reverse = false,
	max,
	glowMax,
	glowBlur,
	glowLabel,
	current = [],
	currentTone,
	currentPulse = false,
	titles = [],
	scale = false,
	categorical = false,
	categoryAxis = "col",
	showValues = false,
	selectable = false,
	label,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;

const effectiveScheme = (scheme ?? (categorical ? "accents" : "intensity")) as HeatmapScheme;
const categoricalPalette = categorical
	? await resolveHeatmapCategorical(effectiveScheme as Palette | string[], values, categoryAxis, reverse, max)
	: null;
const cellColors = categoricalPalette
	? categoricalPalette.cellColors
	: await resolveHeatmapColors(effectiveScheme, values, reverse, max);
const cellGlows = await resolveHeatmapGlows(
	effectiveScheme,
	glow,
	reverse,
	glowMax,
	glowBlur,
	categoricalPalette?.hues,
	categoryAxis,
);
const resolvedGlowLabel = glow.length ? (glowLabel ?? "glow") : null;
const key = scale
	? categoricalPalette
		? { legend: categoricalLegend(categoricalPalette.hues, categoryAxis === "row" ? rows : cols) }
		: await resolveHeatmapScale(effectiveScheme, values, reverse, max)
	: {};
const bindings = {
	values,
	rows,
	cols,
	cellColors,
	cellGlows,
	glowValues: glow,
	glowLabel: resolvedGlowLabel,
	current,
	currentTone: currentTone ?? null,
	currentPulse,
	titles,
	scale,
	...key,
	showValues,
	selectable,
	title: label ?? null,
	ariaLabel: label ?? null,
};
const chrome = await renderFragmentLight("heatmap", bindings);
---

<xtyle-heatmap
	values={JSON.stringify(values)}
	glow={glow.length ? JSON.stringify(glow) : undefined}
	rows={JSON.stringify(rows)}
	cols={JSON.stringify(cols)}
	current={current.length ? JSON.stringify(current) : undefined}
	titles={titles.length ? JSON.stringify(titles) : undefined}
	scheme={Array.isArray(effectiveScheme) ? JSON.stringify(effectiveScheme) : effectiveScheme}
	categorical={categorical || undefined}
	category-axis={categorical && categoryAxis === "row" ? "row" : undefined}
	reverse={reverse || undefined}
	max={max ?? undefined}
	glow-max={glowMax ?? undefined}
	glow-blur={glowBlur ?? undefined}
	glow-label={glowLabel ?? undefined}
	current-tone={currentTone ?? undefined}
	current-pulse={currentPulse || undefined}
	scale={scale || undefined}
	show-values={showValues || undefined}
	selectable={selectable || undefined}
	label={label}
	class={extra}
	set:html={chrome}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
