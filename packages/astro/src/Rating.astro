---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import type { Palette } from "@xtyle/core";
import { bakeRatingGlyphs } from "./internal/palette.ts";

interface Props {
	value?: number;
	max?: number;
	size?: "sm" | "md" | "lg";
	/** The icon to rate with: `star` (default), any functional glyph, or a mark spec (`taco--…`). */
	icon?: string;
	/** Read-only display (fixed, fractional). Omit for an interactive slider (focusable, click / keys). */
	readonly?: boolean;
	/** Snap interactive input to half steps. */
	allowHalf?: boolean;
	/** The series scheme a colorful mark draws its palette from. */
	colors?: string;
	/** Fill tone for a monochrome icon: a register hue (`accent`, `success`, `red`, …). */
	tone?: string;
	/** Form field name; when set, the value posts through a hidden input. */
	name?: string;
	/** Accessible label. */
	label?: string;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it.
	 * The glyph row and its clipped fill are baked, so a static rating reads correctly; only the
	 * pointer and keyboard input are lost, which is what `readonly` already opts out of. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	value = 0,
	max = 5,
	size,
	icon = "star",
	readonly = false,
	allowHalf = false,
	colors,
	tone,
	name,
	label,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("rating", Astro.props);

const clamped = Math.min(Math.max(value, 0), max);
const { empty, filled } = await bakeRatingGlyphs(icon, (colors as Palette) ?? "accents");
const light = await renderFragmentLight("rating", {
	max,
	value: clamped,
	icon,
	emptyIcon: empty,
	filledIcon: filled,
	readonly,
	allowHalf,
	size: size ?? "md",
});

// The hidden input is plumbing the element appends on upgrade; a zero-JS form still has to post the
// value, so the server writes the same one rather than leaving a `name`d rating that submits nothing.
const mirror = name && !readonly ? `<input type="hidden" name="${name}" value="${clamped}">` : "";
const accessibleName = label ?? `${clamped} out of ${max} stars`;
---

<xtyle-rating
	value={clamped}
	max={max}
	size={size}
	icon={icon}
	colors={colors}
	tone={tone}
	name={name}
	readonly={readonly ? "" : undefined}
	allowhalf={allowHalf ? "" : undefined}
	label={label}
	role={readonly ? "img" : "slider"}
	tabindex={readonly ? undefined : 0}
	aria-label={accessibleName}
	aria-valuemin={readonly ? undefined : 0}
	aria-valuemax={readonly ? undefined : max}
	aria-valuenow={readonly ? undefined : clamped}
	aria-valuetext={readonly ? undefined : `${clamped} out of ${max}`}
	style={tone ? `--rating-fill: var(--${tone})` : undefined}
	class:list={["xtyle-rating", size === "sm" && "xtyle-rating--sm", size === "lg" && "xtyle-rating--lg", !readonly && "xtyle-rating--interactive", extra]}
	set:html={light + mirror}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
