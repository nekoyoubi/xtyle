---
import { POPOVER_PLACEMENTS, resolveOptionalVocab, SPOTLIGHT_SHAPES, SPOTLIGHT_PULSES, SPOTLIGHT_ARROWS } from "@xtyle/core";
type Placement = (typeof POPOVER_PLACEMENTS)[number];
type Shape = (typeof SPOTLIGHT_SHAPES)[number];
type Pulse = (typeof SPOTLIGHT_PULSES)[number];
type Arrow = (typeof SPOTLIGHT_ARROWS)[number];

interface Props {
	/** A CSS selector for the element this step isolates. */
	target?: string;
	heading?: string;
	placement?: Placement;
	shape?: Shape;
	padding?: number;
	radius?: number;
	pulse?: Pulse;
	arrow?: Arrow;
	dim?: number;
	blur?: number;
	scrollIntoView?: boolean;
	noDismiss?: boolean;
	class?: string;
	/** Any other attribute passes through to the element. */
	[key: string]: unknown;
}

const {
	target,
	heading,
	placement: placementInput,
	shape: shapeInput,
	padding,
	radius,
	pulse: pulseInput,
	arrow: arrowInput,
	dim,
	blur,
	scrollIntoView = false,
	noDismiss = false,
	class: extra,
	...rest
} = Astro.props;
const placement = resolveOptionalVocab(placementInput, POPOVER_PLACEMENTS, "tour-step placement");
const shape = resolveOptionalVocab(shapeInput, SPOTLIGHT_SHAPES, "tour-step shape");
const pulse = resolveOptionalVocab(pulseInput, SPOTLIGHT_PULSES, "tour-step pulse");
const arrow = resolveOptionalVocab(arrowInput, SPOTLIGHT_ARROWS, "tour-step arrow");
---

<xtyle-tour-step
	target={target}
	heading={heading}
	placement={placement}
	shape={shape}
	padding={padding}
	radius={radius}
	pulse={pulse}
	arrow={arrow}
	dim={dim}
	blur={blur}
	scroll-into-view={scrollIntoView || undefined}
	no-dismiss={noDismiss || undefined}
	class={extra}
	{...rest}
>
	<slot />
</xtyle-tour-step>
