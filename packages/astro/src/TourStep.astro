---
type Placement = "top" | "right" | "bottom" | "left";
type Shape = "auto" | "rect" | "circle";
type Pulse = "none" | "slow" | "fast";
type Arrow = "none" | "static" | "bounce";

interface Props {
	/** A CSS selector for the element this step isolates. */
	target?: string;
	heading?: string;
	placement?: Placement;
	shape?: Shape;
	padding?: number;
	radius?: number;
	pulse?: Pulse;
	arrow?: Arrow;
	dim?: number;
	blur?: number;
	scrollIntoView?: boolean;
	noDismiss?: boolean;
	class?: string;
	/** Any other attribute passes through to the element. */
	[key: string]: unknown;
}

const {
	target,
	heading,
	placement,
	shape,
	padding,
	radius,
	pulse,
	arrow,
	dim,
	blur,
	scrollIntoView = false,
	noDismiss = false,
	class: extra,
	...rest
} = Astro.props;
---

<xtyle-tour-step
	target={target}
	heading={heading}
	placement={placement}
	shape={shape}
	padding={padding}
	radius={radius}
	pulse={pulse}
	arrow={arrow}
	dim={dim}
	blur={blur}
	scroll-into-view={scrollIntoView || undefined}
	no-dismiss={noDismiss || undefined}
	class={extra}
	{...rest}
>
	<slot />
</xtyle-tour-step>
