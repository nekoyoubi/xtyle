---
import { checkAuthoring } from "./internal/diagnose.js";
import { resolveTone, BUTTON_SIZES, SPLIT_BUTTON_VARIANTS, resolveVocab } from "@xtyle/core";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import type { MenuItem } from "@xtyle/core";

type Variant = (typeof SPLIT_BUTTON_VARIANTS)[number];
type Size = (typeof BUTTON_SIZES)[number];

interface Props {
	/** The dropdown's rows: the same `MenuItem` contract Menu speaks — actions, separators, headings. */
	items?: MenuItem[];
	variant?: Variant;
	tone?: string;
	size?: Size;
	open?: boolean;
	disabled?: boolean;
	/** Puts the primary in flight: a spinner replaces its label and the press is blocked. The caret stays live. */
	loading?: boolean;
	/** Accessible name for the caret half. Name it for what the menu holds. */
	menuLabel?: string;
	block?: boolean;
	/** The primary's native button type — `submit` makes the default action submit the surrounding form. */
	type?: string;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	items = [],
	variant: variantInput,
	tone: toneInput,
	size: sizeInput,
	open = false,
	disabled = false,
	loading = false,
	menuLabel,
	block = false,
	type = "button",
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("split-button", Astro.props);
const variant = resolveVocab(variantInput, SPLIT_BUTTON_VARIANTS, "solid", "split-button variant");
const size = resolveVocab(sizeInput, BUTTON_SIZES, "md", "split-button size");
const tone = resolveTone(toneInput, "accent");

const bindings = {
	variant,
	tone,
	size,
	type,
	disabled,
	loading,
	block,
	open,
	menuLabel: menuLabel ?? null,
	itemsJson: JSON.stringify(items),
};
const light = await renderFragmentLight("split-button", bindings);
const labelHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const composed = light.replace("<slot></slot>", () => labelHtml);
---

<xtyle-split-button
	variant={variant}
	tone={tone}
	size={size}
	type={type}
	items={JSON.stringify(items)}
	open={open || undefined}
	disabled={disabled || undefined}
	loading={loading || undefined}
	block={block || undefined}
	menu-label={menuLabel}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
