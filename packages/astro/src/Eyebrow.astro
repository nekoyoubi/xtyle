---
import { checkAuthoring } from "./internal/diagnose.js";
import { resolveTone, EYEBROW_EMPHASIS, EYEBROW_TAGS, resolveVocab, EYEBROW_TRACKINGS } from "@xtyle/core";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import type { EyebrowTone } from "@xtyle/core";

type EyebrowTag = (typeof EYEBROW_TAGS)[number];
type EyebrowTracking = (typeof EYEBROW_TRACKINGS)[number];

interface Props {
	as?: EyebrowTag;
	tone?: EyebrowTone;
	tracking?: EyebrowTracking;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const { as: asInput, tone: toneInput, tracking: trackingInput, static: isStatic = false, class: extra, ...rest } =
	Astro.props;
await checkAuthoring("eyebrow", Astro.props);
const as = resolveVocab(asInput, EYEBROW_TAGS, "p", "eyebrow as");
const tracking = resolveVocab(trackingInput, EYEBROW_TRACKINGS, "normal", "eyebrow tracking");
const tone = resolveTone(toneInput, "accent", EYEBROW_EMPHASIS);

const bindings = { as, tone, tracking };
const chrome = await renderFragmentLight("eyebrow", bindings);
const slotHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const composed = chrome.replace("<slot></slot>", () => slotHtml);
---

<xtyle-eyebrow as={as} tone={tone} tracking={tracking} class={extra} set:html={composed} {...rest} />

{!isStatic && <script>import "@xtyle/core/elements";</script>}
