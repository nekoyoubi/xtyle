---
import { checkAuthoring } from "./internal/diagnose.js";
import { resolveTone, SIZES, resolveVocab } from "@xtyle/core";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";

import type { FullTone as Tone } from "@xtyle/core";
type Size = (typeof SIZES)[number];

interface Props {
	tone?: Tone;
	size?: Size;
	name?: string;
	value?: string;
	checked?: boolean;
	disabled?: boolean;
	invalid?: boolean;
	label?: string;
	labelledby?: string;
	/** A secondary line of explanation under the label (wired to the input's `aria-describedby`). */
	description?: string;
	/** Render the radio as a full-width option card: a bordered box that takes an accent ring and tint when selected. */
	card?: boolean;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	tone: toneInput,
	size: sizeInput,
	name,
	value,
	checked = false,
	disabled = false,
	invalid = false,
	label,
	labelledby,
	description,
	card = false,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("radio", Astro.props);
const size = resolveVocab(sizeInput, SIZES, "md", "radio size");
const tone = resolveTone(toneInput, "accent");

const descriptionId = `xtyle-radio-desc-${Math.random().toString(36).slice(2, 8)}`;
const bindings = {
	tone,
	size,
	name: name ?? null,
	value,
	checked,
	disabled,
	invalid,
	label: label ?? null,
	labelledby: labelledby ?? null,
	description: description ?? null,
	card,
	descriptionId,
};
const light = await renderFragmentLight("radio", bindings);
const slotHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : null;
// the label slot carries the `label` text as its fallback; a consumer's slotted label replaces it
const composed = slotHtml !== null ? light.replace(/<slot>[\s\S]*?<\/slot>/, () => slotHtml) : light.replace(/<slot>([\s\S]*?)<\/slot>/, "$1");
---

<xtyle-radio
	tone={tone}
	size={size}
	name={name}
	value={value}
	checked={checked || undefined}
	disabled={disabled || undefined}
	invalid={invalid || undefined}
	label={label}
	labelledby={labelledby}
	description={description}
	card={card || undefined}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
