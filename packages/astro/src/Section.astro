---
import { checkAuthoring } from "./internal/diagnose.js";
import { resolveTone, SECTION_SURFACES, SECTION_TAGS, resolveVocab, SECTION_VARIANTS, SECTION_PADDINGS } from "@xtyle/core";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import type { FullTone } from "@xtyle/core";

type SectionTag = (typeof SECTION_TAGS)[number];
type SectionVariant = (typeof SECTION_VARIANTS)[number];
type SectionTone = "plain" | "quiet" | FullTone;
type SectionPadding = (typeof SECTION_PADDINGS)[number];

interface Props {
	as?: SectionTag;
	variant?: SectionVariant;
	tone?: SectionTone;
	bordered?: boolean;
	padding?: SectionPadding;
	label?: string;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	as: asInput,
	variant: variantInput,
	tone: toneInput,
	bordered = false,
	padding: paddingInput,
	label,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("section", Astro.props);
const as = resolveVocab(asInput, SECTION_TAGS, "section", "section as");
const variant = resolveVocab(variantInput, SECTION_VARIANTS, "band", "section variant");
const padding = resolveVocab(paddingInput, SECTION_PADDINGS, "lg", "section padding");
const tone = resolveTone(toneInput, "plain", SECTION_SURFACES);

const bindings = {
	as,
	variant,
	tone,
	bordered,
	padding,
	label: label ?? null,
};
const chrome = await renderFragmentLight("section", bindings);
const slotHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const composed = chrome.replace("<slot></slot>", () => slotHtml);
---

<xtyle-section
	as={as}
	variant={variant}
	tone={tone}
	bordered={bordered || undefined}
	padding={padding}
	label={label ?? undefined}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
