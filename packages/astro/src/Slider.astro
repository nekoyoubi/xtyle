---
import { checkAuthoring } from "./internal/diagnose.js";
import { resolveTone, SIZES, resolveVocab } from "@xtyle/core";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";

import type { FullTone as Tone } from "@xtyle/core";
type Size = (typeof SIZES)[number];

interface Props {
	value?: number;
	min?: number;
	max?: number;
	step?: number;
	/** The step taken while the modifier is held (a coarser or finer jump); defaults to `step * 10`. */
	altStep?: number;
	/** Invert the modifier so the alt step is the unmodified default and `step` needs the modifier. */
	altDefault?: boolean;
	/** Which key toggles between `step` and `altStep` for keyboard and drag. */
	modifier?: "shift" | "alt" | "ctrl" | "meta";
	/** Let a typed value exceed `min`/`max`: the thumb pins at the edge while the true value is kept. */
	overflow?: boolean;
	disabled?: boolean;
	size?: Size;
	tone?: Tone;
	label?: string;
	labelledby?: string;
	name?: string;
	showValue?: boolean;
	hideLabel?: boolean;
	/** Reset value for a double-click on the thumb. Defaults to the initial `value`. */
	default?: number;
	/** Disable click-to-edit on the shown value (it is on by default when `showValue` is set). */
	staticValue?: boolean;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	value = 0,
	min = 0,
	max = 100,
	step = 1,
	altStep,
	altDefault = false,
	modifier = "shift",
	overflow = false,
	disabled = false,
	size: sizeInput,
	tone: toneInput,
	label,
	labelledby,
	name,
	showValue = false,
	hideLabel = false,
	default: defaultValue,
	staticValue = false,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("slider", Astro.props);
const size = resolveVocab(sizeInput, SIZES, "md", "slider size");
const tone = resolveTone(toneInput, "accent");

const elementId = `xtyle-slider-${Math.random().toString(36).slice(2, 8)}`;
const editableValue = showValue && !staticValue;

const bindings = {
	value,
	min,
	max,
	step,
	altStep: altStep ?? step * 10,
	disabled,
	size,
	tone,
	label: label ?? null,
	labelledby: labelledby ?? null,
	showValue,
	hideLabel,
	valueText: String(value),
	elementId,
	editableValue,
};
const light = await renderFragmentLight("slider", bindings);
---

<xtyle-slider
	value={value}
	min={min}
	max={max}
	step={step}
	alt-step={altStep ?? undefined}
	alt-default={altDefault || undefined}
	modifier={modifier}
	overflow={overflow || undefined}
	disabled={disabled || undefined}
	size={size}
	tone={tone}
	label={label}
	labelledby={labelledby}
	name={name}
	show-value={showValue || undefined}
	hide-label={hideLabel || undefined}
	default={defaultValue}
	static-value={staticValue || undefined}
	class={extra}
	{...rest}
	set:html={light}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
