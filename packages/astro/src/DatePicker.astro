---
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import {
	datePlaceholder,
	effectiveTimeBounds,
	formatDateDisplay,
	toIso,
	formatIsoTime,
	formatTimeDisplay,
	parseIsoValue,
	resolveHour12,
	stepShowsSeconds,
	timeListOptions,
	type DatePickerMode,
	type HourCyclePosture,
} from "@xtyle/core/markup";

type Size = "sm" | "md" | "lg";

interface Props {
	/** The canonical wall-clock value: `YYYY-MM-DD`, `HH:mm[:ss]`, or `YYYY-MM-DDTHH:mm[:ss]`. No timezone, no offset. */
	value?: string;
	mode?: DatePickerMode;
	min?: string;
	max?: string;
	/** Time granularity in **seconds** (the native `<input type="time">` contract). Defaults to `60`. */
	step?: number;
	/** Granularity of the popup's time list. Defaults to `step`, floored at a quarter hour. */
	listStep?: number;
	locale?: string;
	/** An IANA zone that pins what "today" means. It shifts no value; the value is wall-clock. */
	timezone?: string;
	hourCycle?: HourCyclePosture;
	/** Weekdays that can never be picked, `0` = Sunday (`[0, 6]` → weekends). */
	disabledWeekdays?: string | number[];
	/** The week's first day in the grid, `0` = Sunday. Defaults to the locale's. */
	firstDayOfWeek?: number;
	disabled?: boolean;
	readonly?: boolean;
	required?: boolean;
	invalid?: boolean;
	/** Drop the clear button, otherwise shown whenever the field holds a value and is editable. */
	noClear?: boolean;
	size?: Size;
	name?: string;
	label?: string;
	labelledby?: string;
	dateLabel?: string;
	timeLabel?: string;
	clearLabel?: string;
	openLabel?: string;
	panelLabel?: string;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	value = "",
	mode = "date",
	min,
	max,
	step = 60,
	listStep,
	locale,
	timezone,
	hourCycle = "auto",
	disabledWeekdays,
	firstDayOfWeek,
	disabled = false,
	readonly = false,
	required = false,
	invalid = false,
	noClear = false,
	size = "md",
	name,
	label,
	labelledby,
	dateLabel = "Date",
	timeLabel = "Time",
	clearLabel = "Clear",
	openLabel,
	panelLabel,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;

const uid = `xtyle-datepicker-${Math.random().toString(36).slice(2, 8)}`;
const parsed = parseIsoValue(value, mode);
const draft = parsed ?? { date: null, time: null };
const minValue = parseIsoValue(min, mode);
const maxValue = parseIsoValue(max, mode);
const hour12 = resolveHour12(hourCycle, locale);
const showSeconds = stepShowsSeconds(step);
const weekdays = Array.isArray(disabledWeekdays) ? disabledWeekdays.join(",") : disabledWeekdays;

const bounds = effectiveTimeBounds(draft.date, mode, minValue, maxValue);
const selectedTime = draft.time ? formatIsoTime(draft.time, showSeconds) : null;
const timeOptions =
	mode === "date"
		? []
		: timeListOptions({ stepSeconds: step, listStep, min: bounds.min, max: bounds.max }).map((time) => {
				const iso = formatIsoTime(time, showSeconds);
				return {
					iso,
					label: formatTimeDisplay(time, { locale, hour12, withSeconds: showSeconds }),
					selected: iso === selectedTime,
					disabled: false,
				};
			});

const defaultPanelLabel =
	mode === "time" ? "Choose a time" : mode === "datetime" ? "Choose a date and time" : "Choose a date";

const bindings = {
	mode,
	size,
	disabled,
	readonly,
	required,
	invalid,
	open: false,
	label: label ?? null,
	labelledby: labelledby ?? null,
	ariaLabel: (rest["aria-label"] as string | undefined) ?? null,
	dateLabel,
	timeLabel,
	clearLabel,
	openLabel: openLabel ?? (mode === "time" ? "Open time list" : "Open calendar"),
	panelLabel: panelLabel ?? defaultPanelLabel,
	timeListLabel: timeLabel,
	dateText: draft.date ? formatDateDisplay(draft.date, locale) : "",
	timeText: draft.time ? formatTimeDisplay(draft.time, { locale, hour12, withSeconds: showSeconds }) : "",
	datePlaceholder: datePlaceholder(locale),
	timePlaceholder: hour12 ? `${showSeconds ? "HH:MM:SS" : "HH:MM"} AM` : showSeconds ? "HH:MM:SS" : "HH:MM",
	hasValue: !!draft.date || !!draft.time,
	clearable: !noClear,
	uid,
	panelId: `${uid}-panel`,
	labelId: `${uid}-label`,
	calendar:
		mode === "time"
			? null
			: {
					value: draft.date ? toIso(draft.date) : "",
					min: minValue?.date ? toIso(minValue.date) : "",
					max: maxValue?.date ? toIso(maxValue.date) : "",
					locale: locale ?? "",
					timezone: timezone ?? "",
					size,
					label: dateLabel,
					firstDayOfWeek: firstDayOfWeek != null ? String(firstDayOfWeek) : "",
				},
	timeOptions,
};

const light = await renderFragmentLight("date-picker", bindings);
---

<xtyle-date-picker
	value={value || undefined}
	mode={mode}
	min={min}
	max={max}
	step={String(step)}
	list-step={listStep != null ? String(listStep) : undefined}
	locale={locale}
	timezone={timezone}
	hour-cycle={hourCycle}
	disabled-weekdays={weekdays}
	first-day-of-week={firstDayOfWeek != null ? String(firstDayOfWeek) : undefined}
	disabled={disabled || undefined}
	readonly={readonly || undefined}
	required={required || undefined}
	invalid={invalid || undefined}
	no-clear={noClear || undefined}
	size={size}
	name={name}
	label={label}
	labelledby={labelledby}
	date-label={dateLabel}
	time-label={timeLabel}
	clear-label={clearLabel}
	open-label={openLabel}
	panel-label={panelLabel}
	class={extra}
	{...rest}
	set:html={light}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
