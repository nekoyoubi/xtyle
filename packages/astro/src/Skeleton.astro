---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { SKELETON_SHAPES, resolveVocab, SIZES } from "@xtyle/core";

type SkeletonShape = (typeof SKELETON_SHAPES)[number];
type Size = (typeof SIZES)[number];

interface Props {
	shape?: SkeletonShape;
	size?: Size;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const { shape: shapeInput, size: sizeInput, static: isStatic = false, class: extra, ...rest } = Astro.props;
await checkAuthoring("skeleton", Astro.props);
const shape = resolveVocab(shapeInput, SKELETON_SHAPES, "text", "skeleton shape");
const size = resolveVocab(sizeInput, SIZES, "md", "skeleton size");

const bindings = { shape, size };
const composed = await renderFragmentLight("skeleton", bindings);
---

<xtyle-skeleton shape={shape} size={size} class={extra} set:html={composed} {...rest} />

{!isStatic && <script>import "@xtyle/core/elements";</script>}
