---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { CLUSTER_ALIGNS, resolveOptionalVocab, CLUSTER_JUSTIFIES } from "@xtyle/core";

type ClusterAlign = (typeof CLUSTER_ALIGNS)[number];
type ClusterJustify = (typeof CLUSTER_JUSTIFIES)[number];

interface Props {
	gap?: number;
	align?: ClusterAlign;
	justify?: ClusterJustify;
	nowrap?: boolean;
	inline?: boolean;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const { gap = 2, align: alignInput, justify: justifyInput, nowrap = false, inline = false, static: isStatic = false, class: extra, ...rest } =
	Astro.props;
await checkAuthoring("cluster", Astro.props);
const align = resolveOptionalVocab(alignInput, CLUSTER_ALIGNS, "cluster align");
const justify = resolveOptionalVocab(justifyInput, CLUSTER_JUSTIFIES, "cluster justify");

const bindings = {
	gap,
	align: align ?? null,
	justify: justify ?? null,
	nowrap,
	inline,
};
const chrome = await renderFragmentLight("cluster", bindings);
const slotHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const composed = chrome.replace("<slot></slot>", () => slotHtml);
---

<xtyle-cluster
	gap={gap}
	align={align}
	justify={justify}
	nowrap={nowrap || undefined}
	inline={inline || undefined}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
