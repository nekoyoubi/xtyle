---
import { checkAuthoring } from "./internal/diagnose.js";
import { resolveTone, RIBBON_CORNERS, resolveVocab, RIBBON_SIZES, RIBBON_VARIANTS } from "@xtyle/core";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";

import type { FullTone as Tone } from "@xtyle/core";
type RibbonCorner = (typeof RIBBON_CORNERS)[number];
type RibbonSize = (typeof RIBBON_SIZES)[number];
type RibbonVariant = (typeof RIBBON_VARIANTS)[number];

interface Props {
	tone?: Tone;
	corner?: RibbonCorner;
	size?: RibbonSize;
	variant?: RibbonVariant;
	color?: string;
	textColor?: string;
	label?: string;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	tone: toneInput,
	corner: cornerInput,
	size: sizeInput,
	variant: variantInput,
	color,
	textColor,
	label,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("ribbon", Astro.props);
const corner = resolveVocab(cornerInput, RIBBON_CORNERS, "top-right", "ribbon corner");
const size = resolveVocab(sizeInput, RIBBON_SIZES, "md", "ribbon size");
const variant = resolveVocab(variantInput, RIBBON_VARIANTS, "solid", "ribbon variant");
const tone = resolveTone(toneInput, "accent");

const bindings = {
	tone,
	corner,
	size,
	variant,
	color: color ?? null,
	textColor: textColor ?? null,
	label: label ?? null,
};
const composed = await renderFragmentLight("ribbon", bindings);
---

<xtyle-ribbon
	tone={tone}
	corner={corner}
	size={size}
	variant={variant}
	color={color || undefined}
	text-color={textColor || undefined}
	label={label || undefined}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
