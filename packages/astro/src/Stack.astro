---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { STACK_ALIGNS, resolveOptionalVocab, STACK_JUSTIFIES } from "@xtyle/core";

type StackAlign = (typeof STACK_ALIGNS)[number];
type StackJustify = (typeof STACK_JUSTIFIES)[number];

interface Props {
	gap?: number;
	align?: StackAlign;
	justify?: StackJustify;
	inline?: boolean;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const { gap = 4, align: alignInput, justify: justifyInput, inline = false, static: isStatic = false, class: extra, ...rest } = Astro.props;
await checkAuthoring("stack", Astro.props);
const align = resolveOptionalVocab(alignInput, STACK_ALIGNS, "stack align");
const justify = resolveOptionalVocab(justifyInput, STACK_JUSTIFIES, "stack justify");

const bindings = {
	gap,
	align: align ?? null,
	justify: justify ?? null,
	inline,
};
const chrome = await renderFragmentLight("stack", bindings);
const slotHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const composed = chrome.replace("<slot></slot>", () => slotHtml);
---

<xtyle-stack
	gap={gap}
	align={align}
	justify={justify}
	inline={inline || undefined}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
