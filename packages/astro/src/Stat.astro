---
import { checkAuthoring } from "./internal/diagnose.js";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";
import { STAT_TRENDS, resolveVocab, STAT_SENTIMENTS, resolveOptionalVocab, STAT_ALIGNS, SIZES } from "@xtyle/core";

type StatTrend = (typeof STAT_TRENDS)[number];
type StatSentiment = (typeof STAT_SENTIMENTS)[number];
type StatAlign = (typeof STAT_ALIGNS)[number];
type Size = (typeof SIZES)[number];

interface Props {
	label?: string;
	delta?: string;
	trend?: StatTrend;
	/** The delta's color reading. Omit to derive it from `trend` (up→positive, down→negative, flat→neutral). */
	sentiment?: StatSentiment;
	caption?: string;
	size?: Size;
	align?: StatAlign;
	/** Lay the stat out horizontally: value, label, and trend delta on one line, like a ticker. */
	inline?: boolean;
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const {
	label,
	delta,
	trend: trendInput,
	sentiment: sentimentInput,
	caption,
	size: sizeInput,
	align: alignInput,
	inline = false,
	static: isStatic = false,
	class: extra,
	...rest
} = Astro.props;
await checkAuthoring("stat", Astro.props);
const trend = resolveVocab(trendInput, STAT_TRENDS, "flat", "stat trend");
const sentiment = resolveOptionalVocab(sentimentInput, STAT_SENTIMENTS, "stat sentiment");
const align = resolveVocab(alignInput, STAT_ALIGNS, "start", "stat align");
const size = resolveVocab(sizeInput, SIZES, "md", "stat size");

const bindings = {
	label: label ?? null,
	delta: delta ?? null,
	trend,
	sentiment,
	caption: caption ?? null,
	size,
	align,
	inline,
};
const chrome = await renderFragmentLight("stat", bindings);
const slotHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const composed = chrome.replace("<slot></slot>", () => slotHtml);
---

<xtyle-stat
	label={label}
	delta={delta}
	trend={trend}
	sentiment={sentiment}
	caption={caption}
	size={size}
	align={align}
	inline={inline || undefined}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
