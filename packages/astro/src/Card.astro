---
import { checkAuthoring } from "./internal/diagnose.js";
import { resolveOptionalTone } from "@xtyle/core";
import { renderFragmentLight } from "@xtyle/core/elements/ssr";

import type { FullTone as Tone } from "@xtyle/core";

interface Props {
	overlay?: boolean;
	interactive?: boolean;
	action?: boolean;
	compact?: boolean;
	tone?: Tone;
	/** How far the surface lifts: `sm` a whisper, `md` the eased default, `lg` a pronounced shadow. */
	depthStrength?: "sm" | "md" | "lg";
	/** Render zero-JS: emit the resolved light-DOM markup but never load the runtime to hydrate it. */
	static?: boolean;
	class?: string;
	/** Any other attribute (`id`, `title`, `data-*`, `aria-*`, …) passes through to the element. */
	[key: string]: unknown;
}

const { overlay = false, interactive = false, action = false, compact = false, tone: toneInput, depthStrength, static: isStatic = false, class: extra, ...rest } =
	Astro.props;
await checkAuthoring("card", Astro.props);
const tone = resolveOptionalTone(toneInput);

// The fill hides an unfilled header/footer, and it can only know from a binding: the composed markup
// keeps its `<slot>`, so no selector can tell a filled region from an empty one.
const bindings = {
	overlay,
	interactive,
	action,
	compact,
	tone: tone ?? null,
	depthStrength: depthStrength ?? null,
	hasHeader: Astro.slots.has("header"),
	hasFooter: Astro.slots.has("footer"),
};
const chrome = await renderFragmentLight("card", bindings);
const headerHtml = Astro.slots.has("header") ? await Astro.slots.render("header") : "";
const bodyHtml = Astro.slots.has("default") ? await Astro.slots.render("default") : "";
const footerHtml = Astro.slots.has("footer") ? await Astro.slots.render("footer") : "";
const composed = chrome
	.replace('<slot name="header"></slot>', () => headerHtml)
	.replace('<slot name="footer"></slot>', () => footerHtml)
	.replace("<slot></slot>", () => bodyHtml);
---

<xtyle-card
	overlay={overlay || undefined}
	interactive={interactive || undefined}
	action={action || undefined}
	compact={compact || undefined}
	tone={tone}
	depth-strength={depthStrength}
	class={extra}
	set:html={composed}
	{...rest}
/>

{!isStatic && <script>import "@xtyle/core/elements";</script>}
