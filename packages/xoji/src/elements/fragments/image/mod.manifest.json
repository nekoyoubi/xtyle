{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-image-default",
	"version": "0.0.1",
	"title": "Xoji Image (default)",
	"description": "The built-in fill for the xoji Image component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xoji.component.image"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.image": [
			{
				"id": "image",
				"format": "text/html+jsml",
				"source": "image.html",
				"meta": {
					"tokens": [
						"--bg-2",
						"--bg-3",
						"--fg-2",
						"--radius-sm",
						"--radius-md",
						"--radius-lg",
						"--duration-slow",
						"--ease-standard",
						"--text-sm",
						"--leading-normal",
						"--space-2"
					]
				}
			}
		]
	}
}
