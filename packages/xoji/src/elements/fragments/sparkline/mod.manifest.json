{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-sparkline-default",
	"version": "0.0.1",
	"title": "Xoji Sparkline (default)",
	"description": "The built-in fill for the xoji Sparkline: the mod-zero inline SVG markup every app inherits and may override.",
	"capabilities": ["xoji.component.sparkline"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.sparkline": [
			{
				"id": "sparkline",
				"format": "text/html+jsml",
				"source": "sparkline.html",
				"meta": {
					"tokens": [
						"--accent",
						"--bg-0",
						"--line-2",
						"--font-sans",
						"--text-xs",
						"--leading-normal",
						"--fg-0",
						"--fg-2",
						"--space-1",
						"--space-2",
						"--radius-md",
						"--surface-overlay",
						"--surface-overlay-border",
						"--elevation-3",
						"--border-thin"
					]
				}
			}
		]
	}
}
