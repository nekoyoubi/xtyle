{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xoji-breadcrumb-default",
	"version": "0.0.1",
	"title": "Xoji Breadcrumb (default)",
	"description": "The built-in fill for the xoji Breadcrumb component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xoji.component.breadcrumb"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.breadcrumb": [
			{
				"id": "breadcrumb",
				"format": "text/html+jsml",
				"source": "breadcrumb.html",
				"handlers": [{ "selector": "[data-value]", "on": "click", "handler": "selectCrumb" }],
				"meta": {
					"tokens": [
						"--accent-text",
						"--border-normal",
						"--border-thick",
						"--duration-fast",
						"--ease-standard",
						"--fg-0",
						"--fg-2",
						"--fg-3",
						"--font-sans",
						"--leading-normal",
						"--radius-sm",
						"--ring",
						"--space-0",
						"--space-1",
						"--text-body",
						"--text-sm",
						"--text-xs",
						"--weight-medium"
					]
				}
			}
		]
	}
}
