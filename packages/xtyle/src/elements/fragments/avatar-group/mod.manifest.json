{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-avatar-group-default",
	"version": "0.0.1",
	"title": "Xtyle Avatar Group (default)",
	"description": "The built-in fill for the xtyle Avatar Group component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xtyle.component.avatar-group"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.avatar-group": [
			{
				"id": "avatar-group",
				"format": "text/html+jsml",
				"source": "avatar-group.html",
				"meta": {
					"tokens": [
						"--bg-0",
						"--neutral-bg",
						"--neutral-text",
						"--border-thick",
						"--radius-full",
						"--space-2",
						"--space-3",
						"--space-4",
						"--space-6",
						"--space-7",
						"--space-8",
						"--font-sans",
						"--text-xs",
						"--text-sm",
						"--text-body",
						"--text-lg",
						"--weight-semibold",
						"--leading-tight"
					]
				}
			}
		]
	}
}
