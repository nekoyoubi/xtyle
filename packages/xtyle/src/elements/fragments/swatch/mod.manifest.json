{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-swatch-default",
	"version": "0.0.1",
	"title": "Xtyle Swatch (default)",
	"description": "The built-in fill for the xtyle Swatch component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xtyle.component.swatch"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.swatch": [
			{
				"id": "swatch",
				"format": "text/html+jsml",
				"source": "swatch.html",
				"handlers": [{ "selector": ".xtyle-swatch--interactive", "on": "click", "handler": "select" }],
				"meta": {
					"tokens": [
						"--border-thin",
						"--line-2",
						"--radius-sm",
						"--radius-md",
						"--fg-1",
						"--fg-2",
						"--text-sm",
						"--text-xs",
						"--text-lg",
						"--leading-tight",
						"--font-mono",
						"--font-sans",
						"--border-normal",
						"--border-thick",
						"--ring",
						"--bg-1",
						"--accent",
						"--space-1",
						"--space-2",
						"--space-8",
						"--surface-overlay",
						"--surface-overlay-border",
						"--elevation-2",
						"--duration-fast",
						"--ease-standard"
					]
				}
			}
		]
	}
}
