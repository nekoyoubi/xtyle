{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-textarea-default",
	"version": "0.0.1",
	"title": "Xtyle Textarea (default)",
	"description": "The built-in fill for the xtyle Textarea component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xtyle.component.textarea"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.textarea": [
			{
				"id": "textarea",
				"format": "text/html+jsml",
				"source": "textarea.html",
				"handlers": [
					{ "selector": ".xtyle-textarea__control", "on": "input", "handler": "onInput" },
					{ "selector": ".xtyle-textarea__control", "on": "change", "handler": "onChange" }
				],
				"meta": {
					"tokens": [
						"--accent",
						"--border-normal",
						"--border-thin",
						"--danger",
						"--danger-bg",
						"--duration-fast",
						"--ease-standard",
						"--field-bg",
						"--field-border",
						"--fg-0",
						"--fg-1",
						"--fg-disabled",
						"--font-sans",
						"--leading-normal",
						"--placeholder",
						"--radius-md",
						"--ring",
						"--space-1",
						"--space-2",
						"--space-3",
						"--space-4",
						"--space-6",
						"--space-7",
						"--space-8",
						"--state-disabled",
						"--text-body",
						"--text-lg",
						"--text-sm",
						"--weight-medium"
					]
				}
			}
		]
	}
}
