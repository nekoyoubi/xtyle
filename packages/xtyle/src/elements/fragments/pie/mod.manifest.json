{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-pie-default",
	"version": "0.0.1",
	"title": "Xtyle Pie (default)",
	"description": "The built-in fill for the xtyle Pie chart: the mod-zero SVG markup every app inherits and may override.",
	"capabilities": ["xtyle.component.pie"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.pie": [
			{
				"id": "pie",
				"format": "text/html+jsml",
				"source": "pie.html",
				"meta": {
					"tokens": [
						"--font-sans",
						"--bg-0",
						"--bg-1",
						"--fg-0",
						"--fg-1",
						"--fg-2",
						"--text-xs",
						"--text-sm",
						"--text-lg",
						"--weight-semibold",
						"--weight-bold",
						"--duration-fast",
						"--ease-standard",
						"--ring",
						"--border-thick",
						"--border-thin",
						"--leading-normal",
						"--space-1",
						"--space-2",
						"--space-3",
						"--radius-sm",
						"--radius-md",
						"--surface-overlay",
						"--surface-overlay-border",
						"--elevation-3"
					]
				}
			}
		]
	}
}
