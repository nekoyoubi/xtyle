{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-dialog-default",
	"version": "0.0.1",
	"title": "Xtyle Dialog (default)",
	"description": "The built-in fill for the xtyle Dialog component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xtyle.component.dialog"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.dialog": [
			{
				"id": "dialog",
				"format": "text/html+jsml",
				"source": "dialog.html",
				"handlers": [{ "selector": ".xtyle-dialog__close", "on": "click", "handler": "requestClose" }],
				"meta": {
					"tokens": [
						"--fg-0",
						"--fg-1",
						"--fg-2",
						"--font-sans",
						"--text-body",
						"--text-lg",
						"--leading-normal",
						"--leading-tight",
						"--weight-semibold",
						"--surface-overlay",
						"--surface-overlay-border",
						"--scrim",
						"--line",
						"--border-thin",
						"--border-normal",
						"--border-thick",
						"--radius-lg",
						"--radius-sm",
						"--elevation-5",
						"--ring",
						"--state-hover",
						"--state-press",
						"--duration-fast",
						"--ease-standard",
						"--space-2",
						"--space-3",
						"--space-4",
						"--space-5",
						"--space-6"
					]
				}
			}
		]
	}
}
