{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-steps-default",
	"version": "0.0.1",
	"title": "Xtyle Steps (default)",
	"description": "The built-in fill for the xtyle Steps component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xtyle.component.steps"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.steps": [
			{
				"id": "steps",
				"format": "text/html+jsml",
				"source": "steps.html",
				"meta": {
					"tokens": [
						"--space-2",
						"--accent",
						"--accent-fg",
						"--accent-text",
						"--bg-0",
						"--bg-1",
						"--fg-0",
						"--fg-1",
						"--fg-2",
						"--line",
						"--border-thick",
						"--radius-full",
						"--text-sm",
						"--weight-semibold",
						"--weight-medium"
					]
				}
			}
		]
	}
}
