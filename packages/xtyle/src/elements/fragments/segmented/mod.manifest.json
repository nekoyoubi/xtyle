{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-segmented-default",
	"version": "0.0.1",
	"title": "Xtyle Segmented (default)",
	"description": "The built-in fill for the xtyle Segmented component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xtyle.component.segmented"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.segmented": [
			{
				"id": "segmented",
				"format": "text/html+jsml",
				"source": "segmented.html",
				"handlers": [
					{ "selector": "[role=\"radio\"]", "on": "click", "handler": "selectOption" },
					{ "selector": "[role=\"radio\"]", "on": "keydown", "handler": "navKeydown" }
				],
				"meta": {
					"tokens": [
						"--accent",
						"--accent-fg",
						"--bg-1",
						"--border-normal",
						"--border-thick",
						"--border-thin",
						"--duration-fast",
						"--ease-standard",
						"--fg-0",
						"--fg-1",
						"--fg-disabled",
						"--font-sans",
						"--line-2",
						"--radius-md",
						"--radius-sm",
						"--ring",
						"--space-1",
						"--space-2",
						"--space-3",
						"--space-4",
						"--state-disabled",
						"--state-hover",
						"--state-press",
						"--text-body",
						"--text-sm",
						"--weight-medium"
					]
				}
			}
		]
	}
}
