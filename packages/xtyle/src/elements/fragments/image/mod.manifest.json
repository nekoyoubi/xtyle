{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-image-default",
	"version": "0.0.1",
	"title": "Xtyle Image (default)",
	"description": "The built-in fill for the xtyle Image component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xtyle.component.image"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.image": [
			{
				"id": "image",
				"format": "text/html+jsml",
				"source": "image.html",
				"handlers": [
					{ "selector": ".xtyle-image__zoom", "on": "click", "handler": "zoom" },
					{ "selector": ".xtyle-image__audio", "on": "click", "handler": "audio" }
				],
				"meta": {
					"tokens": [
						"--bg-1",
						"--bg-2",
						"--bg-3",
						"--fg-1",
						"--fg-2",
						"--radius-sm",
						"--radius-md",
						"--radius-lg",
						"--radius-full",
						"--border-thin",
						"--border-thick",
						"--surface-overlay-border",
						"--elevation-3",
						"--ring",
						"--duration-fast",
						"--duration-slow",
						"--ease-standard",
						"--text-sm",
						"--leading-normal",
						"--space-2",
						"--space-7"
					]
				}
			}
		]
	}
}
