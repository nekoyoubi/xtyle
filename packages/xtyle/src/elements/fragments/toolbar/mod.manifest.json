{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-toolbar-default",
	"version": "0.0.1",
	"title": "Xtyle Toolbar (default)",
	"description": "The built-in fill for the xtyle Toolbar component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xtyle.component.toolbar"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.toolbar": [
			{
				"id": "toolbar",
				"format": "text/html+jsml",
				"source": "toolbar.html",
				"meta": {
					"tokens": [
						"--bg-1",
						"--border-normal",
						"--border-thick",
						"--border-thin",
						"--elevation-3",
						"--fg-0",
						"--fg-1",
						"--font-display",
						"--font-sans",
						"--leading-tight",
						"--line",
						"--link-hover",
						"--radius-sm",
						"--ring",
						"--space-1",
						"--space-2",
						"--space-3",
						"--space-4",
						"--space-5",
						"--space-7",
						"--space-8",
						"--text-lg",
						"--weight-bold"
					]
				}
			}
		]
	}
}
