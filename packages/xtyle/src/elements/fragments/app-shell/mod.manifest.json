{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-app-shell-default",
	"version": "0.0.1",
	"title": "Xtyle App Shell (default)",
	"description": "The built-in fill for the xtyle App Shell component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xtyle.component.app-shell"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.app-shell": [
			{
				"id": "app-shell",
				"format": "text/html+jsml",
				"source": "app-shell.html",
				"meta": {
					"consumes": [
						"--body-bg",
						"--fg-0",
						"--font-sans",
						"--text-body",
						"--leading-normal",
						"--space-5",
						"--space-4",
						"--space-3",
						"--space-2",
						"--border-normal",
						"--border-thick",
						"--border-thin",
						"--ring",
						"--text-sm",
						"--weight-medium",
						"--leading-tight",
						"--accent",
						"--accent-fg",
						"--radius-md",
						"--duration-fast",
						"--ease-standard"
					]
				}
			}
		]
	}
}
