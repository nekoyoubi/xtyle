{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-spinner-default",
	"version": "0.0.1",
	"title": "Xtyle Spinner (default)",
	"description": "The built-in fill for the xtyle Spinner component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xtyle.component.spinner"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.spinner": [
			{
				"id": "spinner",
				"format": "text/html+jsml",
				"source": "spinner.html",
				"meta": {
					"tokens": [
						"--accent",
						"--neutral",
						"--danger",
						"--success",
						"--warn",
						"--info",
						"--border-thick",
						"--border-normal",
						"--radius-full",
						"--duration-slow"
					]
				}
			}
		]
	}
}
