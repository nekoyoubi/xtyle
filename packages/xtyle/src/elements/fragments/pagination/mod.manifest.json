{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-pagination-default",
	"version": "0.0.1",
	"title": "Xtyle Pagination (default)",
	"description": "The built-in fill for the xtyle Pagination component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xtyle.component.pagination"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.pagination": [
			{
				"id": "pagination",
				"format": "text/html+jsml",
				"source": "pagination.html",
				"meta": {
					"tokens": [
						"--accent",
						"--accent-fg",
						"--bg-2",
						"--border-normal",
						"--border-thick",
						"--border-thin",
						"--danger",
						"--danger-fg",
						"--duration-fast",
						"--ease-standard",
						"--fg-1",
						"--fg-2",
						"--fg-3",
						"--font-sans",
						"--info",
						"--info-fg",
						"--leading-normal",
						"--neutral",
						"--neutral-fg",
						"--radius-sm",
						"--ring",
						"--space-0",
						"--space-1",
						"--success",
						"--success-fg",
						"--text-body",
						"--text-sm",
						"--text-xs",
						"--warn",
						"--warn-fg",
						"--weight-medium"
					]
				}
			}
		]
	}
}
