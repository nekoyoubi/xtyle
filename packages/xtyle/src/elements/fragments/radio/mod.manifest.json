{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-radio-default",
	"version": "0.0.1",
	"title": "Xtyle Radio (default)",
	"description": "The built-in fill for the xtyle Radio component: the mod-zero markup and behavior every app inherits and may override.",
	"capabilities": ["xtyle.component.radio"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.radio": [
			{
				"id": "radio",
				"format": "text/html+jsml",
				"source": "radio.html",
				"handlers": [{ "selector": ".xtyle-radio__control", "on": "change", "handler": "select" }],
				"meta": {
					"tokens": [
						"--accent",
						"--accent-fg",
						"--border-normal",
						"--border-thick",
						"--danger",
						"--danger-fg",
						"--duration-fast",
						"--ease-emphasized",
						"--ease-standard",
						"--fg-0",
						"--fg-disabled",
						"--field-bg",
						"--field-border",
						"--font-sans",
						"--info",
						"--info-fg",
						"--leading-normal",
						"--line",
						"--line-2",
						"--neutral",
						"--neutral-fg",
						"--radius-full",
						"--ring",
						"--space-1",
						"--space-2",
						"--space-3",
						"--state-disabled",
						"--state-hover",
						"--success",
						"--success-fg",
						"--text-body",
						"--text-lg",
						"--text-sm",
						"--warn",
						"--warn-fg"
					]
				}
			}
		]
	}
}
