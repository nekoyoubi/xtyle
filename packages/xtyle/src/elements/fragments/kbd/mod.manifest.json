{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-kbd-default",
	"version": "0.0.1",
	"title": "Xtyle Kbd (default)",
	"description": "The built-in fill for the xtyle Kbd component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xtyle.component.kbd"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.kbd": [
			{
				"id": "kbd",
				"format": "text/html+jsml",
				"source": "kbd.html",
				"meta": {
					"tokens": [
						"--border-thin",
						"--border-thick",
						"--line-2",
						"--radius-sm",
						"--bg-2",
						"--fg-1",
						"--font-mono",
						"--text-xs",
						"--text-sm",
						"--text-lg",
						"--weight-medium",
						"--leading-tight"
					]
				}
			}
		]
	}
}
