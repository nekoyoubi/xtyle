{
	"$schema": "https://xript.dev/schema/mod/v0.7.json",
	"xript": "0.7",
	"name": "xtyle-bottom-nav-default",
	"version": "0.0.1",
	"title": "Xtyle BottomNav (default)",
	"description": "The built-in fill for the xtyle BottomNav component: the mod-zero markup every app inherits and may override.",
	"capabilities": ["xtyle.component.bottom-nav"],
	"entry": { "script": "mod.js", "format": "script" },
	"fills": {
		"component.bottom-nav": [
			{
				"id": "bottom-nav",
				"format": "text/html+jsml",
				"source": "bottom-nav.html",
				"meta": {
					"tokens": [
						"--bg-1",
						"--line",
						"--fg-3",
						"--accent",
						"--accent-fg",
						"--accent-text",
						"--ring",
						"--radius-sm",
						"--radius-full",
						"--border-thin",
						"--border-thick",
						"--text-xs",
						"--weight-medium",
						"--weight-semibold",
						"--space-1",
						"--space-2",
						"--space-4",
						"--space-6",
						"--space-8",
						"--duration-fast",
						"--ease-standard"
					]
				}
			}
		]
	}
}
